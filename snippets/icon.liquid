{% comment %}
  SVG icon system.
  Usage: {% render 'icon', name: 'search' %}
  Optional: {% render 'icon', name: 'search', size: 24 %}
{% endcomment %}

{%- liquid
  unless size
    assign size = 20
  endunless
-%}

