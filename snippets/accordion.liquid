{% comment %}
  Accordion snippet.
  Usage: {% render 'accordion', title: 'Section title', content: '<p>Content here</p>', id: 'unique-id' %}
  Optional: {% render 'accordion', title: 'Title', content: content, id: 'id', open: true %}
{% endcomment %}

{%- liquid
  unless id
    assign id = title | handleize | append: '-' | append: 'now' | date: '%s'
  endunless
  unless open
    assign open = false
  endunless
-%}

<accordion-toggle class="accordion{% if open %} is-open{% endif %}">
  <button
    class="accordion__trigger"
    data-accordion-trigger
    aria-expanded="{{ open }}"
    aria-controls="accordion-panel-{{ id }}"
    id="accordion-trigger-{{ id }}"
  >
    <span class="accordion__title">{{ title }}</span>
    <span class="accordion__icon">
      {% render 'icon', name: 'chevron-down', size: 16 %}
    </span>
  </button>
  <div
    class="accordion__panel{% if open %} is-open{% endif %}"
    id="accordion-panel-{{ id }}"
    role="region"
    aria-labelledby="accordion-trigger-{{ id }}"
    {% unless open %}hidden{% endunless %}
  >
    <div class="accordion__content">
      {{ content }}
    </div>
  </div>
</accordion-toggle>

