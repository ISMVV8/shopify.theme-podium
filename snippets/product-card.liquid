{% comment %}
  Product card snippet.
  Usage: {% render 'product-card', product: product %}
  Optional: {% render 'product-card', product: product, show_wishlist: true %}
{% endcomment %}

{%- liquid
  unless show_wishlist == false
    assign show_wishlist = true
  endunless
-%}

<article class="product-card">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}">
    <div class="product-card__image-wrap">
      {%- if product.featured_media -%}
        <img
          class="product-card__image"
          src="{{ product.featured_media | image_url: width: 600 }}"
          alt="{{ product.featured_media.alt | escape | default: product.title }}"
          width="600"
          height="{{ 600 | divided_by: product.featured_media.aspect_ratio | round }}"
          loading="lazy"
          srcset="
            {{ product.featured_media | image_url: width: 300 }} 300w,
            {{ product.featured_media | image_url: width: 450 }} 450w,
            {{ product.featured_media | image_url: width: 600 }} 600w,
            {{ product.featured_media | image_url: width: 800 }} 800w
          "
          sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw"
        >
        {%- if product.media.size > 1 -%}
          <img
            class="product-card__image product-card__image--hover"
            src="{{ product.media[1] | image_url: width: 600 }}"
            alt="{{ product.media[1].alt | escape | default: product.title }}"
            width="600"
            height="{{ 600 | divided_by: product.media[1].aspect_ratio | round }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        <div class="product-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__badge product-card__badge--sale">
          -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
        </span>
      {%- endif -%}

      {%- if product.available == false -%}
        <span class="product-card__badge product-card__badge--soldout">
          {{ 'product.sold_out' | t }}
        </span>
      {%- endif -%}

      {%- comment -%} Quick Buy Overlay {%- endcomment -%}
      {%- if product.available -%}
        {%- assign has_size_option = false -%}
        {%- assign size_option_index = nil -%}
        {%- for option in product.options_with_values -%}
          {%- assign option_name_lower = option.name | downcase -%}
          {%- if option_name_lower == 'size' or option_name_lower == 'taille' -%}
            {%- assign has_size_option = true -%}
            {%- assign size_option = option -%}
            {%- assign size_option_index = forloop.index0 -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        <div class="quick-buy" data-quick-buy>
          {%- if has_size_option -%}
            <div class="quick-buy__sizes">
              {%- for size_value in size_option.values -%}
                {%- liquid
                  assign size_available = false
                  assign size_variant_id = nil
                  for variant in product.variants
                    if variant.options[size_option_index] == size_value and variant.available
                      assign size_available = true
                      assign size_variant_id = variant.id
                      break
                    endif
                  endfor
                -%}
                <button
                  type="button"
                  class="quick-buy__size{% unless size_available %} quick-buy__size--disabled{% endunless %}"
                  data-quick-add-variant="{{ size_variant_id }}"
                  {% unless size_available %}disabled{% endunless %}
                  aria-label="{{ size_value }}"
                >
                  {{ size_value }}
                </button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <button
              type="button"
              class="quick-buy__atc"
              data-quick-add-variant="{{ product.first_available_variant.id }}"
            >
              {{ 'product.add_to_cart' | t }}
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-card__info">
      <h3 class="product-card__title">{{ product.title }}</h3>
      {%- if product.variants.size > 1 -%}
        <p class="product-card__subtitle">
          {%- for option in product.options_with_values -%}
            {%- if option.name == 'Color' or option.name == 'Couleur' -%}
              {{ option.values | join: ' / ' }}
            {%- endif -%}
          {%- endfor -%}
        </p>
      {%- endif -%}
      <div class="product-card__price">
        {% render 'price', product: product %}
      </div>
    </div>
  </a>

  {%- if show_wishlist -%}
    <button class="product-card__wishlist btn--icon" data-wishlist-toggle data-product-handle="{{ product.handle }}" aria-label="{{ 'header.wishlist' | t }}">
      {% render 'icon', name: 'heart', size: 18 %}
    </button>
  {%- endif -%}
</article>
