<!DOCTYPE html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- comment -%} CSS Variables from theme settings – inlined directly {%- endcomment -%}
  <style>
    :root {
      --color-bg: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-text-secondary: {{ settings.color_text_secondary }};
      --color-border: {{ settings.color_border }};
      --color-btn-bg: {{ settings.color_button_bg }};
      --color-btn-text: {{ settings.color_button_text }};
      --color-btn-secondary-bg: {{ settings.color_button_secondary_bg }};
      --color-btn-secondary-text: {{ settings.color_button_secondary_text }};
      --color-sale: {{ settings.color_sale }};
      --color-overlay: {{ settings.color_overlay }};

      --font-body: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      --font-body-weight: 400;
      --font-body-style: normal;
      --font-heading: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      --font-heading-weight: 600;
      --font-heading-style: normal;
      --font-body-size: {{ settings.font_body_size }}px;
      --font-heading-scale: {{ settings.font_heading_scale | times: 1.0 | divided_by: 100.0 }};

      --radius: {{ settings.border_radius }}px;
      --page-width: {{ settings.page_width }}px;
      {%- assign spacing_ratio = settings.spacing_scale | times: 1.0 | divided_by: 100.0 -%}
      --spacing-scale: {{ spacing_ratio }};

      --space-xs: calc(4px * {{ spacing_ratio }});
      --space-sm: calc(8px * {{ spacing_ratio }});
      --space-md: calc(16px * {{ spacing_ratio }});
      --space-lg: calc(24px * {{ spacing_ratio }});
      --space-xl: calc(40px * {{ spacing_ratio }});
      --space-2xl: calc(64px * {{ spacing_ratio }});
      --space-3xl: calc(96px * {{ spacing_ratio }});

      --z-header: 100;
      --z-overlay: 200;
      --z-drawer: 300;
      --z-modal: 400;

      --duration-fast: 150ms;
      --duration-base: 250ms;
      --duration-slow: 400ms;
      --ease: cubic-bezier(0.25, 0.1, 0.25, 1);
    }
  </style>

  {%- comment -%} Theme stylesheet {%- endcomment -%}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Liquid objects for JS {%- endcomment -%}
  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.Shopify = window.Shopify || {};
    window.Shopify.routes = {
      root: '{{ routes.root_url }}',
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      search_url: '{{ routes.search_url }}'
    };
    window.Shopify.money_format = {{ shop.money_format | json }};
    window.Shopify.locale = {{ request.locale.iso_code | json }};
  </script>

  {{ content_for_header }}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a href="#main-content" class="visually-hidden focus-visible-only">
    {{ 'general.skip_to_content' | t }}
  </a>

  <div class="overlay-bg" data-overlay></div>

  {% section 'announcement-bar' %}
  {% section 'header' %}
  {% section 'search-overlay' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {% section 'cart-drawer' %}

  <!-- Quick Add Bottom Sheet -->
  <div class="quick-sheet" id="quick-sheet" aria-hidden="true">
    <div class="quick-sheet__backdrop" data-quick-sheet-close></div>
    <div class="quick-sheet__panel">
      <div class="quick-sheet__header">
        <button class="quick-sheet__close btn--icon" data-quick-sheet-close aria-label="{{ 'cart.close' | t | default: 'Fermer' }}">
          {% render 'icon', name: 'close', size: 18 %}
        </button>
        <span class="quick-sheet__heading">{{ 'product.add_to_cart' | t | default: 'Ajouter ce produit' }}</span>
      </div>
      <div class="quick-sheet__product">
        <img class="quick-sheet__img" src="" alt="" width="100" height="100" data-quick-sheet-img>
        <div class="quick-sheet__details">
          <h3 class="quick-sheet__title" data-quick-sheet-title></h3>
          <p class="quick-sheet__variant-label" data-quick-sheet-variant-label></p>
          <p class="quick-sheet__price" data-quick-sheet-price></p>
        </div>
      </div>
      <div class="quick-sheet__options" data-quick-sheet-options></div>
      <button class="quick-sheet__atc btn btn--primary btn--full btn--large" data-quick-sheet-atc disabled>
        {{ 'product.add_to_cart' | t | default: 'AJOUTER AU PANIER' }}
      </button>
      <a class="quick-sheet__more" href="#" data-quick-sheet-link>
        {{ 'product.view_details' | t | default: 'Plus de détails' }}
      </a>

      {%- comment -%} Vous aimerez aussi – Recommendations in quick sheet {%- endcomment -%}
      <div class="cart-reco cart-reco--sheet" data-sheet-reco>
        <div class="cart-reco__header">
          <h3 class="cart-reco__title">{{ 'product.you_may_like' | t }}</h3>
        </div>
        <div class="cart-reco__scroll" data-sheet-reco-scroll>
          {%- comment -%} Products loaded via JS {%- endcomment -%}
        </div>
      </div>
    </div>
  </div>

  <!-- Size Guide Modal -->
  <div class="sg-modal" id="size-guide-modal" aria-hidden="true">
    <div class="sg-modal__backdrop" data-sg-close></div>
    <div class="sg-modal__panel">
      <div class="sg-modal__header">
        <button class="sg-modal__close btn--icon" data-sg-close aria-label="Fermer">
          {% render 'icon', name: 'close', size: 18 %}
        </button>
        <span class="sg-modal__heading">Trouver ma taille</span>
      </div>

      <div class="sg-modal__body">
        {%- comment -%} Step 1: Morphology {%- endcomment -%}
        <div class="sg-step" data-sg-step="1">
          <p class="sg-step__label">Quelle est votre morphologie ?</p>
          <div class="sg-morpho-grid">
            <button type="button" class="sg-morpho-card" data-sg-morpho="slim">
              <div class="sg-morpho-card__icon">
                <svg width="32" height="64" viewBox="0 0 32 64" fill="none"><ellipse cx="16" cy="8" rx="6" ry="7" stroke="currentColor" stroke-width="1.5"/><path d="M12 18c-3 2-5 8-5 16s1 12 2 16h14c1-4 2-8 2-16s-2-14-5-16" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
              </div>
              <span class="sg-morpho-card__label">Mince</span>
            </button>
            <button type="button" class="sg-morpho-card" data-sg-morpho="regular">
              <div class="sg-morpho-card__icon">
                <svg width="36" height="64" viewBox="0 0 36 64" fill="none"><ellipse cx="18" cy="8" rx="7" ry="7" stroke="currentColor" stroke-width="1.5"/><path d="M12 18c-4 3-6 9-6 16s2 12 3 16h18c1-4 3-8 3-16s-2-13-6-16" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
              </div>
              <span class="sg-morpho-card__label">Standard</span>
            </button>
            <button type="button" class="sg-morpho-card" data-sg-morpho="athletic">
              <div class="sg-morpho-card__icon">
                <svg width="40" height="64" viewBox="0 0 40 64" fill="none"><ellipse cx="20" cy="8" rx="7" ry="7" stroke="currentColor" stroke-width="1.5"/><path d="M11 18c-4 3-6 8-5 14s2 14 3 18h22c1-4 2-12 3-18s-1-11-5-14" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
              </div>
              <span class="sg-morpho-card__label">Athlétique</span>
            </button>
            <button type="button" class="sg-morpho-card" data-sg-morpho="curvy">
              <div class="sg-morpho-card__icon">
                <svg width="44" height="64" viewBox="0 0 44 64" fill="none"><ellipse cx="22" cy="8" rx="7" ry="7" stroke="currentColor" stroke-width="1.5"/><path d="M12 18c-5 4-8 10-7 16s3 12 4 16h26c1-4 3-8 4-16s-2-12-7-16" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
              </div>
              <span class="sg-morpho-card__label">Généreux</span>
            </button>
          </div>
        </div>

        {%- comment -%} Step 2: Measurements {%- endcomment -%}
        <div class="sg-step" data-sg-step="2">
          <p class="sg-step__label">Vos mensurations</p>
          <div class="sg-fields">
            <div class="sg-field">
              <label class="sg-field__label" for="sg-height">Taille (cm)</label>
              <input type="number" id="sg-height" class="sg-field__input" data-sg-height placeholder="170" min="140" max="210">
            </div>
            <div class="sg-field">
              <label class="sg-field__label" for="sg-weight">Poids (kg)</label>
              <input type="number" id="sg-weight" class="sg-field__input" data-sg-weight placeholder="65" min="35" max="180">
            </div>
            <div class="sg-field">
              <label class="sg-field__label" for="sg-chest">Tour de poitrine (cm)</label>
              <input type="number" id="sg-chest" class="sg-field__input" data-sg-chest placeholder="90" min="60" max="150">
            </div>
            <div class="sg-field">
              <label class="sg-field__label" for="sg-waist">Tour de taille (cm)</label>
              <input type="number" id="sg-waist" class="sg-field__input" data-sg-waist placeholder="72" min="50" max="140">
            </div>
            <div class="sg-field">
              <label class="sg-field__label" for="sg-hips">Tour de hanches (cm)</label>
              <input type="number" id="sg-hips" class="sg-field__input" data-sg-hips placeholder="96" min="60" max="160">
            </div>
          </div>
          <p class="sg-step__hint">Renseignez au moins votre taille et votre poids pour une recommandation.</p>
        </div>

        {%- comment -%} Step 3: Fit preference {%- endcomment -%}
        <div class="sg-step" data-sg-step="3">
          <p class="sg-step__label">Votre préférence de coupe</p>
          <div class="sg-fit-options">
            <button type="button" class="sg-fit-btn" data-sg-fit="tight">
              <span class="sg-fit-btn__name">Ajusté</span>
              <span class="sg-fit-btn__desc">Près du corps</span>
            </button>
            <button type="button" class="sg-fit-btn is-selected" data-sg-fit="regular">
              <span class="sg-fit-btn__name">Classique</span>
              <span class="sg-fit-btn__desc">Coupe normale</span>
            </button>
            <button type="button" class="sg-fit-btn" data-sg-fit="loose">
              <span class="sg-fit-btn__name">Ample</span>
              <span class="sg-fit-btn__desc">Coupe décontractée</span>
            </button>
          </div>
        </div>

        {%- comment -%} Result {%- endcomment -%}
        <div class="sg-result" data-sg-result style="display:none;">
          <div class="sg-result__box">
            <span class="sg-result__label">Votre taille recommandée</span>
            <span class="sg-result__size" data-sg-result-size>M</span>
          </div>
          <p class="sg-result__note" data-sg-result-note></p>
        </div>

        <button type="button" class="sg-modal__cta btn btn--primary btn--full" data-sg-calculate>
          Trouver ma taille
        </button>

        {%- comment -%} Size chart table {%- endcomment -%}
        <div class="sg-chart">
          <p class="sg-chart__title">Correspondances des tailles</p>
          <div class="sg-chart__scroll">
            <table class="sg-chart__table">
              <thead>
                <tr>
                  <th>Taille</th>
                  <th>Poitrine</th>
                  <th>Taille</th>
                  <th>Hanches</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>XS</td><td>80-84</td><td>60-64</td><td>86-90</td></tr>
                <tr><td>S</td><td>84-88</td><td>64-68</td><td>90-94</td></tr>
                <tr><td>M</td><td>88-92</td><td>68-72</td><td>94-98</td></tr>
                <tr><td>L</td><td>92-96</td><td>72-78</td><td>98-104</td></tr>
                <tr><td>XL</td><td>96-102</td><td>78-84</td><td>104-110</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>

