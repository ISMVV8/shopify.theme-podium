{%- comment -%}
  Product page — Merrachi-inspired minimal layout
  50/50 split: image left (with dot nav), info right (tabs, cross-sell)
  Scoped class prefix: pp-
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_image = product.featured_media
-%}

<section class="pp-section">
  <div class="pp-layout">

    {%- comment -%} ═══ LEFT — Gallery with dot navigation ═══ {%- endcomment -%}
    <product-gallery class="pp-gallery">
      {%- if product.media.size > 1 -%}
        <div class="pp-gallery__dots">
          {%- for media in product.media -%}
            <button
              class="pp-dot{% if forloop.first %} is-active{% endif %}"
              data-dot="{{ forloop.index0 }}"
              aria-label="Image {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="pp-gallery__main">
        {%- if first_image -%}
          <img
            data-main-image
            src="{{ first_image | image_url: width: 1400 }}"
            alt="{{ first_image.alt | escape | default: product.title }}"
            width="1400"
            height="{{ 1400 | divided_by: first_image.aspect_ratio | round }}"
          >
        {%- else -%}
          <div class="pp-gallery__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'pp-gallery__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <script type="application/json" data-gallery-images>
        [
          {%- for media in product.media -%}
            {
              "src": {{ media | image_url: width: 1400 | json }},
              "alt": {{ media.alt | default: product.title | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      </script>
    </product-gallery>

    {%- comment -%} ═══ RIGHT — Product information ═══ {%- endcomment -%}
    <div class="pp-info">

      {%- comment -%} Color / variant label {%- endcomment -%}
      {%- for option in product.options_with_values -%}
        {%- if option.name == 'Color' or option.name == 'Couleur' -%}
          <p class="pp-variant-label" data-color-name>{{ option.selected_value }}</p>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Title {%- endcomment -%}
      <h1 class="pp-title">{{ product.title }}</h1>

      {%- comment -%} Price {%- endcomment -%}
      <p class="pp-price">
        <span data-product-price>{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pp-price--compare" data-compare-price>
            <s>{{ current_variant.compare_at_price | money }}</s>
          </span>
        {%- else -%}
          <span class="pp-price--compare" data-compare-price style="display:none;"></span>
        {%- endif -%}
      </p>

      {%- comment -%} ── Product form ── {%- endcomment -%}
      {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
        <variant-selector>
          <script type="application/json" data-variants>{{ product.variants | json }}</script>

          {%- for option in product.options_with_values -%}
            {%- if option.name == 'Color' or option.name == 'Couleur' -%}
              {%- comment -%} Color swatches — small circles {%- endcomment -%}
              <div class="pp-swatches">
                {%- for value in option.values -%}
                  {%- liquid
                    assign variant_for_color = nil
                    for variant in product.variants
                      if variant.options[forloop.parentloop.index0] == value
                        assign variant_for_color = variant
                        break
                      endif
                    endfor
                  -%}
                  <button
                    type="button"
                    class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                    data-option
                    data-option-position="{{ forloop.parentloop.index }}"
                    data-value="{{ value }}"
                    aria-label="{{ value }}"
                    title="{{ value }}"
                  >
                    {%- if variant_for_color and variant_for_color.featured_image -%}
                      <img src="{{ variant_for_color.featured_image | image_url: width: 80 }}" alt="{{ value }}" width="32" height="32">
                    {%- else -%}
                      <span class="pp-swatch__color" style="background-color: {{ value | handleize }};"></span>
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>

            {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
              {%- comment -%} Model info blocks (rendered above sizes) {%- endcomment -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'model_info' -%}
                  <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} Size options + Size Chart link {%- endcomment -%}
              <div class="pp-size-row">
                <div class="pp-sizes">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                      data-option
                      data-option-position="{{ forloop.parentloop.index }}"
                      data-value="{{ value }}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
                {%- if section.settings.size_guide_url != blank -%}
                  <a href="{{ section.settings.size_guide_url }}" class="pp-size-guide">Size Chart</a>
                {%- endif -%}
              </div>

            {%- else -%}
              {%- comment -%} Generic option {%- endcomment -%}
              <p class="pp-option-label">{{ option.name }}</p>
              <div class="pp-sizes">
                {%- for value in option.values -%}
                  <button
                    type="button"
                    class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                    data-option
                    data-option-position="{{ forloop.parentloop.index }}"
                    data-value="{{ value }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endfor -%}

          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" value="1">
        </variant-selector>

        {%- comment -%} Add to cart {%- endcomment -%}
        <button
          type="submit"
          class="pp-add-btn"
          data-add-to-cart
          data-add-text="{{ 'product.add_to_cart' | t }}"
          data-soldout-text="{{ 'product.sold_out' | t }}"
          data-unavailable-text="{{ 'product.unavailable' | t }}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            {{ 'product.add_to_cart' | t }}
          {%- else -%}
            {{ 'product.sold_out' | t }}
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- comment -%} ── Tabs (Description + custom tabs) ── {%- endcomment -%}
      {%- liquid
        assign has_tabs = false
        if product.description != blank
          assign has_tabs = true
        endif
        for block in section.blocks
          if block.type == 'tab'
            assign has_tabs = true
            break
          endif
        endfor
      -%}

      {%- if has_tabs -%}
        <product-tabs class="pp-tabs">
          <div class="pp-tabs__nav" role="tablist">
            {%- if product.description != blank -%}
              <button class="pp-tab-btn is-active" role="tab" data-tab="description" aria-selected="true">Description</button>
            {%- endif -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <button class="pp-tab-btn" role="tab" data-tab="{{ block.id }}" aria-selected="false" {{ block.shopify_attributes }}>{{ block.settings.title }}</button>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <div class="pp-tabs__content">
            {%- if product.description != blank -%}
              <div class="pp-tab-panel is-active" data-tab-panel="description">
                {{ product.description }}
              </div>
            {%- endif -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <div class="pp-tab-panel" data-tab-panel="{{ block.id }}">
                  {{ block.settings.content }}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </product-tabs>
      {%- endif -%}

      {%- comment -%} ── Cross-sell: Complete the look ── {%- endcomment -%}
      {%- liquid
        assign has_cross_sell = false
        for block in section.blocks
          if block.type == 'cross_sell_product' and block.settings.product != blank
            assign has_cross_sell = true
            break
          endif
        endfor
      -%}

      {%- if has_cross_sell -%}
        <div class="pp-cross-sell">
          <h3 class="pp-cross-sell__heading">{{ section.settings.cross_sell_heading | default: 'Complete the look' }}</h3>
          <div class="pp-cross-sell__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'cross_sell_product' and block.settings.product != blank -%}
                {%- assign cs = block.settings.product -%}
                <div class="pp-cross-item" {{ block.shopify_attributes }}>
                  <a href="{{ cs.url }}" class="pp-cross-item__image">
                    {%- if cs.featured_media -%}
                      <img
                        src="{{ cs.featured_media | image_url: width: 200 }}"
                        alt="{{ cs.featured_media.alt | escape | default: cs.title }}"
                        width="90"
                        height="117"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </a>
                  <div class="pp-cross-item__details">
                    <div class="pp-cross-item__header">
                      <a href="{{ cs.url }}" class="pp-cross-item__name">{{ cs.title }}</a>
                      <span class="pp-cross-item__price">{{ cs.price | money }}</span>
                    </div>
                    {%- for cs_option in cs.options_with_values -%}
                      {%- if cs_option.name == 'Color' or cs_option.name == 'Couleur' -%}
                        <span class="pp-cross-item__variant">{{ cs_option.selected_value }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                    {%- for cs_option in cs.options_with_values -%}
                      {%- if cs_option.name == 'Size' or cs_option.name == 'Taille' -%}
                        <div class="pp-cross-item__sizes">
                          {%- for value in cs_option.values -%}
                            <span class="pp-cross-item__size-pill">{{ value }}</span>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
/* ============================================================
   PRODUCT PAGE — Merrachi-inspired minimal layout (pp-*)
   Pixel-perfect dimensions matched to reference screenshot
   ============================================================ */

.pp-section {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.pp-section *, .pp-section *::before, .pp-section *::after {
  font-family: inherit;
  box-sizing: border-box;
}

/* ── Layout: image 52% / info 48% ── */

.pp-layout {
  display: grid;
  grid-template-columns: 52% 1fr;
  min-height: calc(100vh - 80px);
}

/* ═══════════════════════════════════════════════
   LEFT — Gallery (edge-to-edge, no padding)
   ═══════════════════════════════════════════════ */

.pp-gallery {
  position: relative;
  display: block;
  background: #f5f3ef;
  overflow: hidden;
}

.pp-gallery__main {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.pp-gallery__main img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: top center;
}

.pp-gallery__placeholder {
  width: 100%;
  height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ede8;
}

.pp-gallery__placeholder-svg {
  width: 40%;
  opacity: 0.3;
}

/* Dot navigation — vertically centered, 28px from left */

.pp-gallery__dots {
  position: absolute;
  left: 28px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  z-index: 2;
}

.pp-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #c0bdb8;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.25s ease;
}

.pp-dot.is-active {
  width: 8px;
  height: 8px;
  background: #222;
}

.pp-dot:hover:not(.is-active) {
  background: #888;
}

/* ═══════════════════════════════════════════════
   RIGHT — Product info
   Padding: 50px top, 48px right, 64px bottom, 64px left
   ═══════════════════════════════════════════════ */

.pp-info {
  padding: 50px 48px 64px 64px;
  border-left: 1px solid #e8e6e2;
  overflow-y: auto;
}

/* ── Variant / color label ── */

.pp-variant-label {
  font-size: 13px;
  color: #888;
  margin: 0 0 6px;
  font-weight: 400;
  letter-spacing: 0.01em;
}

/* ── Title ── */

.pp-title {
  font-family: inherit;
  font-size: 22px;
  font-weight: 500;
  letter-spacing: -0.01em;
  line-height: 1.3;
  margin: 0 0 12px;
  color: #1a1a1a;
}

/* ── Price ── */

.pp-price {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin: 0 0 32px;
  font-size: 16px;
  font-weight: 400;
  color: #1a1a1a;
}

.pp-price--compare {
  font-size: 14px;
  color: #aaa;
}

.pp-price--compare s {
  text-decoration: line-through;
}

/* ── Color swatches (small circles, 26px) ── */

.pp-swatches {
  display: flex;
  gap: 10px;
  margin-bottom: 24px;
}

.pp-swatch {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  border: 1.5px solid #d5d3d0;
  overflow: hidden;
  cursor: pointer;
  padding: 2px;
  transition: border-color 0.2s;
  background: none;
}

.pp-swatch.is-active {
  border-color: #333;
}

.pp-swatch:hover:not(.is-active) {
  border-color: #999;
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

.pp-swatch__color {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Model info ── */

.pp-model-info {
  font-size: 13px;
  color: #666;
  margin: 0 0 28px;
  line-height: 1.55;
}

/* ── Size row: sizes left, size chart right ── */

.pp-size-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
}

.pp-sizes {
  display: flex;
  gap: 22px;
  flex-wrap: wrap;
  align-items: center;
}

.pp-size {
  background: none;
  border: none;
  padding: 6px 0;
  font-family: inherit;
  font-size: 14px;
  cursor: pointer;
  color: #555;
  transition: all 0.2s;
  letter-spacing: 0.03em;
  position: relative;
}

.pp-size::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1.5px;
  background: #1a1a1a;
  transform: scaleX(0);
  transition: transform 0.2s;
}

.pp-size.is-active {
  color: #1a1a1a;
  font-weight: 500;
}

.pp-size.is-active::after {
  transform: scaleX(1);
}

.pp-size:hover:not(.is-active) {
  color: #1a1a1a;
}

.pp-size:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  text-decoration: line-through;
}

.pp-size-guide {
  font-size: 13px;
  color: #555;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  transition: color 0.2s;
  white-space: nowrap;
}

.pp-size-guide:hover {
  color: #1a1a1a;
}

/* ── Option label (generic) ── */

.pp-option-label {
  font-size: 14px;
  color: #666;
  margin: 0 0 12px;
}

/* ── Add to cart — 50px height, full width, dark ── */

.pp-add-btn {
  width: 100%;
  height: 50px;
  margin-top: 0;
  background: #1a1a1a;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-family: inherit;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: background 0.2s;
}

.pp-add-btn:hover {
  background: #333;
}

.pp-add-btn:disabled {
  background: #ccc;
  cursor: not-allowed;
}

/* ═══════════════════════════════════════════════
   TABS — 40px below button
   ═══════════════════════════════════════════════ */

.pp-tabs {
  display: block;
  margin-top: 40px;
}

.pp-tabs__nav {
  display: flex;
  gap: 28px;
  border-bottom: 1px solid #e8e6e2;
  padding-bottom: 0;
}

.pp-tab-btn {
  background: none;
  border: none;
  padding: 0 0 16px;
  font-family: inherit;
  font-size: 14px;
  font-weight: 400;
  color: #aaa;
  cursor: pointer;
  transition: color 0.2s;
  position: relative;
  white-space: nowrap;
}

.pp-tab-btn::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 1.5px;
  background: #1a1a1a;
  transform: scaleX(0);
  transition: transform 0.25s ease;
}

.pp-tab-btn.is-active {
  color: #1a1a1a;
  font-weight: 400;
}

.pp-tab-btn.is-active::after {
  transform: scaleX(1);
}

.pp-tab-btn:hover:not(.is-active) {
  color: #666;
}

/* Tab content — 24px below border */

.pp-tabs__content {
  padding-top: 24px;
}

.pp-tab-panel {
  display: none;
  font-size: 14px;
  line-height: 1.7;
  color: #444;
}

.pp-tab-panel.is-active {
  display: block;
}

.pp-tab-panel p {
  margin: 0 0 12px;
}

.pp-tab-panel p:last-child {
  margin-bottom: 0;
}

.pp-tab-panel a {
  color: #1a1a1a;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.pp-tab-panel ul, .pp-tab-panel ol {
  padding-left: 18px;
  margin: 0 0 12px;
}

.pp-tab-panel li {
  margin-bottom: 4px;
  font-size: 13px;
  line-height: 1.6;
}

/* ═══════════════════════════════════════════════
   CROSS-SELL — 48px below tab content
   ═══════════════════════════════════════════════ */

.pp-cross-sell {
  margin-top: 48px;
}

.pp-cross-sell__heading {
  font-family: inherit;
  font-size: 16px;
  font-weight: 400;
  color: #1a1a1a;
  margin: 0 0 18px;
}

.pp-cross-sell__list {
  display: flex;
  flex-direction: column;
}

.pp-cross-item {
  display: flex;
  gap: 16px;
  padding: 18px 0;
  border-top: 1px solid #e8e6e2;
}

.pp-cross-item:last-child {
  border-bottom: 1px solid #e8e6e2;
}

/* Cross-sell image — 82px wide, 3:4 ratio */

.pp-cross-item__image {
  flex-shrink: 0;
  width: 82px;
}

.pp-cross-item__image img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 2px;
  background: #f5f3ef;
}

/* Cross-sell details */

.pp-cross-item__details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-top: 2px;
}

.pp-cross-item__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.pp-cross-item__name {
  font-size: 14px;
  font-weight: 400;
  color: #1a1a1a;
  text-decoration: none;
  line-height: 1.3;
}

.pp-cross-item__name:hover {
  text-decoration: underline;
}

.pp-cross-item__price {
  font-size: 14px;
  font-weight: 400;
  color: #1a1a1a;
  white-space: nowrap;
}

.pp-cross-item__variant {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.pp-cross-item__sizes {
  display: flex;
  gap: 8px;
  margin-top: 10px;
  flex-wrap: wrap;
}

.pp-cross-item__size-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36px;
  height: 32px;
  padding: 0 10px;
  border: 1px solid #ddd;
  border-radius: 3px;
  font-size: 12px;
  color: #444;
  background: transparent;
  cursor: default;
  letter-spacing: 0.02em;
}

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */

@media (max-width: 1279px) {
  .pp-info {
    padding: 44px 36px 56px 48px;
  }
}

@media (max-width: 1023px) {
  .pp-layout {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .pp-gallery {
    aspect-ratio: 3 / 4;
    max-height: 75vh;
  }

  .pp-info {
    padding: 32px 24px 48px;
    border-left: none;
    border-top: 1px solid #e8e6e2;
  }

  .pp-gallery__dots {
    left: 16px;
  }
}

@media (max-width: 767px) {
  .pp-gallery {
    max-height: 65vh;
  }

  .pp-info {
    padding: 24px 16px 40px;
  }

  .pp-title {
    font-size: 20px;
  }

  .pp-price {
    margin-bottom: 24px;
  }

  .pp-model-info {
    margin-bottom: 22px;
  }

  .pp-size-row {
    margin-bottom: 22px;
  }

  .pp-tabs {
    margin-top: 32px;
  }

  .pp-tabs__nav {
    gap: 18px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .pp-tabs__nav::-webkit-scrollbar {
    display: none;
  }

  .pp-tab-btn {
    font-size: 13px;
  }

  .pp-cross-sell {
    margin-top: 36px;
  }

  .pp-cross-item__sizes {
    gap: 6px;
  }

  .pp-cross-item__size-pill {
    min-width: 32px;
    height: 30px;
    font-size: 11px;
  }
}
</style>

{% schema %}
{
  "name": "Product content",
  "class": "product-content-section",
  "settings": [
    {
      "type": "url",
      "id": "size_guide_url",
      "label": "Size guide URL"
    },
    {
