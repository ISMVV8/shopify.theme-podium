{%- comment -%}
  Product page — Louis Vuitton-inspired luxury layout
  Scrollable images left (stacked), sticky info right
  Scoped class prefix: pp-
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="pp-section">
  <div class="pp-layout">

    {%- comment -%} ═══ LEFT — Vertical scrollable gallery ═══ {%- endcomment -%}
    <product-gallery class="pp-gallery">
      {%- for media in product.media -%}
        <div class="pp-gallery__item" data-gallery-item data-media-id="{{ media.id }}">
          <img
            src="{{ media | image_url: width: 1400 }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="1400"
            height="{{ 1400 | divided_by: media.aspect_ratio | round }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        </div>
      {%- endfor -%}
      {%- if product.media.size == 0 -%}
        <div class="pp-gallery__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'pp-gallery__placeholder-svg' }}
        </div>
      {%- endif -%}
    </product-gallery>

    {%- comment -%} ═══ RIGHT — Sticky product info ═══ {%- endcomment -%}
    <div class="pp-info-col">
      <div class="pp-info-sticky">
        <div class="pp-info">

          {%- comment -%} Title {%- endcomment -%}
          <h1 class="pp-title">{{ product.title }}</h1>

          {%- comment -%} SKU / reference {%- endcomment -%}
          {%- if current_variant.sku != blank -%}
            <p class="pp-sku" data-variant-sku>{{ current_variant.sku }}</p>
          {%- endif -%}

          {%- comment -%} Price {%- endcomment -%}
          <p class="pp-price">
            <span data-product-price>{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="pp-price--compare" data-compare-price>
                <s>{{ current_variant.compare_at_price | money }}</s>
              </span>
            {%- else -%}
              <span class="pp-price--compare" data-compare-price style="display:none;"></span>
            {%- endif -%}
          </p>

          {%- comment -%} ── Product form ── {%- endcomment -%}
          {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
            <variant-selector>
              <script type="application/json" data-variants>{{ product.variants | json }}</script>

              {%- for option in product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Couleur' -%}
                  {%- comment -%} Color swatches {%- endcomment -%}
                  <div class="pp-option-group">
                    <div class="pp-option-header">
                      <span class="pp-option-name">{{ option.name }}</span>
                      <span class="pp-option-value" data-color-name>{{ option.selected_value }}</span>
                    </div>
                    <div class="pp-swatches">
                      {%- for value in option.values -%}
                        {%- liquid
                          assign variant_for_color = nil
                          for variant in product.variants
                            if variant.options[forloop.parentloop.index0] == value
                              assign variant_for_color = variant
                              break
                            endif
                          endfor
                        -%}
                        <button
                          type="button"
                          class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                          data-option
                          data-option-position="{{ forloop.parentloop.index }}"
                          data-value="{{ value }}"
                          aria-label="{{ value }}"
                          title="{{ value }}"
                        >
                          {%- if variant_for_color and variant_for_color.featured_image -%}
                            <img src="{{ variant_for_color.featured_image | image_url: width: 100 }}" alt="{{ value }}">
                          {%- else -%}
                            <span class="pp-swatch__color" style="background-color: {{ value | handleize }};"></span>
                          {%- endif -%}
                        </button>
                      {%- endfor -%}
                    </div>
                  </div>

                {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
                  {%- comment -%} Size selector — expandable panel {%- endcomment -%}
                  <div class="pp-option-group">
                    <button type="button" class="pp-size-selector" data-size-toggle aria-expanded="false">
                      <span class="pp-size-selector__label">{{ option.name }}</span>
                      <span class="pp-size-selector__right">
                        <span class="pp-size-selector__value" data-size-value>{{ option.selected_value }}</span>
                        <span class="pp-size-selector__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                      </span>
                    </button>
                    <div class="pp-size-panel" data-size-panel hidden>
                      <div class="pp-size-dots">
                        {%- for value in option.values -%}
                          <div class="pp-size-dot-wrap">
                            <button
                              type="button"
                              class="pp-size-dot{% if option.selected_value == value %} is-active{% endif %}"
                              data-option
                              data-option-position="{{ forloop.parentloop.index }}"
                              data-value="{{ value }}"
                            >{{ value }}</button>
                          </div>
                        {%- endfor -%}
                      </div>
                      {%- if section.settings.size_guide_url != blank -%}
                        <a href="{{ section.settings.size_guide_url }}" class="pp-size-guide">Size guide</a>
                      {%- endif -%}
                    </div>
                  </div>

                {%- else -%}
                  {%- comment -%} Generic option {%- endcomment -%}
                  <div class="pp-option-group">
                    <div class="pp-option-header">
                      <span class="pp-option-name">{{ option.name }}</span>
                    </div>
                    <div class="pp-size-dots">
                      {%- for value in option.values -%}
                        <div class="pp-size-dot-wrap">
                          <button
                            type="button"
                            class="pp-size-dot{% if option.selected_value == value %} is-active{% endif %}"
                            data-option
                            data-option-position="{{ forloop.parentloop.index }}"
                            data-value="{{ value }}"
                          >{{ value }}</button>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}

              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <input type="hidden" name="quantity" value="1">
            </variant-selector>

            {%- comment -%} Purchase buttons {%- endcomment -%}
            <div class="pp-purchase">
              <button
                type="submit"
                class="pp-add-btn"
                data-add-to-cart
                data-add-text="{{ 'product.add_to_cart' | t }}"
                data-soldout-text="{{ 'product.sold_out' | t }}"
                data-unavailable-text="{{ 'product.unavailable' | t }}"
                {% unless current_variant.available %}disabled{% endunless %}
              >
                {%- if current_variant.available -%}
                  {{ 'product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'product.sold_out' | t }}
                {%- endif -%}
              </button>
            </div>
          {%- endform -%}

          {%- comment -%} Model info (subtle) {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'model_info' -%}
              <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} ── Accordions ── {%- endcomment -%}
          <div class="pp-accordions">

            {%- comment -%} Product details accordion (product.description) {%- endcomment -%}
            {%- if product.description != blank -%}
              <accordion-toggle class="pp-accordion">
                <button class="pp-accordion__trigger" data-accordion-trigger aria-expanded="false">
                  <span>{{ 'product.product_details' | t | default: 'Product details' }}</span>
                  <span class="pp-accordion__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                </button>
                <div class="accordion__panel pp-accordion__panel" hidden>
                  <div class="pp-accordion__content">
                    {{ product.description }}
                  </div>
                </div>
              </accordion-toggle>
            {%- endif -%}

            {%- comment -%} Custom accordion blocks (Delivery, Fabric, etc.) {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <accordion-toggle class="pp-accordion" {{ block.shopify_attributes }}>
                  <button class="pp-accordion__trigger" data-accordion-trigger aria-expanded="false">
                    <span>{{ block.settings.title }}</span>
                    <span class="pp-accordion__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                  </button>
                  <div class="accordion__panel pp-accordion__panel" hidden>
                    <div class="pp-accordion__content">
                      {{ block.settings.content }}
                    </div>
                  </div>
                </accordion-toggle>
              {%- endif -%}
            {%- endfor -%}

          </div>

          {%- comment -%} ── Cross-sell ── {%- endcomment -%}
          {%- liquid
            assign has_cross_sell = false
            for block in section.blocks
              if block.type == 'cross_sell_product' and block.settings.product != blank
                assign has_cross_sell = true
                break
              endif
            endfor
          -%}

          {%- if has_cross_sell -%}
            <div class="pp-cross-sell">
              <h3 class="pp-cross-sell__heading">{{ section.settings.cross_sell_heading | default: 'You may also like' }}</h3>
              <div class="pp-cross-sell__grid">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'cross_sell_product' and block.settings.product != blank -%}
                    {%- assign cs = block.settings.product -%}
                    <a href="{{ cs.url }}" class="pp-cross-item" {{ block.shopify_attributes }}>
                      {%- if cs.featured_media -%}
                        <div class="pp-cross-item__image">
                          <img
                            src="{{ cs.featured_media | image_url: width: 400 }}"
                            alt="{{ cs.featured_media.alt | escape | default: cs.title }}"
                            loading="lazy"
                          >
                        </div>
                      {%- endif -%}
                      <span class="pp-cross-item__name">{{ cs.title }}</span>
                      <span class="pp-cross-item__price">{{ cs.price | money }}</span>
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  </div>
</section>

<style>
/* ============================================================
   PRODUCT PAGE — Louis Vuitton-exact layout (pp-*)
   Values extracted from louisvuitton.com production CSS
   ============================================================ */

.pp-section {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 24px;
  color: #000;
}

.pp-section *, .pp-section *::before, .pp-section *::after {
  font-family: inherit;
  box-sizing: border-box;
}

/* ── Layout: 50/50 flex row ── */

.pp-layout {
  display: flex;
  flex-direction: row;
}

/* ═══════════════════════════════════════════════
   LEFT — Vertical scrollable image gallery
   Background: #f8f8f8 (LV gallery bg)
   ═══════════════════════════════════════════════ */

.pp-gallery {
  width: 50%;
  background: #f8f8f8;
  display: block;
}

.pp-gallery__item {
  display: block;
  width: 100%;
  overflow: hidden;
}

.pp-gallery__item img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

.pp-gallery__placeholder {
  width: 100%;
  aspect-ratio: 4 / 5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
}

.pp-gallery__placeholder-svg {
  width: 40%;
  opacity: 0.2;
}

/* ═══════════════════════════════════════════════
   RIGHT — Sticky info column
   White background, vertically centered content
   ═══════════════════════════════════════════════ */

.pp-info-col {
  width: 50%;
  background: #fff;
  position: relative;
}

.pp-info-sticky {
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  width: 100%;
}

.pp-info {
  width: 100%;
  max-width: 360px;
  padding: 48px 16px;
}

/* ── Title — heading-s: 18px/400 ── */

.pp-title {
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.5rem;
  margin: 0 0 0.25rem;
  color: #000;
}

/* ── SKU — overline: 10px uppercase ── */

.pp-sku {
  font-size: 0.625rem;
  font-weight: 400;
  letter-spacing: 0.0625rem;
  line-height: 1rem;
  text-transform: uppercase;
  color: #000;
  margin: 0;
}

/* ── Price — body-s: 14px ── */

.pp-price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #000;
  margin: 1rem 0 0;
}

.pp-price--compare {
  font-size: 0.875rem;
  color: #767676;
}

.pp-price--compare s {
  text-decoration: line-through;
}

/* ═══════════════════════════════════════════════
   OPTIONS — Color swatches & Size selector
   ═══════════════════════════════════════════════ */

.pp-option-group {
  border-top: 1px solid #e1e1e1;
}

.pp-option-group:last-of-type {
  border-bottom: 1px solid #e1e1e1;
}

/* Option header row (Color label + value) */

.pp-option-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 0 0.75rem;
}

.pp-option-name {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

.pp-option-value {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

/* Color swatches — 40px circles with image/color fill */

.pp-swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  padding-bottom: 1.5rem;
}

.pp-swatch {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid #b4b4b4;
  overflow: hidden;
  cursor: pointer;
  padding: 1px;
  transition: border-color 0.3s, border-width 0.3s;
  background: none;
}

.pp-swatch.is-active {
  border-color: #000;
  border-width: 2px;
  padding: 0;
}

.pp-swatch:hover:not(.is-active) {
  border-color: #767676;
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

.pp-swatch__color {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Size selector — expandable row ── */

.pp-size-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 4.5rem;
  padding: 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
  color: #000;
}

.pp-size-selector__label {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
}

.pp-size-selector__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.pp-size-selector__value {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
}

.pp-size-selector__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.pp-size-selector__chevron svg {
  width: 12px;
  height: 12px;
}

.pp-size-selector.is-open .pp-size-selector__chevron {
  transform: rotate(90deg);
}

/* Size panel (hidden by default) */

.pp-size-panel {
  padding: 0 0 1.5rem;
}

.pp-size-dots {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem 1.5rem;
}

.pp-size-dot-wrap {
  position: relative;
}

.pp-size-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 2.5rem;
  padding: 0 0.75rem;
  border-radius: 100vmax;
  border: 1px solid #b4b4b4;
  background: none;
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
  cursor: pointer;
  transition: border-color 0.3s, border-width 0.3s;
}

.pp-size-dot.is-active {
  border-color: #000;
  border-width: 2px;
}

.pp-size-dot:hover:not(.is-active) {
  border-color: #767676;
}

.pp-size-dot:disabled {
  color: #b4b4b4;
  border-color: #e1e1e1;
  cursor: not-allowed;
  text-decoration: line-through;
}

.pp-size-guide {
  display: inline-block;
  margin-top: 1.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  color: #000;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
}

.pp-size-guide:hover {
  color: #767676;
}

/* ═══════════════════════════════════════════════
   PURCHASE — Add to bag + secondary button
   margin: 1.5rem 0
   ═══════════════════════════════════════════════ */

.pp-purchase {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin: 1.5rem 0;
}

/* Primary button — pill shape, black bg */

.pp-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0.8125rem 2rem;
  background-color: #000;
  color: #fff;
  border: 1px solid #000;
  border-radius: 100vmax;
  font-family: inherit;
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  text-decoration: none;
  cursor: pointer;
  text-align: center;
  transition: border 0.3s, box-shadow 0.3s, color 0.3s, background 0.3s;
}

.pp-add-btn:hover {
  color: #000;
  background-color: #fff;
}

.pp-add-btn:disabled {
  color: #767676;
  background-color: #e1e1e1;
  border-color: #e1e1e1;
  cursor: not-allowed;
}

/* ── Model info ── */

.pp-model-info {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #767676;
  margin: 0 0 1rem;
}

/* ═══════════════════════════════════════════════
   ACCORDIONS — LV product panels
   border-top: 1px solid #e1e1e1
   ═══════════════════════════════════════════════ */

.pp-accordions {
  margin-top: 2rem;
}

.pp-accordion {
  display: block;
}

.pp-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 1.5rem 0;
  background: none;
  border: none;
  border-top: 1px solid #e1e1e1;
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
  cursor: pointer;
  text-align: left;
}

.pp-accordion:last-child .pp-accordion__trigger {
  border-bottom: none;
}

.pp-accordion__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.pp-accordion__chevron svg {
  width: 12px;
  height: 12px;
}

.pp-accordion.is-open .pp-accordion__chevron {
  transform: rotate(90deg);
}

.pp-accordion__panel {
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.pp-accordion__content {
  padding: 0 0 1.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #000;
}

.pp-accordion__content p {
  margin: 0 0 0.75rem;
}

.pp-accordion__content p:last-child {
  margin-bottom: 0;
}

.pp-accordion__content a {
  color: #000;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.pp-accordion__content ul,
.pp-accordion__content ol {
  padding-left: 1.25rem;
  margin: 0 0 0.75rem;
}

.pp-accordion__content li {
  margin-bottom: 0.25rem;
  line-height: 1.25rem;
}

/* ═══════════════════════════════════════════════
   CROSS-SELL — Product cards grid
   ═══════════════════════════════════════════════ */

.pp-cross-sell {
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e1e1e1;
}

.pp-cross-sell__heading {
  font-family: inherit;
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.5rem;
  color: #000;
  margin: 0 0 1.25rem;
}

.pp-cross-sell__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

.pp-cross-item {
  text-decoration: none;
  color: #000;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.pp-cross-item:hover .pp-cross-item__name {
  text-decoration: underline;
}

.pp-cross-item__image {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f8f8f8;
  border-radius: 0;
}

.pp-cross-item__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-cross-item__name {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #000;
}

.pp-cross-item__price {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #000;
}

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */

/* Tablet — stack layout */
@media (max-width: 1023px) {
  .pp-layout {
    flex-direction: column;
  }

  .pp-gallery {
    width: 100%;
  }

  .pp-info-col {
    width: 100%;
  }

  .pp-info-sticky {
    position: static;
    min-height: auto;
  }

  .pp-info {
    max-width: 100%;
    padding: 1.5rem 3.125vw;
    margin: 0 auto;
  }
}

/* Mobile */
@media (max-width: 767px) {
  .pp-info {
    padding: 1.5rem 6.4vw;
  }

  .pp-title {
    font-size: 1rem;
    line-height: 1.25rem;
  }

  .pp-size-selector {
    height: 3.25rem;
  }

  .pp-size-dots {
    gap: 1.5rem 1rem;
  }

