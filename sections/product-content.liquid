{%- comment -%}
  Product page — Merrachi-inspired minimal layout
  50/50 split: image left (with dot nav), info right (tabs, cross-sell)
  Scoped class prefix: pp-
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_image = product.featured_media
-%}

<section class="pp-section">
  <div class="pp-layout">

    {%- comment -%} ═══ LEFT — Gallery with dot navigation ═══ {%- endcomment -%}
    <product-gallery class="pp-gallery">
      {%- if product.media.size > 1 -%}
        <div class="pp-gallery__dots">
          {%- for media in product.media -%}
            <button
              class="pp-dot{% if forloop.first %} is-active{% endif %}"
              data-dot="{{ forloop.index0 }}"
              aria-label="Image {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="pp-gallery__main">
        {%- if first_image -%}
          <img
            data-main-image
            src="{{ first_image | image_url: width: 1400 }}"
            alt="{{ first_image.alt | escape | default: product.title }}"
            width="1400"
            height="{{ 1400 | divided_by: first_image.aspect_ratio | round }}"
          >
        {%- else -%}
          <div class="pp-gallery__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'pp-gallery__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <script type="application/json" data-gallery-images>
        [
          {%- for media in product.media -%}
            {
              "src": {{ media | image_url: width: 1400 | json }},
              "alt": {{ media.alt | default: product.title | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      </script>
    </product-gallery>

    {%- comment -%} ═══ RIGHT — Info column (border-left, centered content) ═══ {%- endcomment -%}
    <div class="pp-info-col">
      <div class="pp-info">

        {%- comment -%} Color / variant label {%- endcomment -%}
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Color' or option.name == 'Couleur' -%}
            <p class="pp-variant-label" data-color-name>{{ option.selected_value }}</p>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="pp-title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <p class="pp-price">
          <span data-product-price>{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="pp-price--compare" data-compare-price>
              <s>{{ current_variant.compare_at_price | money }}</s>
            </span>
          {%- else -%}
            <span class="pp-price--compare" data-compare-price style="display:none;"></span>
          {%- endif -%}
        </p>

        {%- comment -%} ── Product form ── {%- endcomment -%}
        {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
          <variant-selector>
            <script type="application/json" data-variants>{{ product.variants | json }}</script>

            {%- for option in product.options_with_values -%}
              {%- if option.name == 'Color' or option.name == 'Couleur' -%}
                {%- comment -%} Color swatches — small 16px circles {%- endcomment -%}
                <div class="pp-swatches">
                  {%- for value in option.values -%}
                    {%- liquid
                      assign variant_for_color = nil
                      for variant in product.variants
                        if variant.options[forloop.parentloop.index0] == value
                          assign variant_for_color = variant
                          break
                        endif
                      endfor
                    -%}
                    <button
                      type="button"
                      class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                      data-option
                      data-option-position="{{ forloop.parentloop.index }}"
                      data-value="{{ value }}"
                      aria-label="{{ value }}"
                      title="{{ value }}"
                    >
                      {%- if variant_for_color and variant_for_color.featured_image -%}
                        <img src="{{ variant_for_color.featured_image | image_url: width: 80 }}" alt="{{ value }}" width="16" height="16">
                      {%- else -%}
                        <span class="pp-swatch__color" style="background-color: {{ value | handleize }};"></span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                </div>

              {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
                {%- comment -%} Model info blocks (rendered above sizes) {%- endcomment -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'model_info' -%}
                    <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
                  {%- endif -%}
                {%- endfor -%}

                {%- comment -%} Size options {%- endcomment -%}
                <div class="pp-size-wrap">
                  <div class="pp-sizes">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                  {%- if section.settings.size_guide_url != blank -%}
                    <a href="{{ section.settings.size_guide_url }}" class="pp-size-guide">Size Chart</a>
                  {%- endif -%}
                </div>

              {%- else -%}
                {%- comment -%} Generic option {%- endcomment -%}
                <p class="pp-option-label">{{ option.name }}</p>
                <div class="pp-sizes">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                      data-option
                      data-option-position="{{ forloop.parentloop.index }}"
                      data-value="{{ value }}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            {%- endfor -%}

            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <input type="hidden" name="quantity" value="1">
          </variant-selector>

          {%- comment -%} Add to cart {%- endcomment -%}
          <button
            type="submit"
            class="pp-add-btn"
            data-add-to-cart
            data-add-text="{{ 'product.add_to_cart' | t }}"
            data-soldout-text="{{ 'product.sold_out' | t }}"
            data-unavailable-text="{{ 'product.unavailable' | t }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}
              {{ 'product.add_to_cart' | t }}
            {%- else -%}
              {{ 'product.sold_out' | t }}
            {%- endif -%}
          </button>
        {%- endform -%}

        {%- comment -%} ── Tabs (Description + custom tabs) ── {%- endcomment -%}
        {%- liquid
          assign has_tabs = false
          if product.description != blank
            assign has_tabs = true
          endif
          for block in section.blocks
            if block.type == 'tab'
              assign has_tabs = true
              break
            endif
          endfor
        -%}

        {%- if has_tabs -%}
          <product-tabs class="pp-tabs">
            <div class="pp-tabs__nav" role="tablist">
              {%- if product.description != blank -%}
                <button class="pp-tab-btn is-active" role="tab" data-tab="description" aria-selected="true">Description</button>
              {%- endif -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'tab' -%}
                  <button class="pp-tab-btn" role="tab" data-tab="{{ block.id }}" aria-selected="false" {{ block.shopify_attributes }}>{{ block.settings.title }}</button>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <div class="pp-tabs__content">
              {%- if product.description != blank -%}
                <div class="pp-tab-panel is-active" data-tab-panel="description">
                  {{ product.description }}
                </div>
              {%- endif -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'tab' -%}
                  <div class="pp-tab-panel" data-tab-panel="{{ block.id }}">
                    {{ block.settings.content }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </product-tabs>
        {%- endif -%}

        {%- comment -%} ── Cross-sell: Complete the look ── {%- endcomment -%}
        {%- liquid
          assign has_cross_sell = false
          for block in section.blocks
            if block.type == 'cross_sell_product' and block.settings.product != blank
              assign has_cross_sell = true
              break
            endif
          endfor
        -%}

        {%- if has_cross_sell -%}
          <div class="pp-cross-sell">
            <h3 class="pp-cross-sell__heading">{{ section.settings.cross_sell_heading | default: 'Complete the look' }}</h3>
            <div class="pp-cross-sell__list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'cross_sell_product' and block.settings.product != blank -%}
                  {%- assign cs = block.settings.product -%}
                  <div class="pp-cross-item" {{ block.shopify_attributes }}>
                    <a href="{{ cs.url }}" class="pp-cross-item__image">
                      {%- if cs.featured_media -%}
                        <img
                          src="{{ cs.featured_media | image_url: width: 200 }}"
                          alt="{{ cs.featured_media.alt | escape | default: cs.title }}"
                          width="60"
                          height="78"
                          loading="lazy"
                        >
                      {%- endif -%}
                    </a>
                    <div class="pp-cross-item__details">
                      <a href="{{ cs.url }}" class="pp-cross-item__name">{{ cs.title }}</a>
                      <span class="pp-cross-item__price">{{ cs.price | money }}</span>
                      {%- for cs_option in cs.options_with_values -%}
                        {%- if cs_option.name == 'Size' or cs_option.name == 'Taille' -%}
                          <div class="pp-cross-item__sizes">
                            {%- for value in cs_option.values -%}
                              <span class="pp-cross-item__size">{{ value }}</span>
                            {%- endfor -%}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
/* ============================================================
   PRODUCT PAGE — Merrachi-exact layout (pp-*)
   Values extracted from bymerrachi.com production CSS
   ============================================================ */

.pp-section {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 12px;
  font-weight: 500;
  line-height: 130%;
  color: #2A2A2A;
}

.pp-section *, .pp-section *::before, .pp-section *::after {
  font-family: inherit;
  box-sizing: border-box;
}

/* ── Layout: 50/50 grid, 8px gap ── */

.pp-layout {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  min-height: calc(100vh - 80px);
}

/* ═══════════════════════════════════════════════
   LEFT — Gallery (edge-to-edge, no padding)
   ═══════════════════════════════════════════════ */

.pp-gallery {
  position: relative;
  display: block;
  background: #F2EEE8;
  overflow: hidden;
}

.pp-gallery__main {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.pp-gallery__main img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: top center;
}

.pp-gallery__placeholder {
  width: 100%;
  height: 600px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2EEE8;
}

.pp-gallery__placeholder-svg {
  width: 40%;
  opacity: 0.3;
}

/* Dot navigation — vertically centered, left side */

.pp-gallery__dots {
  position: absolute;
  left: 24px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  z-index: 2;
}

.pp-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #A59D93;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.25s ease;
  opacity: 0.5;
}

.pp-dot.is-active {
  width: 7px;
  height: 7px;
  background: #2A2A2A;
  opacity: 1;
}

.pp-dot:hover:not(.is-active) {
  opacity: 0.8;
}

/* ═══════════════════════════════════════════════
   RIGHT — Info column wrapper (border + centering)
   ═══════════════════════════════════════════════ */

.pp-info-col {
  display: flex;
  justify-content: center;
  border-left: 1px solid #E7E3DD;
  overflow-y: auto;
}

.pp-info {
  width: 100%;
  max-width: 378px;
  padding: 108px 12px 50px;
}

/* ── Variant / color label ── */

.pp-variant-label {
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
  margin: 0 0 8px;
  line-height: 130%;
}

/* ── Title ── */

.pp-title {
  font-family: inherit;
  font-size: 16px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0;
  line-height: 1.25;
  margin: 0;
  color: #2A2A2A;
}

/* ── Price ── */

.pp-price {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin: 6px 0 0;
  padding-bottom: 32px;
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
}

.pp-price--compare {
  font-size: 12px;
  color: #A59D93;
}

.pp-price--compare s {
  text-decoration: line-through;
}

/* ── Color swatches (16x16 circles) ── */

.pp-swatches {
  display: flex;
  gap: 8px;
  margin-bottom: 4px;
}

.pp-swatch {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 1px solid transparent;
  overflow: hidden;
  cursor: pointer;
  padding: 0;
  transition: border-color 0.2s, box-shadow 0.2s;
  background: none;
}

.pp-swatch.is-active {
  border-color: #b1b1b1;
  box-shadow: inset 0 0 0 3px #fff;
}

.pp-swatch:hover:not(.is-active) {
  border-color: #ccc;
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

.pp-swatch__color {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* ── Model info ── */

.pp-model-info {
  font-size: 12px;
  font-weight: 500;
  color: #645B57;
  margin: 12px 0 0;
  line-height: 130%;
}

/* ── Size options ── */

.pp-size-wrap {
  margin: 32px 0;
}

.pp-sizes {
  display: flex;
  gap: 12px 24px;
  flex-wrap: wrap;
  align-items: center;
}

.pp-size {
  background: none;
  border: none;
  padding: 4px 0;
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  color: #2A2A2A;
  transition: all 0.2s;
  position: relative;
  border-bottom: 1px solid transparent;
}

.pp-size.is-active {
  color: #2A2A2A;
  border-bottom-color: #2A2A2A;
}

.pp-size:hover:not(.is-active) {
  opacity: 0.7;
}

.pp-size:disabled {
  opacity: 0.3;
  cursor: not-allowed;
  text-decoration: line-through;
}

.pp-size-guide {
  display: inline-block;
  margin-top: 16px;
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
  text-decoration: none;
  border-bottom: 1px solid rgba(42, 42, 42, 0.5);
  padding-bottom: 1px;
  transition: opacity 0.2s;
}

.pp-size-guide:hover {
  opacity: 0.7;
}

/* ── Option label (generic) ── */

.pp-option-label {
  font-size: 12px;
  font-weight: 500;
  color: #645B57;
  margin: 0 0 12px;
}

/* ── Add to cart — full width, square corners ── */

.pp-add-btn {
  width: 100%;
  padding: 12px;
  background: #2A2A2A;
  color: #fff;
  border: 1px solid #2A2A2A;
  border-radius: 0;
  font-family: inherit;
  font-size: 12px;
  font-weight: 400;
  text-transform: capitalize;
  letter-spacing: 0;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}

.pp-add-btn:hover {
  background: #fff;
  color: #2A2A2A;
}

.pp-add-btn:disabled {
  background: #E7E3DD;
  border-color: #E7E3DD;
  color: #A59D93;
  cursor: not-allowed;
}

/* ═══════════════════════════════════════════════
   TABS — margin: 40px 0 60px
   ═══════════════════════════════════════════════ */

.pp-tabs {
  display: block;
  margin: 40px 0 60px;
}

.pp-tabs__nav {
  display: flex;
  gap: 24px;
}

.pp-tab-btn {
  background: none;
  border: none;
  padding: 0 0 8px;
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
  cursor: pointer;
  transition: opacity 0.2s;
  position: relative;
  white-space: nowrap;
  opacity: 0.5;
  border-bottom: 1px solid transparent;
}

.pp-tab-btn.is-active {
  opacity: 1;
  border-bottom-color: #2A2A2A;
}

.pp-tab-btn:hover:not(.is-active) {
  opacity: 0.75;
}

/* Tab content */

.pp-tabs__content {
  margin-top: 15px;
}

.pp-tab-panel {
  display: none;
  max-width: 296px;
  font-size: 12px;
  font-weight: 500;
  line-height: 130%;
  color: #2A2A2A;
}

.pp-tab-panel.is-active {
  display: block;
}

.pp-tab-panel p {
  margin: 0 0 8px;
}

.pp-tab-panel p:last-child {
  margin-bottom: 0;
}

.pp-tab-panel a {
  color: #2A2A2A;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.pp-tab-panel ul, .pp-tab-panel ol {
  padding-left: 16px;
  margin: 0 0 8px;
}

.pp-tab-panel li {
  margin-bottom: 4px;
  font-size: 12px;
  line-height: 130%;
}

/* ═══════════════════════════════════════════════
   CROSS-SELL
   ═══════════════════════════════════════════════ */

.pp-cross-sell {
  margin-top: 0;
}

.pp-cross-sell__heading {
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
  margin: 0 0 16px;
}

.pp-cross-sell__list {
  display: flex;
  flex-direction: column;
}

.pp-cross-item {
  display: flex;
  gap: 12px;
  padding: 16px 0;
  border-top: 1px solid #E7E3DD;
}

.pp-cross-item:last-child {
  border-bottom: 1px solid #E7E3DD;
}

/* Cross-sell image — 60px wide */

.pp-cross-item__image {
  flex-shrink: 0;
  width: 60px;
}

.pp-cross-item__image img {
  width: 100%;
  height: auto;
  display: block;
  background: #F2EEE8;
}

/* Cross-sell details */

.pp-cross-item__details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 4px 12px 0 0;
}

.pp-cross-item__name {
  font-size: 10px;
  font-weight: 500;
  color: #2A2A2A;
  text-decoration: none;
  text-transform: capitalize;
  opacity: 0.5;
  line-height: 1.3;
}

.pp-cross-item__name:hover {
  opacity: 0.8;
}

.pp-cross-item__price {
  font-size: 11px;
  font-weight: 500;
  color: #2A2A2A;
  text-transform: uppercase;
  white-space: nowrap;
}

.pp-cross-item__sizes {
  display: flex;
  gap: 12px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.pp-cross-item__size {
  font-size: 12px;
  font-weight: 500;
  color: #2A2A2A;
  padding-bottom: 2px;
  border-bottom: 1px solid #2A2A2A;
  cursor: pointer;
  transition: opacity 0.2s;
}

.pp-cross-item__size:hover {
  opacity: 0.6;
}

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */

@media (max-width: 1279px) {
  .pp-info {
    padding: 80px 12px 50px;
  }
}

@media (max-width: 1023px) {
  .pp-layout {
    grid-template-columns: 1fr;
    gap: 0;
    min-height: auto;
  }

  .pp-gallery {
    aspect-ratio: 3 / 4;
    max-height: 75vh;
  }

  .pp-info-col {
    border-left: none;
    border-top: 1px solid #E7E3DD;
  }

  .pp-info {
    max-width: 100%;
    padding: 32px 24px 48px;
  }

  .pp-gallery__dots {
    left: 16px;
  }
}

@media (max-width: 767px) {
  .pp-gallery {
    max-height: 65vh;
  }

  .pp-info {
    padding: 24px 16px 40px;
  }

  .pp-title {
    font-size: 14px;
  }

  .pp-tabs {
    margin: 32px 0 40px;
  }

  .pp-tabs__nav {
    gap: 16px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .pp-tabs__nav::-webkit-scrollbar {
    display: none;
  }

  .pp-tab-panel {
    max-width: 100%;
  }

  .pp-cross-sell {
    margin-top: 0;
  }
}
</style>

{% schema %}
{
  "name": "Product content",
  "class": "product-content-section",
  "settings": [
    {
      "type": "url",
      "id": "size_guide_url",
      "label": "Size guide URL"
    },
    {
      "type": "header",
      "content": "Cross-sell"
    },
    {
      "type": "text",
      "id": "cross_sell_heading",
      "label": "Cross-sell heading",
      "default": "Complete the look"
    }
  ],
  "blocks": [
    {
      "type": "model_info",
      "name": "Model info line",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "This model is 173cm tall and wearing a size S"
        }
      ]
    },
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab title",
          "default": "Fabric"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab content",
