{%- comment -%}
  Product content section — gallery + info + description + accordions
  Scoped class prefix: pp-
  Full rebuild for clean premium fashion layout.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_image = product.featured_media
-%}

<section class="pp-section">
  <div class="pp-container">

    {%- comment -%} ── Breadcrumbs ── {%- endcomment -%}
    <nav class="pp-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="{{ routes.root_url }}">Accueil</a></li>
        {%- if product.collections.size > 0 -%}
          <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
        {%- endif -%}
        <li aria-current="page">{{ product.title }}</li>
      </ol>
    </nav>

    {%- comment -%} ── Two-column product layout ── {%- endcomment -%}
    <div class="pp-layout">

      {%- comment -%} ═══ LEFT COLUMN: Gallery ═══ {%- endcomment -%}
      <div class="pp-gallery-col">
        <product-gallery class="pp-gallery-wrap">
          <div class="pp-gallery">

            {%- comment -%} Vertical thumbnail rail {%- endcomment -%}
            {%- if product.media.size > 1 -%}
              <div class="pp-thumbs">
                <button class="pp-thumbs__arrow pp-thumbs__arrow--up" data-thumbs-up aria-label="Scroll thumbnails up">
                  {% render 'icon', name: 'chevron-down', size: 14 %}
                </button>
                <div class="pp-thumbs__track" data-thumbs-list role="list">
                  {%- for media in product.media -%}
                    <button
                      class="pp-thumb{% if forloop.first %} is-active{% endif %}"
                      data-thumb="{{ forloop.index0 }}"
                      data-full-src="{{ media | image_url: width: 1200 }}"
                      role="listitem"
                      aria-label="Image {{ forloop.index }} sur {{ product.media.size }}"
                    >
                      <img
                        src="{{ media | image_url: width: 120 }}"
                        alt="{{ media.alt | escape | default: product.title }}"
                        width="60"
                        height="80"
                        loading="lazy"
                      >
                    </button>
                  {%- endfor -%}
                </div>
                <button class="pp-thumbs__arrow pp-thumbs__arrow--down" data-thumbs-down aria-label="Scroll thumbnails down">
                  {% render 'icon', name: 'chevron-down', size: 14 %}
                </button>
              </div>
            {%- endif -%}

            {%- comment -%} Main media area {%- endcomment -%}
            <div class="pp-main-image">
              {%- if first_image -%}
                <img
                  data-main-image
                  src="{{ first_image | image_url: width: 1200 }}"
                  alt="{{ first_image.alt | escape | default: product.title }}"
                  width="1200"
                  height="{{ 1200 | divided_by: first_image.aspect_ratio | round }}"
                >
              {%- else -%}
                <div class="pp-main-image__placeholder">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              {%- if product.media.size > 1 -%}
                <button class="pp-nav pp-nav--prev" data-gallery-prev aria-label="Image précédente">
                  {% render 'icon', name: 'chevron-left', size: 18 %}
                </button>
                <button class="pp-nav pp-nav--next" data-gallery-next aria-label="Image suivante">
                  {% render 'icon', name: 'chevron-right', size: 18 %}
                </button>
              {%- endif -%}
            </div>
          </div>
        </product-gallery>
      </div>

      {%- comment -%} ═══ RIGHT COLUMN: Product Info ═══ {%- endcomment -%}
      <div class="pp-info-col">
        <div class="pp-info">

          {%- comment -%} 1. Title {%- endcomment -%}
          <h1 class="pp-title">{{ product.title }}</h1>

          {%- comment -%} 2. Color label {%- endcomment -%}
          {%- for option in product.options_with_values -%}
            {%- if option.name == 'Color' or option.name == 'Couleur' -%}
              <p class="pp-color-label">
                Couleur : <span data-color-name>{{ option.selected_value }}</span>
              </p>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} 3. Price {%- endcomment -%}
          <div class="pp-price">
            <span class="pp-price__current" data-product-price>{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="pp-price__compare" data-compare-price>
                <s>{{ current_variant.compare_at_price | money }}</s>
              </span>
            {%- else -%}
              <span class="pp-price__compare" data-compare-price style="display:none;"></span>
            {%- endif -%}
          </div>

          {%- comment -%} Product form {%- endcomment -%}
          {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
            <variant-selector>
              <script type="application/json" data-variants>{{ product.variants | json }}</script>

              {%- for option in product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Couleur' -%}
                  {%- comment -%} Color swatches {%- endcomment -%}
                  <div class="pp-swatches">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign variant_for_color = nil
                        for variant in product.variants
                          if variant.options[forloop.parentloop.index0] == value
                            assign variant_for_color = variant
                            break
                          endif
                        endfor
                      -%}
                      <button
                        type="button"
                        class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                        aria-label="{{ value }}"
                        title="{{ value }}"
                      >
                        {%- if variant_for_color and variant_for_color.featured_image -%}
                          <img src="{{ variant_for_color.featured_image | image_url: width: 72 }}" alt="{{ value }}" width="36" height="36">
                        {%- else -%}
                          <span class="pp-swatch__dot" style="background-color: {{ value | handleize }};"></span>
                        {%- endif -%}
                      </button>
                    {%- endfor -%}
                  </div>

                {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
                  {%- comment -%} 4–5. Size label row + pills {%- endcomment -%}
                  <div class="pp-size-row">
                    <span class="pp-size-label">Taille</span>
                    {%- if section.settings.size_guide_url != blank -%}
                      <a href="{{ section.settings.size_guide_url }}" class="pp-size-guide">Guide des tailles</a>
                    {%- endif -%}
                  </div>
                  <div class="pp-sizes">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>

                {%- else -%}
                  {%- comment -%} Generic option pills {%- endcomment -%}
                  <p class="pp-size-label" style="margin-bottom:10px;">{{ option.name }}</p>
                  <div class="pp-sizes">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}

              <input type="hidden" name="id" value="{{ current_variant.id }}">
            </variant-selector>

            {%- comment -%} 6. Model info {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'model_info' -%}
                <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} 7. Installments {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'installments' -%}
                <div class="pp-installments" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
              {%- endif -%}
            {%- endfor -%}

            <input type="hidden" name="quantity" value="1">

            {%- comment -%} 8. Add to cart {%- endcomment -%}
            <button
              type="submit"
              class="pp-add-btn"
              data-add-to-cart
              data-add-text="{{ 'product.add_to_cart' | t }}"
              data-soldout-text="{{ 'product.sold_out' | t }}"
              data-unavailable-text="{{ 'product.unavailable' | t }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'product.add_to_cart' | t }}
              {%- else -%}
                {{ 'product.sold_out' | t }}
              {%- endif -%}
            </button>

            {%- comment -%} 9. Dynamic checkout {%- endcomment -%}
            <div class="pp-express-btn">
              {{ form | payment_button }}
            </div>
          {%- endform -%}

          {%- comment -%} 10. Trust box — 2-column layout {%- endcomment -%}
          <div class="pp-trust-box">
            <div class="pp-trust-cell">
              {% render 'icon', name: 'return', size: 18 %}
              <div class="pp-trust-cell__text">
                <strong>{{ section.settings.trust_return_title | default: 'Retours gratuits' }}</strong>
                <span>{{ section.settings.trust_return_desc | default: 'Sous 14 jours' }}</span>
              </div>
            </div>
            <div class="pp-trust-cell">
              {% render 'icon', name: 'truck', size: 18 %}
              <div class="pp-trust-cell__text">
                <strong>{{ section.settings.trust_shipping_title | default: 'Livraison offerte' }}</strong>
                <span>{{ section.settings.trust_shipping_desc | default: "Dès 150€ d'achat" }}</span>
              </div>
            </div>
          </div>

          {%- comment -%} 11. Description {%- endcomment -%}
          {%- if product.description != blank -%}
            <div class="pp-description">
              {{ product.description }}
            </div>
          {%- endif -%}

          {%- comment -%} 12. Accordions {%- endcomment -%}
          <div class="pp-accordions">
            {%- for block in section.blocks -%}
              {%- if block.type == 'accordion' -%}
                {% render 'accordion', title: block.settings.title, content: block.settings.content, id: block.id, open: block.settings.open_by_default %}
              {%- endif -%}
            {%- endfor -%}

            {%- assign has_accordions = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'accordion' -%}{%- assign has_accordions = true -%}{%- endif -%}
            {%- endfor -%}
            {%- unless has_accordions -%}
              {% render 'accordion', title: 'Composition & entretien', content: '<p>Informations à compléter par le marchand.</p>', id: 'composition' %}
              {% render 'accordion', title: 'Livraisons & retours', content: '<p>Livraison standard sous 3-5 jours ouvrés. Retour gratuit sous 14 jours.</p>', id: 'shipping' %}
              {% render 'accordion', title: 'Moyens de paiement', content: '<p>Visa, Mastercard, American Express, PayPal, Scalapay (3x sans frais).</p>', id: 'payment' %}
            {%- endunless -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* ============================================================
   PRODUCT PAGE — Scoped styles (pp-*)
   Premium fashion layout, clean structure, no hacks.
   ============================================================ */

/* ── Section wrapper ── */
.pp-section {
  padding: 0 0 40px;
}

.pp-container {
  max-width: 1320px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Breadcrumbs ── */
.pp-breadcrumbs {
  padding: 14px 0 20px;
  font-size: 0.78rem;
  color: #999;
}

.pp-breadcrumbs ol {
  display: flex;
  align-items: center;
  list-style: none;
  padding: 0;
  margin: 0;
  flex-wrap: wrap;
  gap: 0;
}

.pp-breadcrumbs li {
  display: flex;
  align-items: center;
}

.pp-breadcrumbs li:not(:last-child)::after {
  content: '/';
  margin: 0 8px;
  color: #ccc;
}

.pp-breadcrumbs a {
  color: #999;
  text-decoration: none;
  transition: color 0.2s;
}

.pp-breadcrumbs a:hover {
  color: var(--color-text);
  text-decoration: none;
}

.pp-breadcrumbs li[aria-current="page"] {
  color: var(--color-text);
}

/* ── Two-column layout ── */
.pp-layout {
  display: grid;
  grid-template-columns: 58% 1fr;
  gap: 52px;
  align-items: start;
}

/* ═══════════════════════════════════════════════
   LEFT COLUMN: Gallery
   ═══════════════════════════════════════════════ */
.pp-gallery-col {
  position: sticky;
  top: 90px;
}

.pp-gallery-wrap {
  display: block;
}

.pp-gallery {
  display: flex;
  gap: 12px;
}

/* Thumbnail rail */
.pp-thumbs {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
  width: 64px;
}

.pp-thumbs__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: none;
  background: none;
  cursor: pointer;
  color: #aaa;
  transition: color 0.2s;
  flex-shrink: 0;
  padding: 0;
}

.pp-thumbs__arrow:hover {
  color: var(--color-text);
}

.pp-thumbs__arrow--up svg {
  transform: rotate(180deg);
}

.pp-thumbs__track {
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow-y: auto;
  max-height: 560px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.pp-thumbs__track::-webkit-scrollbar {
  display: none;
}

.pp-thumb {
  width: 60px;
  height: 78px;
  border: 1.5px solid #e0ddd8;
  border-radius: 4px;
  overflow: hidden;
  cursor: pointer;
  opacity: 0.5;
  transition: all 0.2s ease;
  flex-shrink: 0;
  padding: 0;
  background: none;
}

.pp-thumb.is-active,
.pp-thumb:hover {
  opacity: 1;
  border-color: var(--color-text);
}

.pp-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Main media area — constrained aspect ratio */
.pp-main-image {
  position: relative;
  flex: 1;
  min-width: 0;
  border-radius: 8px;
  overflow: hidden;
  background: #f5f3ef;
  aspect-ratio: 3 / 4;
}

.pp-main-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-main-image__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ede8;
}

.pp-main-image__placeholder svg {
  width: 50%;
  opacity: 0.35;
}

/* Gallery prev/next arrows */
.pp-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  transition: opacity 0.2s, transform 0.2s;
  color: #333;
  padding: 0;
  z-index: 2;
}

.pp-nav:hover {
  opacity: 0.85;
}

.pp-nav--prev { left: 12px; }
.pp-nav--next { right: 12px; }

/* ═══════════════════════════════════════════════
   RIGHT COLUMN: Product Info
   ═══════════════════════════════════════════════ */
.pp-info-col {
  min-width: 0;
}

.pp-info {
  max-width: 480px;
}

/* 1. Title */
.pp-title {
  font-family: var(--font-heading);
  font-size: 1.65rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.25;
  margin: 0 0 6px;
  color: var(--color-text);
}

/* 2. Color label */
.pp-color-label {
  font-size: 0.82rem;
  color: #888;
  margin: 0 0 14px;
}

.pp-color-label span {
  color: var(--color-text);
}

/* 3. Price */
.pp-price {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 22px;
}

.pp-price__current {
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--color-text);
}

.pp-price__compare {
  font-size: 0.9rem;
  color: #aaa;
}

.pp-price__compare s {
  text-decoration: line-through;
}

/* Color swatches */
.pp-swatches {
  display: flex;
  gap: 8px;
  margin-bottom: 22px;
  flex-wrap: wrap;
}

.pp-swatch {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 2px solid #e0ddd8;
  overflow: hidden;
  cursor: pointer;
  padding: 2px;
  transition: border-color 0.2s;
  background: none;
}

.pp-swatch.is-active {
  border-color: var(--color-text);
  box-shadow: 0 0 0 1px var(--color-text);
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

.pp-swatch__dot {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

/* 4. Size row (label left, guide link right) */
.pp-size-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.pp-size-label {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--color-text);
}

.pp-size-guide {
  font-size: 0.78rem;
  color: #888;
  text-decoration: underline;
  text-underline-offset: 2px;
  transition: color 0.2s;
}

.pp-size-guide:hover {
  color: var(--color-text);
  text-decoration: underline;
}

/* 5. Size pills */
.pp-sizes {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.pp-size {
  min-width: 46px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d0cdc8;
  border-radius: 6px;
  background: transparent;
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.2s;
  padding: 0 14px;
  color: var(--color-text);
}

.pp-size:hover {
  border-color: var(--color-text);
}

.pp-size.is-active {
  background: var(--color-text);
  color: #fff;
  border-color: var(--color-text);
}

.pp-size:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  text-decoration: line-through;
}

/* 6. Model info */
.pp-model-info {
  font-size: 0.78rem;
  color: #999;
  margin: 0 0 4px;
  line-height: 1.5;
}

/* 7. Installments */
.pp-installments {
  font-size: 0.8rem;
  color: #888;
  margin: 12px 0 0;
  padding: 10px 0;
  border-top: 1px solid #eae8e4;
}

.pp-installments p {
  margin: 0;
}

/* 8. Add to cart button */
.pp-add-btn {
  width: 100%;
  height: 54px;
  margin-top: 16px;
  background: var(--color-text);
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s;
}

.pp-add-btn:hover {
  opacity: 0.85;
}

.pp-add-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* 9. Dynamic checkout */
.pp-express-btn {
  width: 100%;
  margin-top: 8px;
}

/* 10. Trust box — 2-column grid */
.pp-trust-box {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: 24px;
  border: 1px solid #eae8e4;
  border-radius: 8px;
  overflow: hidden;
}

.pp-trust-cell {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 16px;
}

.pp-trust-cell:first-child {
  border-right: 1px solid #eae8e4;
}

.pp-trust-cell svg {
  flex-shrink: 0;
  color: #888;
  margin-top: 2px;
}

.pp-trust-cell__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.pp-trust-cell__text strong {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.pp-trust-cell__text span {
  font-size: 0.72rem;
  color: #999;
  line-height: 1.3;
}

/* 11. Description */
.pp-description {
  margin-top: 28px;
  padding-top: 20px;
  border-top: 1px solid #eae8e4;
  font-size: 0.88rem;
  line-height: 1.75;
  color: var(--color-text);
}

.pp-description p {
  margin: 0 0 12px;
}

.pp-description p:last-child {
  margin-bottom: 0;
}

.pp-description ul,
.pp-description ol {
  list-style: disc;
  padding-left: 20px;
  margin: 0 0 12px;
}

.pp-description li {
  margin-bottom: 4px;
  font-size: 0.85rem;
  line-height: 1.6;
}

/* 12. Accordions */
.pp-accordions {
  margin-top: 24px;
}

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */

/* Tablet: keep 2 columns, tighter */
@media (max-width: 1200px) {
  .pp-layout {
    gap: 36px;
  }

  .pp-info {
    max-width: 100%;
  }
}

/* Mobile: single column */
@media (max-width: 1023px) {
  .pp-layout {
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .pp-gallery-col {
    position: static;
  }

  .pp-gallery {
    flex-direction: column;
  }

  .pp-thumbs {
    flex-direction: row;
    width: auto;
    order: 2;
  }

  .pp-thumbs__track {
    flex-direction: row;
    max-height: none;
    overflow-x: auto;
    overflow-y: hidden;
    max-width: 100%;
  }

  .pp-thumbs__arrow {
    display: none;
  }

  .pp-thumb {
    width: 48px;
    height: 62px;
  }

  .pp-main-image {
    aspect-ratio: 3 / 4;
  }

  .pp-info {
    max-width: 100%;
  }
}

@media (max-width: 767px) {
  .pp-container {
    padding: 0 16px;
  }

  .pp-title {
    font-size: 1.35rem;
  }

  .pp-trust-box {
    grid-template-columns: 1fr;
  }

  .pp-trust-cell:first-child {
    border-right: none;
    border-bottom: 1px solid #eae8e4;
  }

  .pp-trust-cell {
    padding: 14px;
  }
}
</style>

