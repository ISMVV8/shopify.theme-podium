{%- comment -%}
  Product page — Louis Vuitton-inspired luxury layout
  Scrollable images left (stacked), sticky info right
  Scoped class prefix: pp-
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="pp-section">
  <div class="pp-layout">

    {%- comment -%} ═══ LEFT — Vertical scrollable gallery (desktop) / Swipe carousel (mobile) ═══ {%- endcomment -%}
    <product-gallery class="pp-gallery">
      <div class="pp-gallery__track">
        {%- for media in product.media -%}
          <div class="pp-gallery__item" data-gallery-item data-media-id="{{ media.id }}">
            <img
              src="{{ media | image_url: width: 1400 }}"
              alt="{{ media.alt | escape | default: product.title }}"
              width="1400"
              height="{{ 1400 | divided_by: media.aspect_ratio | round }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          </div>
        {%- endfor -%}
      </div>
      {%- if product.media.size > 1 -%}
        <div class="pp-gallery__dots">
          {%- for media in product.media -%}
            <button
              class="pp-gallery__dot{% if forloop.first %} is-active{% endif %}"
              data-gallery-dot="{{ forloop.index0 }}"
              aria-label="Image {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if product.media.size == 0 -%}
        <div class="pp-gallery__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'pp-gallery__placeholder-svg' }}
        </div>
      {%- endif -%}
    </product-gallery>

    {%- comment -%} ═══ RIGHT — Sticky product info ═══ {%- endcomment -%}
    <div class="pp-info-col">
      <div class="pp-info-sticky">
        <div class="pp-info">

          {%- comment -%} Title {%- endcomment -%}
          <div class="pp-title-row">
            <h1 class="pp-title">{{ product.title }}</h1>
          </div>

          {%- comment -%} SKU / reference {%- endcomment -%}
          {%- if current_variant.sku != blank -%}
            <p class="pp-sku" data-variant-sku>{{ current_variant.sku }}</p>
          {%- endif -%}

          {%- comment -%} Price {%- endcomment -%}
          <p class="pp-price">
            <span data-product-price>{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="pp-price--compare" data-compare-price>
                <s>{{ current_variant.compare_at_price | money }}</s>
              </span>
            {%- else -%}
              <span class="pp-price--compare" data-compare-price style="display:none;"></span>
            {%- endif -%}
          </p>

          {%- comment -%} ── Product form ── {%- endcomment -%}
          {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
            <variant-selector>
              <script type="application/json" data-variants>{{ product.variants | json }}</script>

              {%- for option in product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Couleur' -%}
                  {%- comment -%} Color swatches {%- endcomment -%}
                  {%- assign color_option_index = forloop.index0 -%}
                  <div class="pp-option-group">
                    <div class="pp-option-header">
                      <span class="pp-option-name">{{ option.name }}</span>
                      <span class="pp-option-value" data-color-name>{{ option.selected_value }}</span>
                    </div>
                    <div class="pp-swatches">
                      {%- for value in option.values -%}
                        {%- liquid
                          assign variant_for_color = nil
                          for variant in product.variants
                            if variant.options[color_option_index] == value and variant.featured_image
                              assign variant_for_color = variant
                              break
                            endif
                          endfor
                        -%}
                        <button
                          type="button"
                          class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                          data-option
                          data-option-position="{{ forloop.parentloop.index }}"
                          data-value="{{ value }}"
                          aria-label="{{ value }}"
                          title="{{ value }}"
                        >
                          {%- if variant_for_color and variant_for_color.featured_image -%}
                            <img src="{{ variant_for_color.featured_image | image_url: width: 200 }}" alt="{{ value }}">
                          {%- else -%}
                            <span class="pp-swatch__color" style="background-color: {{ value | handleize }};"></span>
                          {%- endif -%}
                        </button>
                      {%- endfor -%}
                    </div>
                  </div>

                {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
                  {%- comment -%} Size selector — expandable panel (desktop) / bottom sheet (mobile) {%- endcomment -%}
                  <div class="pp-option-group">
                    <button type="button" class="pp-size-selector" data-size-toggle aria-expanded="false">
                      <span class="pp-size-selector__label">{{ option.name }}</span>
                      <span class="pp-size-selector__right">
                        <span class="pp-size-selector__value" data-size-value>{{ option.selected_value }}</span>
                        <span class="pp-size-selector__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                      </span>
                    </button>
                    {%- comment -%} Desktop: inline panel {%- endcomment -%}
                    <div class="pp-size-panel pp-size-panel--inline" data-size-panel hidden>
                      <div class="pp-size-dots">
                        {%- for value in option.values -%}
                          <div class="pp-size-dot-wrap">
                            <button
                              type="button"
                              class="pp-size-dot{% if option.selected_value == value %} is-active{% endif %}"
                              data-option
                              data-option-position="{{ forloop.parentloop.index }}"
                              data-value="{{ value }}"
                            >{{ value }}</button>
                          </div>
                        {%- endfor -%}
                      </div>
                      <button type="button" class="pp-size-guide" data-size-guide-open>{{ 'product.size_guide' | t | default: 'Trouver ma taille' }}</button>
                    </div>
                  </div>

                  {%- comment -%} Mobile: bottom sheet drawer {%- endcomment -%}
                  <div class="pp-size-sheet" data-size-sheet>
                    <div class="pp-size-sheet__overlay" data-size-sheet-close></div>
                    <div class="pp-size-sheet__drawer">
                      <div class="pp-size-sheet__header">
                        <span class="pp-size-sheet__title">{{ option.name }}</span>
                        <button type="button" class="pp-size-sheet__close" data-size-sheet-close aria-label="Close">
                          {% render 'icon', name: 'close', size: 20 %}
                        </button>
                      </div>
                      <div class="pp-size-sheet__body">
                        <div class="pp-size-dots">
                          {%- for value in option.values -%}
                            <div class="pp-size-dot-wrap">
                              <button
                                type="button"
                                class="pp-size-dot{% if option.selected_value == value %} is-active{% endif %}"
                                data-option
                                data-option-position="{{ forloop.parentloop.index }}"
                                data-value="{{ value }}"
                                data-sheet-size
                              >{{ value }}</button>
                            </div>
                          {%- endfor -%}
                        </div>
                        <button type="button" class="pp-size-guide" data-size-guide-open>{{ 'product.size_guide' | t | default: 'Trouver ma taille' }}</button>
                      </div>
                    </div>
                  </div>

                {%- else -%}
                  {%- comment -%} Generic option {%- endcomment -%}
                  <div class="pp-option-group">
                    <div class="pp-option-header">
                      <span class="pp-option-name">{{ option.name }}</span>
                    </div>
                    <div class="pp-size-dots">
                      {%- for value in option.values -%}
                        <div class="pp-size-dot-wrap">
                          <button
                            type="button"
                            class="pp-size-dot{% if option.selected_value == value %} is-active{% endif %}"
                            data-option
                            data-option-position="{{ forloop.parentloop.index }}"
                            data-value="{{ value }}"
                          >{{ value }}</button>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}

              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <input type="hidden" name="quantity" value="1">
            </variant-selector>

            {%- comment -%} Purchase buttons + wishlist {%- endcomment -%}
            <div class="pp-purchase">
              <div class="pp-purchase__row">
                <button
                  type="submit"
                  class="pp-add-btn"
                  data-add-to-cart
                  data-add-text="{{ 'product.add_to_cart' | t }}"
                  data-soldout-text="{{ 'product.sold_out' | t }}"
                  data-unavailable-text="{{ 'product.unavailable' | t }}"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  {%- if current_variant.available -%}
                    {{ 'product.add_to_cart' | t }}
                  {%- else -%}
                    {{ 'product.sold_out' | t }}
                  {%- endif -%}
                </button>
                <button
                  type="button"
                  class="pp-wishlist-btn"
                  data-wishlist-toggle
                  data-product-handle="{{ product.handle }}"
                  aria-label="{{ 'header.wishlist' | t }}"
                >
                  <span class="pp-wishlist-btn__icon">{% render 'icon', name: 'heart', size: 20 %}</span>
                  <span class="pp-wishlist-btn__icon--filled">{% render 'icon', name: 'heart-filled', size: 20 %}</span>
                </button>
              </div>
            </div>
          {%- endform -%}

          {%- comment -%} ── Trust badges ── {%- endcomment -%}
          {%- liquid
            assign has_badges = false
            for block in section.blocks
              if block.type == 'trust_badge'
                assign has_badges = true
                break
              endif
            endfor
          -%}

          {%- if has_badges -%}
            <div class="pp-trust-badges">
              {%- for block in section.blocks -%}
                {%- if block.type == 'trust_badge' -%}
                  <div class="pp-trust-badge" {{ block.shopify_attributes }}>
                    <span class="pp-trust-badge__icon">
                      {% render 'icon', name: block.settings.icon, size: 20 %}
                    </span>
                    <span class="pp-trust-badge__text">{{ block.settings.text }}</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Model info (subtle) {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'model_info' -%}
              <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} ── Accordions ── {%- endcomment -%}
          <div class="pp-accordions">

            {%- comment -%} Product details accordion (product.description) {%- endcomment -%}
            {%- if product.description != blank -%}
              <accordion-toggle class="pp-accordion">
                <button class="pp-accordion__trigger" data-accordion-trigger aria-expanded="false">
                  <span>{{ 'product.product_details' | t | default: 'Détails du produit' }}</span>
                  <span class="pp-accordion__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                </button>
                <div class="accordion__panel pp-accordion__panel" hidden>
                  <div class="pp-accordion__content">
                    {{ product.description }}
                  </div>
                </div>
              </accordion-toggle>
            {%- endif -%}

            {%- comment -%} Custom accordion blocks (Delivery, Fabric, etc.) {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'tab' -%}
                <accordion-toggle class="pp-accordion" {{ block.shopify_attributes }}>
                  <button class="pp-accordion__trigger" data-accordion-trigger aria-expanded="false">
                    <span>{{ block.settings.title }}</span>
                    <span class="pp-accordion__chevron">{% render 'icon', name: 'chevron-right', size: 12 %}</span>
                  </button>
                  <div class="accordion__panel pp-accordion__panel" hidden>
                    <div class="pp-accordion__content">
                      {{ block.settings.content }}
                    </div>
                  </div>
                </accordion-toggle>
              {%- endif -%}
            {%- endfor -%}

          </div>

          {%- comment -%} ── Complete the Look ── {%- endcomment -%}
          {%- liquid
            assign has_manual_cross_sell = false
            for block in section.blocks
              if block.type == 'cross_sell_product' and block.settings.product != blank
                assign has_manual_cross_sell = true
                break
              endif
            endfor
          -%}

          {%- if has_manual_cross_sell -%}
            {%- comment -%} Manual picks from theme editor {%- endcomment -%}
            <div class="pp-look">
              <div class="pp-look__header">
                <h3 class="pp-look__title">{{ section.settings.cross_sell_heading | default: 'Complétez le look' }}</h3>
              </div>
              <div class="pp-look__track">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'cross_sell_product' and block.settings.product != blank -%}
                    {%- assign cs = block.settings.product -%}
                    <a href="{{ cs.url }}" class="pp-look__card" {{ block.shopify_attributes }}>
                      <div class="pp-look__card-image">
                        {%- if cs.featured_media -%}
                          <img
                            src="{{ cs.featured_media | image_url: width: 500 }}"
                            alt="{{ cs.featured_media.alt | escape | default: cs.title }}"
                            loading="lazy"
                          >
                        {%- endif -%}
                      </div>
                      <div class="pp-look__card-info">
                        <span class="pp-look__card-name">{{ cs.title }}</span>
                        <span class="pp-look__card-price">{{ cs.price | money }}</span>
                      </div>
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            {%- comment -%} Auto recommendations via Shopify API + collection fallback {%- endcomment -%}
            <div
              class="pp-look"
              data-product-recommendations
              data-product-id="{{ product.id }}"
              data-product-handle="{{ product.handle }}"
              data-collection-url="{{ product.collections.first.url }}"
              data-limit="8"
              data-heading="{{ section.settings.cross_sell_heading | default: 'Complétez le look' }}"
              style="display:none;"
            >
              <div class="pp-look__header">
                <h3 class="pp-look__title">{{ section.settings.cross_sell_heading | default: 'Complétez le look' }}</h3>
              </div>
              <div class="pp-look__track"></div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} Sticky bottom bar — mobile only (like LV) {%- endcomment -%}
<div class="pp-sticky-bar">
  <div class="pp-sticky-bar__info">
    <span class="pp-sticky-bar__name">{{ product.title }}</span>
    <span class="pp-sticky-bar__price" data-product-price>{{ current_variant.price | money }}</span>
  </div>
  <button
    type="button"
    class="pp-sticky-bar__btn"
    data-sticky-atc
  >
    {{ 'product.add_to_cart' | t }}
  </button>
</div>

<style>
/* ============================================================
   PRODUCT PAGE — Louis Vuitton-exact layout (pp-*)
   Values extracted from louisvuitton.com production CSS
   ============================================================ */

.pp-section {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 24px;
  color: #000;
  margin: 0;
  padding: 0;
}

.pp-section *, .pp-section *::before, .pp-section *::after {
  font-family: inherit;
  box-sizing: border-box;
}

/* ── Layout: 50/50 flex row ── */

.pp-layout {
  display: flex;
  flex-direction: row;
}

/* ═══════════════════════════════════════════════
   LEFT — Vertical scrollable image gallery
   Background: #f8f8f8 (LV gallery bg)
   ═══════════════════════════════════════════════ */

.pp-gallery {
  width: 50%;
  background: #f8f8f8;
  display: block;
  position: relative;
}

.pp-gallery__track {
  display: block;
}

.pp-gallery__item {
  display: block;
  width: 100%;
  overflow: hidden;
}

.pp-gallery__item img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* Dots indicator — hidden on desktop */
.pp-gallery__dots {
  display: none;
}

.pp-gallery__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: none;
  background: #b4b4b4;
  padding: 0;
  cursor: pointer;
  transition: background 0.2s;
}

.pp-gallery__dot.is-active {
  background: #000;
}

.pp-gallery__placeholder {
  width: 100%;
  aspect-ratio: 4 / 5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
}

.pp-gallery__placeholder-svg {
  width: 40%;
  opacity: 0.2;
}

/* ── Title row (title + wishlist side by side) ── */

.pp-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.75rem;
}

.pp-title-row .pp-title {
  flex: 1;
}

/* Mobile-only wishlist button next to title — hidden on desktop */
.pp-wishlist-btn--title {
  display: none;
}

/* ── Sticky bottom bar — mobile only ── */

.pp-sticky-bar {
  display: none;
}

/* ═══════════════════════════════════════════════
   RIGHT — Sticky info column
   White background, vertically centered content
   ═══════════════════════════════════════════════ */

.pp-info-col {
  width: 50%;
  background: #fff;
  position: relative;
}

.pp-info-sticky {
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  width: 100%;
}

.pp-info {
  width: 100%;
  max-width: 360px;
  padding: 48px 16px;
}

/* ── Title — heading-s: 18px/400 ── */

.pp-title {
  font-size: 1.375rem;
  font-weight: 500;
  letter-spacing: 0.01rem;
  line-height: 1.75rem;
  margin: 0;
  color: #000;
}

/* ── SKU — overline: 10px uppercase ── */

.pp-sku {
  font-size: 0.625rem;
  font-weight: 400;
  letter-spacing: 0.0625rem;
  line-height: 1rem;
  text-transform: uppercase;
  color: #000;
  margin: 0;
}

/* ── Price — body-s: 14px ── */

.pp-price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.01rem;
  line-height: 1.5rem;
  color: #000;
  margin: 0.25rem 0 0;
}

.pp-price--compare {
  font-size: 0.875rem;
  color: #767676;
}

.pp-price--compare s {
  text-decoration: line-through;
}

/* ═══════════════════════════════════════════════
   OPTIONS — Color swatches & Size selector
   ═══════════════════════════════════════════════ */

.pp-option-group {
  border-top: none;
}

.pp-option-group:last-of-type {
  border-bottom: 1px solid #e1e1e1;
}

/* Option header row (Color label + value) */

.pp-option-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 0 0.75rem;
}

.pp-option-name {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

.pp-option-value {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

/* Color swatches — 40px circles with image/color fill */

.pp-swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  padding-bottom: 1.5rem;
}

.pp-swatch {
  width: 64px;
  height: 80px;
  border-radius: 10px;
  border: 2px solid #e1e1e1;
  overflow: hidden;
  cursor: pointer;
  padding: 4px;
  transition: border-color 0.3s;
  background: #f6f6f6;
}

.pp-swatch.is-active {
  border-color: #000;
}

.pp-swatch:hover:not(.is-active) {
  border-color: #767676;
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 6px;
  display: block;
}

.pp-swatch__color {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 6px;
}

/* ── Size selector — expandable row ── */

.pp-size-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 4.5rem;
  padding: 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
  color: #000;
}

.pp-size-selector__label {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
}

.pp-size-selector__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.pp-size-selector__value {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
}

.pp-size-selector__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.pp-size-selector__chevron svg {
  width: 12px;
  height: 12px;
}

.pp-size-selector.is-open .pp-size-selector__chevron {
  transform: rotate(90deg);
}

/* Size panel (hidden by default) */

.pp-size-panel {
  padding: 0 0 1.5rem;
}

.pp-size-dots {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem 1.5rem;
}

.pp-size-dot-wrap {
  position: relative;
}

.pp-size-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 2.5rem;
  height: 2.5rem;
  padding: 0 0.75rem;
  border-radius: 100vmax;
  border: 1px solid #b4b4b4;
  background: none;
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
  cursor: pointer;
  transition: border-color 0.3s, border-width 0.3s;
}

.pp-size-dot.is-active {
  border-color: #000;
  border-width: 2px;
}

.pp-size-dot:hover:not(.is-active) {
  border-color: #767676;
}

.pp-size-dot:disabled {
  color: #b4b4b4;
  border-color: #e1e1e1;
  cursor: not-allowed;
  text-decoration: line-through;
}

.pp-size-guide {
  display: inline-block;
  margin-top: 1.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  color: #000;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-thickness: 1px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  font-family: inherit;
}

.pp-size-guide:hover {
  color: #767676;
}

/* ── Size bottom sheet — hidden on desktop ── */

.pp-size-sheet {
  display: none;
}

/* ═══════════════════════════════════════════════
   PURCHASE — Add to bag + secondary button
   margin: 1.5rem 0
   ═══════════════════════════════════════════════ */

.pp-purchase {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin: 1.5rem 0;
}

.pp-purchase__row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

/* Primary button — pill shape, black bg */

.pp-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 0.8125rem 2rem;
  background-color: #000;
  color: #fff;
  border: 1px solid #000;
  border-radius: 100vmax;
  font-family: inherit;
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  text-decoration: none;
  cursor: pointer;
  text-align: center;
  transition: border 0.3s, box-shadow 0.3s, color 0.3s, background 0.3s;
}

.pp-add-btn:hover {
  color: #000;
  background-color: #fff;
}

.pp-add-btn:disabled {
  color: #767676;
  background-color: #e1e1e1;
  border-color: #e1e1e1;
  cursor: not-allowed;
}

/* Wishlist button — circle outline */

.pp-wishlist-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 3rem;
  height: 3rem;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1px solid #000;
  background: none;
  cursor: pointer;
  color: #000;
  padding: 0;
  transition: background 0.3s, color 0.3s;
}

.pp-wishlist-btn:hover {
  background: #000;
  color: #fff;
}

.pp-wishlist-btn__icon,
.pp-wishlist-btn__icon--filled {
  display: flex;
  align-items: center;
  justify-content: center;
}

.pp-wishlist-btn__icon--filled {
  display: none;
}

.pp-wishlist-btn.is-wishlisted .pp-wishlist-btn__icon {
  display: none;
}

.pp-wishlist-btn.is-wishlisted .pp-wishlist-btn__icon--filled {
  display: flex;
}

.pp-wishlist-btn__icon svg,
.pp-wishlist-btn__icon--filled svg {
  width: 20px;
  height: 20px;
}

/* ── Model info ── */

.pp-model-info {
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #767676;
  margin: 0 0 1rem;
}

/* ═══════════════════════════════════════════════
   TRUST BADGES — below ATC button
   ═══════════════════════════════════════════════ */

.pp-trust-badges {
  display: flex;
  border: 1px solid #e1e1e1;
  border-radius: 100vmax;
  overflow: hidden;
  margin-bottom: 1rem;
}

.pp-trust-badge {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 0.75rem;
  text-align: center;
  position: relative;
}

.pp-trust-badge + .pp-trust-badge::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 1px;
  background: #e1e1e1;
}

.pp-trust-badge__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
}

.pp-trust-badge__icon svg {
  width: 20px;
  height: 20px;
}

.pp-trust-badge__text {
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

/* ═══════════════════════════════════════════════
   ACCORDIONS — LV product panels
   border-top: 1px solid #e1e1e1
   ═══════════════════════════════════════════════ */

.pp-accordions {
  margin-top: 2rem;
}

.pp-accordion {
  display: block;
}

.pp-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 1.5rem 0;
  background: none;
  border: none;
  border-top: 1px solid #e1e1e1;
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
  cursor: pointer;
  text-align: left;
}

.pp-accordion:last-child .pp-accordion__trigger {
  border-bottom: none;
}

.pp-accordion__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.pp-accordion__chevron svg {
  width: 12px;
  height: 12px;
}

.pp-accordion.is-open .pp-accordion__chevron {
  transform: rotate(90deg);
}

.pp-accordion__panel {
  overflow: hidden;
  transition: max-height 0.35s ease;
}

.pp-accordion__content {
  padding: 0 0 1.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.25rem;
  color: #000;
}

.pp-accordion__content p {
  margin: 0 0 0.75rem;
}

.pp-accordion__content p:last-child {
  margin-bottom: 0;
}

.pp-accordion__content a {
  color: #000;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.pp-accordion__content ul,
.pp-accordion__content ol {
  padding-left: 1.25rem;
  margin: 0 0 0.75rem;
}

.pp-accordion__content li {
  margin-bottom: 0.25rem;
  line-height: 1.25rem;
}

/* ═══════════════════════════════════════════════
   COMPLETE THE LOOK — LV-style horizontal scroll
   ═══════════════════════════════════════════════ */

.pp-look {
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e1e1e1;
}

.pp-look__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
}

.pp-look__title {
  font-family: inherit;
  font-size: 1.125rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1.5rem;
  color: #000;
  margin: 0;
}

.pp-look__track {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding-bottom: 0.5rem;
}

.pp-look__track::-webkit-scrollbar {
  display: none;
}

.pp-look__card {
  flex: 0 0 10rem;
  scroll-snap-align: start;
  text-decoration: none;
  color: #000;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.pp-look__card:hover .pp-look__card-name {
  text-decoration: underline;
}

.pp-look__card-image {
  width: 100%;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: #f8f8f8;
}

.pp-look__card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.pp-look__card:hover .pp-look__card-image img {
  transform: scale(1.03);
}

.pp-look__card-info {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}

.pp-look__card-name {
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pp-look__card-price {
  font-size: 0.75rem;
  font-weight: 400;
  letter-spacing: 0.025rem;
  line-height: 1rem;
  color: #000;
}

/* ═══════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════ */

/* Tablet — stack layout */
@media (max-width: 1023px) {
  .pp-layout {
    flex-direction: column;
  }

  .pp-gallery {
    width: 100%;
  }

  .pp-info-col {
    width: 100%;
  }

  .pp-info-sticky {
    position: static;
    min-height: auto;
  }

  .pp-info {
    max-width: 100%;
    padding: 1.5rem 3.125vw;
    margin: 0 auto;
  }
}

/* ═══════════════════════════════════════════════
   MOBILE — LV-style product page
   ═══════════════════════════════════════════════ */
@media (max-width: 767px) {

  /* ── Gallery: horizontal swipe carousel ── */
  .pp-gallery {
    background: #f6f6f6;
    overflow: hidden;
    position: relative;
  }

  .pp-gallery__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .pp-gallery__track::-webkit-scrollbar {
    display: none;
  }

  .pp-gallery__item {
    flex: 0 0 100%;
    scroll-snap-align: center;
  }

  .pp-gallery__item img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  /* Dots indicator */
  .pp-gallery__dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 12px 0 16px;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
  }

  /* ── Info section ── */
  .pp-info {
    padding: 20px 16px 100px; /* bottom padding for sticky bar */
  }

  /* Title + wishlist row */
  .pp-title-row {
    align-items: center;
  }

  .pp-title {
    font-size: 1.375rem;
    line-height: 1.75rem;
    font-weight: 500;
    margin: 0;
  }

  /* Show wishlist button next to title on mobile */
  .pp-wishlist-btn--title {
    display: flex;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    background: none;
    color: #000;
  }

  .pp-wishlist-btn--title:hover {
    background: none;
    color: #000;
  }

  /* Hide wishlist button next to ATC on mobile */
  .pp-purchase__row .pp-wishlist-btn {
    display: none;
  }

  .pp-purchase__row {
    gap: 0;
  }

  /* Full-width ATC on mobile */
  .pp-add-btn {
    width: 100%;
    flex: none;
    padding: 14px 24px;
    font-size: 0.9375rem;
  }

  /* SKU */
  .pp-sku {
    margin-top: 2px;
  }

  /* Price */
  .pp-price {
    margin: 4px 0 0;
    font-size: 1.125rem;
    font-weight: 400;
  }

  /* Size selector */
  .pp-size-selector {
    height: 3.25rem;
  }

  .pp-size-dots {
    gap: 1rem 0.625rem;
  }

  .pp-size-dot {
    min-width: 2.5rem;
    height: 2.5rem;
    font-size: 0.8125rem;
  }

  /* Trust badges — equal width on mobile */
  .pp-trust-badges {
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .pp-trust-badge {
    flex: 1 1 0%;
    min-width: 0;
    padding: 0.875rem 0.5rem;
    gap: 0.375rem;
  }

  .pp-trust-badge__text {
    font-size: 0.6875rem;
    line-height: 0.875rem;
    white-space: normal;
    word-break: break-word;
  }

  /* Accordions tighter spacing */
  .pp-accordion__trigger {
    padding: 16px 0;
  }

  .pp-accordion__content {
    font-size: 0.8125rem;
    line-height: 1.375rem;
  }

  /* Complete the Look cards smaller */
  .pp-look {
    margin-top: 2rem;
    padding-top: 1.25rem;
  }

  .pp-look__card {
    flex: 0 0 8.5rem;
  }

  .pp-look__card-image {
    aspect-ratio: 3 / 4;
  }

  /* ── Sticky bottom bar ── */
  .pp-sticky-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #fff;
    border-top: 1px solid #e1e1e1;
    padding: 10px 16px;
    gap: 12px;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .pp-sticky-bar.is-visible {
    transform: translateY(0);
  }

  .pp-sticky-bar__info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .pp-sticky-bar__name {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02rem;
    line-height: 1rem;
    color: #000;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pp-sticky-bar__price {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02rem;
    line-height: 1rem;
    color: #000;
  }

  .pp-sticky-bar__btn {
    flex-shrink: 0;
    padding: 10px 20px;
    background: #000;
    color: #fff;
    border: 1px solid #000;
    border-radius: 100vmax;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.025rem;
    line-height: 1.25rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.3s, color 0.3s;
  }

  .pp-sticky-bar__btn:hover {
    background: #fff;
    color: #000;
  }

  /* ── Size selector: hide inline panel, use bottom sheet ── */
  .pp-size-panel--inline {
    display: none !important;
  }

  .pp-size-selector {
    cursor: pointer;
  }

  /* ── Size bottom sheet ── */
  .pp-size-sheet {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
    visibility: hidden;
  }

  .pp-size-sheet.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .pp-size-sheet__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.3s ease;
  }

  .pp-size-sheet.is-open .pp-size-sheet__overlay {
    background: rgba(0, 0, 0, 0.4);
  }

  .pp-size-sheet__drawer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    border-radius: 16px 16px 0 0;
    padding: 0 20px 32px;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    max-height: 70vh;
    overflow-y: auto;
  }

  .pp-size-sheet.is-open .pp-size-sheet__drawer {
    transform: translateY(0);
  }

  .pp-size-sheet__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0 24px;
    position: sticky;
    top: 0;
    background: #fff;
  }

  .pp-size-sheet__title {
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: 0.025rem;
    line-height: 1.5rem;
    color: #000;
  }

  .pp-size-sheet__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    color: #000;
    cursor: pointer;
    padding: 0;
  }

  .pp-size-sheet__body {
    padding-bottom: 8px;
  }

  .pp-size-sheet__body .pp-size-dots {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .pp-size-sheet__body .pp-size-dot {
    min-width: 3.5rem;
    height: 2.75rem;
    padding: 0 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    background: #f6f6f6;
    border: 2px solid transparent;
  }

  .pp-size-sheet__body .pp-size-dot.is-active {
    border-color: #000;
    background: #fff;
  }

  .pp-size-sheet__body .pp-size-dot:not(.is-active):not(:disabled) {
    border-color: transparent;
  }

  .pp-size-sheet__body .pp-size-guide {
    margin-top: 1.25rem;
  }
}

/* Wide screens — slightly larger info area */
@media (min-width: 1100px) {
  .pp-info {
    max-width: 380px;
  }
}

@media (min-width: 1440px) {
  .pp-info {
    max-width: 400px;
  }
}
