{%- comment -%}
  Product content section — gallery + info + cross-sell + accordions
  Scoped class prefix: pp-
  Matching reference: premium fashion product page layout.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_image = product.featured_media
-%}

<section class="pp-section">
  <div class="pp-container">

    {%- comment -%} ── Breadcrumbs ── {%- endcomment -%}
    <nav class="pp-breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="{{ routes.root_url }}">Accueil</a></li>
        {%- if product.collections.size > 0 -%}
          <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
        {%- endif -%}
        <li aria-current="page">{{ product.title }}</li>
      </ol>
    </nav>

    {%- comment -%} ── Two-column product layout ── {%- endcomment -%}
    <div class="pp-layout">

      {%- comment -%} ═══ LEFT COLUMN: Gallery + Cross-sell ═══ {%- endcomment -%}
      <div class="pp-left-col">

        {%- comment -%} Gallery ── {%- endcomment -%}
        <product-gallery class="pp-gallery-wrap">
          <div class="pp-gallery">

            {%- comment -%} Vertical thumbnail rail {%- endcomment -%}
            {%- if product.media.size > 1 -%}
              <div class="pp-thumbs">
                <div class="pp-thumbs__track" data-thumbs-list role="list">
                  {%- for media in product.media -%}
                    <button
                      class="pp-thumb{% if forloop.first %} is-active{% endif %}"
                      data-thumb="{{ forloop.index0 }}"
                      data-full-src="{{ media | image_url: width: 1200 }}"
                      role="listitem"
                      aria-label="Image {{ forloop.index }} sur {{ product.media.size }}"
                    >
                      <img
                        src="{{ media | image_url: width: 120 }}"
                        alt="{{ media.alt | escape | default: product.title }}"
                        width="60"
                        height="80"
                        loading="lazy"
                      >
                    </button>
                  {%- endfor -%}
                </div>
                <button class="pp-thumbs__arrow" data-thumbs-down aria-label="Plus d'images">
                  {% render 'icon', name: 'chevron-down', size: 12 %}
                </button>
              </div>
            {%- endif -%}

            {%- comment -%} Main media area {%- endcomment -%}
            <div class="pp-main-image">
              {%- if first_image -%}
                <img
                  data-main-image
                  src="{{ first_image | image_url: width: 1200 }}"
                  alt="{{ first_image.alt | escape | default: product.title }}"
                  width="1200"
                  height="{{ 1200 | divided_by: first_image.aspect_ratio | round }}"
                >
              {%- else -%}
                <div class="pp-main-image__placeholder">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              {%- if product.media.size > 1 -%}
                <button class="pp-nav pp-nav--prev" data-gallery-prev aria-label="Image précédente">
                  {% render 'icon', name: 'chevron-left', size: 18 %}
                </button>
                <button class="pp-nav pp-nav--next" data-gallery-next aria-label="Image suivante">
                  {% render 'icon', name: 'chevron-right', size: 18 %}
                </button>
              {%- endif -%}
            </div>
          </div>
        </product-gallery>

        {%- comment -%} Cross-sell: Complétez le look ── {%- endcomment -%}
        {%- liquid
          assign has_cross_sell = false
          for block in section.blocks
            if block.type == 'cross_sell_product' and block.settings.product != blank
              assign has_cross_sell = true
              break
            endif
          endfor
          if section.settings.cross_sell_metafield and product.metafields.custom.cross_sell_products.value
            assign has_cross_sell = true
          endif
        -%}

        {%- if has_cross_sell -%}
          <div class="pp-cross-sell">
            <h2 class="pp-cross-sell__title">{{ section.settings.cross_sell_heading | default: 'Complétez le look' }}</h2>
            <div class="pp-cross-sell__grid">
              {%- for block in section.blocks -%}
                {%- if block.type == 'cross_sell_product' and block.settings.product != blank -%}
                  {% render 'product-card', product: block.settings.product %}
                {%- endif -%}
              {%- endfor -%}

              {%- if section.settings.cross_sell_metafield and product.metafields.custom.cross_sell_products.value -%}
                {%- for cross_product in product.metafields.custom.cross_sell_products.value -%}
                  {% render 'product-card', product: cross_product %}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} ═══ RIGHT COLUMN: Product Info ═══ {%- endcomment -%}
      <div class="pp-info-col">
        <div class="pp-info">

          {%- comment -%} 1. Title + Wishlist {%- endcomment -%}
          <div class="pp-title-row">
            <h1 class="pp-title">{{ product.title }}</h1>
            <button class="pp-wishlist btn--icon" data-wishlist-toggle data-product-handle="{{ product.handle }}" aria-label="Ajouter aux favoris">
              {% render 'icon', name: 'heart', size: 20 %}
            </button>
          </div>

          {%- comment -%} 2. Subtitle (selected color value) {%- endcomment -%}
          {%- for option in product.options_with_values -%}
            {%- if option.name == 'Color' or option.name == 'Couleur' -%}
              <p class="pp-subtitle" data-color-name>{{ option.selected_value }}</p>
            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} 3. Price {%- endcomment -%}
          <div class="pp-price">
            <span class="pp-price__current" data-product-price>{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="pp-price__compare" data-compare-price>
                <s>{{ current_variant.compare_at_price | money }}</s>
              </span>
            {%- else -%}
              <span class="pp-price__compare" data-compare-price style="display:none;"></span>
            {%- endif -%}
          </div>

          {%- comment -%} Product form {%- endcomment -%}
          {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
            <variant-selector>
              <script type="application/json" data-variants>{{ product.variants | json }}</script>

              {%- for option in product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Couleur' -%}
                  {%- comment -%} Divider + Color {%- endcomment -%}
                  <hr class="pp-divider">
                  <p class="pp-option-label">Couleur : <span data-color-name>{{ option.selected_value }}</span></p>
                  <div class="pp-swatches">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign variant_for_color = nil
                        for variant in product.variants
                          if variant.options[forloop.parentloop.index0] == value
                            assign variant_for_color = variant
                            break
                          endif
                        endfor
                      -%}
                      <button
                        type="button"
                        class="pp-swatch{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                        aria-label="{{ value }}"
                        title="{{ value }}"
                      >
                        {%- if variant_for_color and variant_for_color.featured_image -%}
                          <img src="{{ variant_for_color.featured_image | image_url: width: 120 }}" alt="{{ value }}" width="52" height="52">
                        {%- else -%}
                          <span class="pp-swatch__dot" style="background-color: {{ value | handleize }};"></span>
                        {%- endif -%}
                      </button>
                    {%- endfor -%}
                  </div>

                {%- elsif option.name == 'Size' or option.name == 'Taille' -%}
                  {%- comment -%} Divider + Size {%- endcomment -%}
                  <hr class="pp-divider">
                  <div class="pp-size-row">
                    <span class="pp-size-label">Taille <span data-size-value>{{ option.selected_value }}</span></span>
                    {%- if section.settings.size_guide_url != blank -%}
                      <a href="{{ section.settings.size_guide_url }}" class="pp-size-guide">Guide des tailles</a>
                    {%- endif -%}
                  </div>
                  <div class="pp-sizes">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>

                {%- else -%}
                  {%- comment -%} Generic option {%- endcomment -%}
                  <hr class="pp-divider">
                  <p class="pp-option-label">{{ option.name }}</p>
                  <div class="pp-sizes">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="pp-size{% if option.selected_value == value %} is-active{% endif %}"
                        data-option
                        data-option-position="{{ forloop.parentloop.index }}"
                        data-value="{{ value }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}

              <input type="hidden" name="id" value="{{ current_variant.id }}">
            </variant-selector>

            {%- comment -%} Model info blocks {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'model_info' -%}
                <p class="pp-model-info" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} Installments {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'installments' -%}
                <div class="pp-installments" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
              {%- endif -%}
            {%- endfor -%}

            <input type="hidden" name="quantity" value="1">

            {%- comment -%} Add to cart {%- endcomment -%}
            <button
              type="submit"
              class="pp-add-btn"
              data-add-to-cart
              data-add-text="{{ 'product.add_to_cart' | t }}"
              data-soldout-text="{{ 'product.sold_out' | t }}"
              data-unavailable-text="{{ 'product.unavailable' | t }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'product.add_to_cart' | t }}
              {%- else -%}
                {{ 'product.sold_out' | t }}
              {%- endif -%}
            </button>

            {%- comment -%} Dynamic checkout {%- endcomment -%}
            <div class="pp-express-btn">
              {{ form | payment_button }}
            </div>
          {%- endform -%}

          {%- comment -%} Trust box — 2 columns, icons centered above text {%- endcomment -%}
          <div class="pp-trust-box">
            <div class="pp-trust-cell">
              {% render 'icon', name: 'return', size: 22 %}
              <span>{{ section.settings.trust_return_text | default: 'Retour sous 14 jours' }}</span>
            </div>
            <div class="pp-trust-cell">
              {% render 'icon', name: 'truck', size: 22 %}
              <span>{{ section.settings.trust_shipping_text | default: 'Livraison Rapide' }}</span>
            </div>
          </div>

          {%- comment -%} Description accordion (open by default) {%- endcomment -%}
          {%- if product.description != blank -%}
            {% render 'accordion', title: 'Description', content: product.description, id: 'product-description', open: true %}
          {%- endif -%}

          {%- comment -%} Other accordions {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'accordion' -%}
              {% render 'accordion', title: block.settings.title, content: block.settings.content, id: block.id, open: block.settings.open_by_default %}
            {%- endif -%}
          {%- endfor -%}

          {%- assign has_accordions = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'accordion' -%}{%- assign has_accordions = true -%}{%- endif -%}
          {%- endfor -%}
          {%- unless has_accordions -%}
            {% render 'accordion', title: 'Composition & entretien', content: '<p>Informations du marchand.</p>', id: 'composition' %}
            {% render 'accordion', title: 'Livraisons & retours', content: '<p>Livraison standard sous 3-5 jours ouvrés. Retour gratuit sous 14 jours.</p>', id: 'shipping' %}
            {% render 'accordion', title: 'Moyens de paiement', content: '<p>Visa, Mastercard, American Express, PayPal, Scalapay (3x sans frais).</p>', id: 'payment' %}
          {%- endunless -%}

        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* ============================================================
   PRODUCT PAGE — Scoped styles (pp-*)
   Matches reference: premium fashion product page.
   Font: Avenir
   ============================================================ */

/* ── Section wrapper ── */
.pp-section {
  padding: 0 0 20px;
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.pp-section *, .pp-section *::before, .pp-section *::after {
  font-family: inherit;
}

.pp-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ── Breadcrumbs ── */
.pp-breadcrumbs {
  padding: 14px 0 20px;
  font-size: 0.78rem;
  color: #999;
}

.pp-breadcrumbs ol {
  display: flex;
  align-items: center;
  list-style: none;
  padding: 0;
  margin: 0;
  flex-wrap: wrap;
  gap: 0;
}

.pp-breadcrumbs li {
  display: flex;
  align-items: center;
}

.pp-breadcrumbs li:not(:last-child)::after {
  content: '-';
  margin: 0 8px;
  color: #ccc;
}

.pp-breadcrumbs a {
  color: #999;
  text-decoration: none;
  transition: color 0.2s;
}

.pp-breadcrumbs a:hover {
  color: var(--color-text);
}

.pp-breadcrumbs li[aria-current="page"] {
  color: var(--color-text);
}

/* ── Two-column layout ── */
.pp-layout {
  display: grid;
  grid-template-columns: 56% 1fr;
  gap: 40px;
  align-items: start;
}

/* ═══════════════════════════════════════════════
   LEFT COLUMN: Gallery + Cross-sell
   ═══════════════════════════════════════════════ */
.pp-left-col {
  min-width: 0;
}

.pp-gallery-wrap {
  display: block;
  position: sticky;
  top: 90px;
}

.pp-gallery {
  display: flex;
  gap: 12px;
}

/* Thumbnail rail */
.pp-thumbs {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
  width: 110px;
}

.pp-thumbs__track {
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow-y: auto;
  max-height: 650px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.pp-thumbs__track::-webkit-scrollbar {
  display: none;
}

.pp-thumb {
  width: 100px;
  height: 130px;
  border: 1.5px solid transparent;
  border-radius: 4px;
  overflow: hidden;
  cursor: pointer;
  opacity: 0.6;
  transition: all 0.2s ease;
  flex-shrink: 0;
  padding: 0;
  background: none;
}

.pp-thumb.is-active,
.pp-thumb:hover {
  opacity: 1;
  border-color: var(--color-text);
}

.pp-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-thumbs__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: none;
  background: none;
  cursor: pointer;
  color: #aaa;
  transition: color 0.2s;
  flex-shrink: 0;
  padding: 0;
  margin-top: 4px;
}

.pp-thumbs__arrow:hover {
  color: var(--color-text);
}

/* Main media area */
.pp-main-image {
  position: relative;
  flex: 1;
  min-width: 0;
  border-radius: 4px;
  overflow: hidden;
  background: #f5f3ef;
  aspect-ratio: 3 / 4;
}

.pp-main-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pp-main-image__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0ede8;
}

.pp-main-image__placeholder svg {
  width: 50%;
  opacity: 0.35;
}

/* Gallery prev/next arrows */
.pp-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 1px 5px rgba(0, 0, 0, 0.1);
  transition: opacity 0.2s;
  color: #333;
  padding: 0;
  z-index: 2;
}

.pp-nav:hover {
  opacity: 0.8;
}

.pp-nav--prev { left: 12px; }
.pp-nav--next { right: 12px; }

/* ── Cross-sell: Complétez le look ── */
.pp-cross-sell {
  margin-top: 48px;
}

.pp-cross-sell__title {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 1.25rem;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 0;
  text-align: center;
  margin: 0 0 22px;
  color: var(--color-text);
}

.pp-cross-sell__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ═══════════════════════════════════════════════
   RIGHT COLUMN: Product Info
   ═══════════════════════════════════════════════ */
.pp-info-col {
  min-width: 0;
}

.pp-info {
  max-width: 440px;
}

/* Title row */
.pp-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.pp-title {
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 1.6rem;
  font-weight: 500;
  letter-spacing: 0;
  line-height: 1.25;
  margin: 0;
  color: var(--color-text);
}

.pp-wishlist {
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: #888;
  flex-shrink: 0;
  margin-top: 2px;
  transition: color 0.2s;
}

.pp-wishlist:hover {
  color: var(--color-text);
}

/* Subtitle */
.pp-subtitle {
  font-size: 0.95rem;
  color: #555;
  margin: 8px 0 0;
  font-weight: 400;
}

/* Price */
.pp-price {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin: 28px 0 0;
}

.pp-price__current {
  font-size: 1.3rem;
  font-weight: 500;
  color: var(--color-text);
}

.pp-price__compare {
  font-size: 0.95rem;
  color: #aaa;
}

.pp-price__compare s {
  text-decoration: line-through;
}

/* Dividers */
.pp-divider {
  border: none;
  border-top: 1px solid #e5e2dd;
  margin: 24px 0;
}

/* Option label */
.pp-option-label {
  font-size: 0.92rem;
  color: #777;
  margin: 0 0 16px;
}

.pp-option-label span {
  color: var(--color-text);
}

/* Color swatches */
.pp-swatches {
  display: flex;
  gap: 10px;
  margin-bottom: 0;
  flex-wrap: wrap;
}

.pp-swatch {
  width: 62px;
  height: 80px;
  border-radius: 4px;
  border: 1.5px solid #e0ddd8;
  overflow: hidden;
  cursor: pointer;
  padding: 2px;
  transition: border-color 0.2s;
  background: none;
}

.pp-swatch.is-active {
  border-color: var(--color-text);
}

.pp-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 2px;
  display: block;
}

.pp-swatch__dot {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 2px;
}

/* Size row */
.pp-size-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.pp-size-label {
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--color-text);
}

.pp-size-guide {
  font-size: 0.85rem;
  color: #777;
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s;
}

.pp-size-guide:hover {
  color: var(--color-text);
}

/* Size pills */
.pp-sizes {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 0;
}

.pp-size {
  min-width: 48px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d4d1cc;
  border-radius: 6px;
  background: transparent;
  font-size: 0.88rem;
  cursor: pointer;
  transition: all 0.2s;
  padding: 0 16px;
  color: var(--color-text);
}

.pp-size:hover {
  border-color: var(--color-text);
}

.pp-size.is-active {
  background: #f0ede8;
  border-color: #c8c5c0;
  font-weight: 500;
}

.pp-size:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  text-decoration: line-through;
}

/* Model info */
.pp-model-info {
  font-size: 0.88rem;
  color: #777;
  margin: 22px 0 0;
  line-height: 1.6;
}

.pp-model-info a {
  color: var(--color-text);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* Installments */
.pp-installments {
  font-size: 0.85rem;
  color: #777;
  margin: 20px 0 0;
  line-height: 1.55;
}

.pp-installments p {
  margin: 0;
}

/* ATC button */
.pp-add-btn {
  width: 100%;
  height: 52px;
  margin-top: 24px;
  background: #333;
  color: #fff;
  border: none;
  border-radius: 5px;
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s;
}

.pp-add-btn:hover {
  opacity: 0.85;
}

.pp-add-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

/* Dynamic checkout */
.pp-express-btn {
  width: 100%;
  margin-top: 8px;
}

.pp-express-btn .shopify-payment-button__button {
  border-radius: 5px !important;
  height: 50px !important;
  font-family: 'Avenir', 'Avenir Next', 'Helvetica Neue', Helvetica, Arial, sans-serif !important;
}

/* Trust box — 2 columns, icons centered above text */
.pp-trust-box {
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: 22px;
  border: 1px solid #e5e2dd;
  border-radius: 6px;
  overflow: hidden;
}

.pp-trust-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
