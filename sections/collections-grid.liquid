<section class="cg-section" data-section-id="{{ section.id }}">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h2 class="cg-title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="cg-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign col_title = block.settings.title_override
          if col_title == blank and col != blank
            assign col_title = col.title
          endif
          if col_title == blank
            assign col_title = 'Collection'
          endif
          assign col_image = block.settings.image_override
          if col_image == blank and col != blank
            assign col_image = col.image
          endif
          assign link_label = block.settings.link_label | default: section.settings.card_link_text | default: 'Découvrir'
        -%}
        <a href="{{ col.url | default: '#' }}" class="cg-card" {{ block.shopify_attributes }}>
          <div class="cg-card__img-wrap">
            {%- if col_image != blank -%}
              <img
                src="{{ col_image | image_url: width: 700 }}"
                alt="{{ col_title | escape }}"
                class="cg-card__img"
                width="700"
                height="875"
                loading="lazy"
                srcset="
                  {{ col_image | image_url: width: 400 }} 400w,
                  {{ col_image | image_url: width: 550 }} 550w,
                  {{ col_image | image_url: width: 700 }} 700w
                "
                sizes="(min-width: 1024px) 25vw, (min-width: 768px) 50vw, 100vw"
              >
            {%- else -%}
              <div class="cg-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'cg-card__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          <div class="cg-card__overlay">
            <h3 class="cg-card__name">{{ col_title }}</h3>
            <span class="cg-card__link">{{ link_label }}</span>
          </div>
        </a>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- for i in (1..4) -%}
          <a href="#" class="cg-card">
            <div class="cg-card__img-wrap">
              <div class="cg-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'cg-card__placeholder-svg' }}
              </div>
            </div>
            <div class="cg-card__overlay">
              <h3 class="cg-card__name">Collection {{ i }}</h3>
              <span class="cg-card__link">Découvrir</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="cg-footer">
        <a href="{{ section.settings.button_link | default: '/collections' }}" class="cg-btn">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Collections grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Découvrir nos collections"
    },
    {
      "type": "text",
      "id": "card_link_text",
      "label": "Card link text",
      "default": "Découvrir"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "TOUTES LES COLLECTIONS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Image override"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
