<section class="collections-grid-section section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="collections-grid-section__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign col_title = block.settings.title_override | default: col.title | default: 'Collection'
          assign col_image = block.settings.image_override | default: col.image
          assign col_url = col.url | default: '#'
        -%}
        <a href="{{ col_url }}" class="collection-card" {{ block.shopify_attributes }}>
          {%- if col_image != blank -%}
            <img
              src="{{ col_image | image_url: width: 600 }}"
              alt="{{ col_title | escape }}"
              class="collection-card__image"
              width="600"
              height="{{ 600 | divided_by: col_image.aspect_ratio | round }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image' }}
          {%- endif -%}
          <div class="collection-card__overlay">
            <h3 class="collection-card__title">{{ col_title }}</h3>
          </div>
        </a>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- for i in (1..4) -%}
          <a href="#" class="collection-card">
            {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image' }}
            <div class="collection-card__overlay">
              <h3 class="collection-card__title">Collection {{ i }}</h3>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections grid",
  "class": "collections-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Découvrir nos collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Image override"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

