<section class="collections-grid-section section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="collections-grid-section__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="collections-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign col_title = block.settings.title_override
          if col_title == blank and col != blank
            assign col_title = col.title
          endif
          if col_title == blank
            assign col_title = 'Collection'
          endif
          assign col_image = block.settings.image_override
          if col_image == blank and col != blank
            assign col_image = col.image
          endif
        -%}
        <a href="{{ col.url | default: '#' }}" class="collection-card" {{ block.shopify_attributes }}>
          {%- if col_image != blank -%}
            <img
              src="{{ col_image | image_url: width: 600 }}"
              alt="{{ col_title | escape }}"
              class="collection-card__image"
              width="600"
              height="750"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image' }}
          {%- endif -%}
          <div class="collection-card__overlay">
            <h3 class="collection-card__title">{{ col_title }}</h3>
            <span class="collection-card__link">{{ section.settings.card_link_text | default: 'Découvrir' }}</span>
          </div>
        </a>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- for i in (1..4) -%}
          <a href="#" class="collection-card">
            {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image' }}
            <div class="collection-card__overlay">
              <h3 class="collection-card__title">Collection {{ i }}</h3>
              <span class="collection-card__link">Découvrir</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="collections-grid-section__footer">
        <a href="{{ section.settings.button_link | default: '/collections' }}" class="btn btn--secondary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Découvrir nos collections"
    },
    {
      "type": "text",
      "id": "card_link_text",
      "label": "Card link text",
      "default": "Découvrir"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "TOUTES LES COLLECTIONS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Image override"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
