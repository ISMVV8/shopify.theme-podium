{%- if section.settings.enable_bar -%}
  <announcement-bar
    class="announcement-bar"
    role="complementary"
    aria-label="{{ 'announcement.default_message' | t | default: 'Announcement' }}"
    data-rotate="{{ section.settings.enable_message_rotation }}"
    data-interval="{{ section.settings.rotation_interval_seconds | times: 1000 }}"
    style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
  >
    <div class="announcement-bar__inner">

      {%- comment -%} LEFT — Language selector {%- endcomment -%}
      <div class="announcement-bar__zone announcement-bar__left">
        {%- if section.settings.show_language_left -%}
          <button class="announcement-bar__lang" type="button" aria-label="Change language">
            <span class="announcement-bar__lang-code">{{ request.locale.iso_code | upcase }}</span>
            {% render 'icon', name: 'chevron-down', size: 10 %}
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} CENTER — Messages carousel (true-centered via grid) {%- endcomment -%}
      <div class="announcement-bar__zone announcement-bar__center">
        {%- if section.blocks.size > 1 and section.settings.show_arrows -%}
          <button class="announcement-bar__arrow" data-announce-prev aria-label="Previous message" type="button">
            {% render 'icon', name: 'chevron-left', size: 12 %}
          </button>
        {%- endif -%}

        <div class="announcement-bar__messages" data-announce-track>
          {%- for block in section.blocks -%}
            {%- if block.type == 'message' -%}
              <p class="announcement-bar__message{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="announcement-bar__link">
                    {{ block.settings.message_text }}
                  </a>
                {%- else -%}
                  {{ block.settings.message_text }}
                {%- endif -%}
              </p>
            {%- endif -%}
          {%- endfor -%}

          {%- if section.blocks.size == 0 -%}
            <p class="announcement-bar__message is-active">
              Votre shopping encore plus facile : Téléchargez notre app !
            </p>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 1 and section.settings.show_arrows -%}
          <button class="announcement-bar__arrow" data-announce-next aria-label="Next message" type="button">
            {% render 'icon', name: 'chevron-right', size: 12 %}
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — Trustpilot badge {%- endcomment -%}
      <div class="announcement-bar__zone announcement-bar__right">
        {%- if section.settings.show_trustpilot_right -%}
          <div class="announcement-bar__trustpilot">
            <span class="announcement-bar__tp-rating">{{ section.settings.trustpilot_label_left }}</span>
            <span class="announcement-bar__tp-stars" aria-label="4.5 out of 5 stars">
              {%- for i in (1..4) -%}
                <svg class="announcement-bar__star" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <rect width="14" height="14" rx="1" fill="#00b67a"/>
                  <polygon points="7,1.5 8.3,5.2 12,5.2 9,7.4 10,11 7,8.8 4,11 5,7.4 2,5.2 5.7,5.2" fill="#fff"/>
                </svg>
              {%- endfor -%}
              <svg class="announcement-bar__star" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect width="14" height="14" rx="1" fill="#dcdce6"/>
                <clipPath id="announce-half-star"><rect x="0" y="0" width="7" height="14"/></clipPath>
                <rect width="14" height="14" rx="1" fill="#00b67a" clip-path="url(#announce-half-star)"/>
                <polygon points="7,1.5 8.3,5.2 12,5.2 9,7.4 10,11 7,8.8 4,11 5,7.4 2,5.2 5.7,5.2" fill="#fff"/>
              </svg>
            </span>
            <span class="announcement-bar__tp-name">{{ section.settings.trustpilot_label_right }}</span>
          </div>
        {%- endif -%}
      </div>

    </div>
  </announcement-bar>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_bar",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d7e9f6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Language selector"
    },
    {
      "type": "checkbox",
      "id": "show_language_left",
      "label": "Show language selector (left)",
      "default": true
    },
    {
      "type": "header",
      "content": "Trustpilot badge"
    },
    {
      "type": "checkbox",
      "id": "show_trustpilot_right",
      "label": "Show Trustpilot badge (right)",
      "default": true
    },
    {
      "type": "text",
      "id": "trustpilot_label_left",
      "label": "Rating label",
      "default": "Bien"
    },
    {
      "type": "text",
      "id": "trustpilot_label_right",
      "label": "Brand label",
      "default": "Trustpilot"
    },
    {
      "type": "header",
      "content": "Message rotation"
    },
    {
      "type": "checkbox",
      "id": "enable_message_rotation",
      "label": "Auto-rotate messages",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_interval_seconds",
      "label": "Rotation interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "message_text",
          "label": "Message text",
          "default": "Livraison offerte dès 75€ d'achat"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "message_text": "Votre shopping encore plus facile : Téléchargez notre app !"
          }
        }
      ]
    }
  ]
}
{% endschema %}
