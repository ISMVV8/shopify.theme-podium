<section class="login-hero">
  <div class="login-hero__image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>
  <div class="login-hero__content">
    <div class="login-hero__card">
      <h1 class="login-hero__title">{{ 'customer.login.title' | t }}</h1>

      {%- form 'customer_login' -%}
        {%- if form.errors -%}
          <div class="form-errors" role="alert">
            <p>{{ form.errors | default_errors }}</p>
          </div>
        {%- endif -%}

        <div class="form-field">
          <label for="customer-email">{{ 'customer.login.email' | t }}</label>
          <input type="email" id="customer-email" name="customer[email]" autocomplete="email" required>
        </div>

        <div class="form-field">
          <label for="customer-password">{{ 'customer.login.password' | t }}</label>
          <div class="form-field__input-wrap">
            <input type="password" id="customer-password" name="customer[password]" autocomplete="current-password" required>
            <button type="button" class="form-field__toggle btn--icon" data-password-toggle aria-label="Show password">
              <span class="icon-eye">{% render 'icon', name: 'eye', size: 18 %}</span>
              <span class="icon-eye-off" style="display:none;">{% render 'icon', name: 'eye-off', size: 18 %}</span>
            </button>
          </div>
        </div>

        <a href="#recover" class="login-hero__forgot">{{ 'customer.login.forgot_password' | t }}</a>

        <button type="submit" class="btn btn--primary btn--full btn--large">
          {{ 'customer.login.sign_in' | t }}
        </button>
      {%- endform -%}

      <div class="login-hero__divider">
        <p class="login-hero__register-text">{{ 'customer.login.new_customer' | t: shop_name: shop.name | escape }}</p>
        <a href="{{ routes.account_register_url }}" class="btn btn--secondary btn--full">
          {{ 'customer.login.create_account' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

{%- comment -%} Password recovery form (hidden by default) {%- endcomment -%}
<div id="recover" style="display:none;">
  <div class="container" style="max-width:500px; padding: var(--space-2xl) var(--space-md);">
    <h2>{{ 'customer.reset_password.title' | t }}</h2>
    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <p role="status">{{ 'customer.reset_password.success' | t }}</p>
      {%- endif -%}
      <div class="form-field">
        <label for="recover-email">{{ 'customer.login.email' | t }}</label>
        <input type="email" id="recover-email" name="email" autocomplete="email" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>

<script>
  if (window.location.hash === '#recover') {
    document.querySelector('.login-hero').style.display = 'none';
    document.getElementById('recover').style.display = 'block';
  }
</script>

{% schema %}
{
  "name": "Login hero",
  "class": "login-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    }
  ],
  "presets": [{"name": "Login hero"}]
}
{% endschema %}

