<sticky-header class="header-wrapper" data-sticky="{{ settings.header_sticky }}" data-transparent-header="{{ section.settings.transparent_hero }}" data-header-hero-style="{{ section.settings.hero_header_style }}" data-template="{{ template.name }}">
  <header class="header" role="banner">
    <div class="header__inner container">
      {%- comment -%} Mobile menu button {%- endcomment -%}
      <button class="header__menu-btn btn--icon desktop-hidden" data-mobile-menu-open aria-label="{{ 'accessibility.open_menu' | t }}" aria-expanded="false">
        {% render 'icon', name: 'menu', size: 22 %}
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      <div class="header__logo">
        <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 200 }}"
              alt="{{ shop.name }}"
              width="200"
              height="{{ 200 | divided_by: section.settings.logo.aspect_ratio | round }}"
              class="header__logo-image"
            >
          {%- else -%}
            <span class="header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} Desktop navigation with mega menu {%- endcomment -%}
      <nav class="header__nav mobile-hidden" role="navigation" aria-label="{{ 'header.menu' | t }}">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="header__nav-item has-mega-menu">
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">
                {{ link.title }}
              </a>
              <div class="mega-menu">
                <div class="mega-menu__inner container">
                  <div class="mega-menu__columns">
                    {%- for child in link.links -%}
                      <div class="mega-menu__column">
                        <span class="mega-menu__heading">{{ child.title }}</span>
                        {%- if child.links.size > 0 -%}
                          {%- for grandchild in child.links -%}
                            <a href="{{ grandchild.url }}" class="mega-menu__link">{{ grandchild.title }}</a>
                          {%- endfor -%}
                          <a href="{{ child.url }}" class="mega-menu__view-all">{{ 'header.view_all_category' | t }}</a>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>

                  {%- comment -%} Featured image from section blocks {%- endcomment -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'mega_menu_image' and block.settings.menu_title == link.title -%}
                      <div class="mega-menu__feature" {{ block.shopify_attributes }}>
                        <a href="{{ block.settings.link }}" class="mega-menu__feature-link">
                          {%- if block.settings.image != blank -%}
                            <img
                              src="{{ block.settings.image | image_url: width: 400 }}"
                              alt="{{ block.settings.heading | escape }}"
                              width="400"
                              height="{{ 400 | divided_by: block.settings.image.aspect_ratio | round }}"
                              loading="lazy"
                              class="mega-menu__feature-img"
                            >
                          {%- endif -%}
                          <span class="mega-menu__feature-title">{{ block.settings.heading }}</span>
                          <span class="mega-menu__feature-cta">{{ 'header.discover_collection' | t }}</span>
                        </a>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%} Icons {%- endcomment -%}
      <div class="header__icons">
        <button class="header__icon btn--icon" data-search-open aria-label="{{ 'header.search' | t }}">
          {% render 'icon', name: 'search', size: 20 %}
        </button>

        <a href="/pages/wishlist" class="header__icon btn--icon mobile-hidden" aria-label="{{ 'header.wishlist' | t }}" data-wishlist-link>
          {% render 'icon', name: 'heart', size: 20 %}
          <span class="header__wishlist-count" data-wishlist-count></span>
        </a>

        <a href="{{ routes.account_url }}" class="header__icon btn--icon mobile-hidden" aria-label="{{ 'header.account' | t }}">
          {% render 'icon', name: 'user', size: 20 %}
        </a>

        <button class="header__icon header__cart-btn btn--icon" data-cart-open aria-label="{{ 'header.cart' | t }}">
          {% render 'icon', name: 'cart', size: 20 %}
          <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </header>
</sticky-header>

{%- comment -%} Mobile menu drawer {%- endcomment -%}
<mobile-menu class="mobile-menu" id="mobile-menu" aria-label="{{ 'header.menu' | t }}">
  <div class="mobile-menu__header">
    <span class="mobile-menu__title">{{ 'header.menu' | t }}</span>
    <button class="btn--icon" data-mobile-menu-close aria-label="{{ 'accessibility.close_menu' | t }}">
      {% render 'icon', name: 'close', size: 20 %}
    </button>
  </div>
  <nav class="mobile-menu__nav" role="navigation">
    {%- for link in section.settings.menu.links -%}
      {%- if link.links.size > 0 -%}
        <div class="mobile-menu__group">
          <div class="mobile-menu__link-row">
            <a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}">
              {{ link.title }}
            </a>
            <button class="mobile-menu__toggle btn--icon" data-submenu-toggle aria-expanded="false" aria-label="{{ link.title }}">
              {% render 'icon', name: 'chevron-down', size: 14 %}
            </button>
          </div>
          <div class="mobile-menu__submenu" data-submenu>
            {%- for child in link.links -%}
              {%- if child.links.size > 0 -%}
                <span class="mobile-menu__sub-heading">{{ child.title }}</span>
                {%- for grandchild in child.links -%}
                  <a href="{{ grandchild.url }}" class="mobile-menu__sub-link">{{ grandchild.title }}</a>
                {%- endfor -%}
                <a href="{{ child.url }}" class="mobile-menu__sub-link mobile-menu__sub-link--viewall">{{ 'header.view_all_category' | t }}</a>
              {%- else -%}
                <a href="{{ child.url }}" class="mobile-menu__sub-link mobile-menu__sub-link--standalone">{{ child.title }}</a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="mobile-menu__link{% if link.active %} is-active{% endif %}">
          {{ link.title }}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </nav>
  <div class="mobile-menu__footer">
    <a href="{{ routes.account_url }}" class="mobile-menu__link">
      {% render 'icon', name: 'user', size: 18 %}
      {{ 'header.account' | t }}
    </a>
    <a href="/pages/wishlist" class="mobile-menu__link">
      {% render 'icon', name: 'heart', size: 18 %}
      {{ 'header.wishlist' | t }}
    </a>
  </div>
</mobile-menu>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Transparent header"
    },
    {
      "type": "checkbox",
      "id": "transparent_hero",
      "label": "Enable transparent header on homepage hero",
      "default": true
    },
    {
      "type": "select",
      "id": "hero_header_style",
      "label": "Header style on hero",
      "options": [
        { "value": "light", "label": "Light (white text/icons)" },
        { "value": "dark", "label": "Dark (dark text/icons)" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_image",
      "name": "Mega menu image",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menu item title",
          "info": "Must match the nav link title exactly (e.g. VÊTEMENTS FEMME)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Featured image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Nouveautés"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
