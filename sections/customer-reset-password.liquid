<section class="section">
  <div class="container" style="max-width: 500px;">
    <h1 style="text-align: center; margin-bottom: var(--space-xl);">{{ 'customer.reset_password.title' | t }}</h1>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="form-errors" role="alert">
          <p>{{ form.errors | default_errors }}</p>
        </div>
      {%- endif -%}

      <div class="form-field">
        <label for="reset-password">{{ 'customer.login.password' | t }}</label>
        <input type="password" id="reset-password" name="customer[password]" autocomplete="new-password" required>
      </div>

      <div class="form-field">
        <label for="reset-password-confirm">Confirm password</label>
        <input type="password" id="reset-password-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--large">
        {{ 'customer.reset_password.submit' | t }}
      </button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "class": "reset-password-section",
  "settings": []
}
{% endschema %}
