<product-gallery class="product-gallery-wrapper">
  <div class="product-gallery">
    {%- comment -%} Thumbnails {%- endcomment -%}
    <div class="product-gallery__thumbs" role="list">
      {%- for media in product.media -%}
        <button
          class="product-gallery__thumb{% if forloop.first %} active{% endif %}"
          data-thumb="{{ forloop.index0 }}"
          data-full-src="{{ media | image_url: width: 1200 }}"
          role="listitem"
          aria-label="{{ 'accessibility.slide_number' | t: number: forloop.index, total: product.media.size }}"
        >
          <img
            src="{{ media | image_url: width: 120 }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="60"
            height="80"
            loading="lazy"
          >
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} Main image {%- endcomment -%}
    <div class="product-gallery__main">
      {%- if product.featured_media -%}
        <img
          data-main-image
          src="{{ product.featured_media | image_url: width: 1200 }}"
          alt="{{ product.featured_media.alt | escape | default: product.title }}"
          width="1200"
          height="{{ 1200 | divided_by: product.featured_media.aspect_ratio | round }}"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}

      {%- if product.media.size > 1 -%}
        <button class="product-gallery__nav product-gallery__nav--prev" data-gallery-prev aria-label="{{ 'accessibility.previous_slide' | t }}">
          {% render 'icon', name: 'chevron-left', size: 18 %}
        </button>
        <button class="product-gallery__nav product-gallery__nav--next" data-gallery-next aria-label="{{ 'accessibility.next_slide' | t }}">
          {% render 'icon', name: 'chevron-right', size: 18 %}
        </button>
      {%- endif -%}
    </div>
  </div>
</product-gallery>

{% schema %}
{
  "name": "Product gallery",
  "class": "product-gallery-section",
  "settings": []
}
{% endschema %}
