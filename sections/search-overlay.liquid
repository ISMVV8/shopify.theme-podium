<search-overlay class="search-overlay" id="search-overlay" role="dialog" aria-label="{{ 'search.title' | t }}">
  <div class="search-overlay__backdrop" data-search-close></div>
  <div class="search-overlay__panel">
    {%- comment -%} Close button {%- endcomment -%}
    <button type="button" class="search-overlay__close" data-search-close aria-label="{{ 'accessibility.close_search' | t }}">
      {% render 'icon', name: 'close', size: 22 %}
    </button>

    {%- comment -%} Title {%- endcomment -%}
    <p class="search-overlay__title">Rechercher</p>

    {%- comment -%} Search form {%- endcomment -%}
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-overlay__form">
      <div class="search-overlay__input-wrap">
        <span class="search-overlay__search-icon" aria-hidden="true">
          {% render 'icon', name: 'search', size: 18 %}
        </span>
        <input
          type="search"
          name="q"
          class="search-overlay__input"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          aria-label="{{ 'search.placeholder' | t }}"
        >
        <input type="hidden" name="type" value="product">
      </div>
    </form>

    {%- comment -%} Popular searches {%- endcomment -%}
    <div class="search-overlay__frequent">
      <p class="search-overlay__frequent-label">Recherches populaires</p>
      <div class="search-overlay__pills">
        {%- for block in section.blocks -%}
          {%- if block.type == 'quick_link' -%}
            <a href="{{ block.settings.link }}" class="search-overlay__pill" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          <a href="{{ routes.search_url }}?q=robes&type=product" class="search-overlay__pill">Robes</a>
          <a href="{{ routes.search_url }}?q=chemisiers&type=product" class="search-overlay__pill">Chemisiers & Blouses</a>
          <a href="{{ routes.search_url }}?q=pulls+gilets&type=product" class="search-overlay__pill">Pulls & Gilets</a>
          <a href="{{ routes.search_url }}?q=vestes+manteaux&type=product" class="search-overlay__pill">Vestes & Manteaux</a>
          <a href="{{ routes.search_url }}?q=tops+t-shirts&type=product" class="search-overlay__pill">Tops & T-shirts</a>
          <a href="{{ routes.search_url }}?q=accessoires&type=product" class="search-overlay__pill">Accessoires</a>
          <a href="{{ routes.search_url }}?q=pantalons&type=product" class="search-overlay__pill">Pantalons</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</search-overlay>

{% schema %}
{
  "name": "Search overlay",
  "class": "search-overlay-section",
  "settings": [],
  "blocks": [
    {
      "type": "quick_link",
      "name": "Quick search link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Robes"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}
