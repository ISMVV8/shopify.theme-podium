<section class="nl--{{ section.id }}">
  <div class="nl-inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="nl-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="nl-subtitle">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'nl-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="nl-msg nl-msg--ok" role="status">Merci pour votre inscription !</p>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="nl-msg nl-msg--err" role="alert">
          {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
        </p>
      {%- endif -%}

      <div class="nl-field">
        <input
          type="email"
          name="contact[email]"
          class="nl-input"
          placeholder="Votre e-mail"
          required
          autocomplete="email"
          aria-label="Votre e-mail"
          {% if form.posted_successfully? %}value=""{% endif %}
        >
        <button type="submit" class="nl-arrow" aria-label="S'inscrire">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    {%- endform -%}

    {%- if section.settings.consent_text != blank -%}
      <p class="nl-consent">
        {{ section.settings.consent_text }}
        {%- if section.settings.policy_link != blank -%}
          <a href="{{ section.settings.policy_link }}" class="nl-consent__link">politique de confidentialité</a>.
        {%- endif -%}
      </p>
    {%- endif -%}

  </div>
</section>

<style>
  .nl--{{ section.id }} {
    padding: 40px 20px 44px;
    text-align: center;
  }

  .nl-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .nl-heading {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
    color: var(--color-text);
  }

  .nl-subtitle {
    font-size: 0.85rem;
    color: #888;
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .nl-form {
    margin: 0 auto;
    max-width: 380px;
  }

  .nl-field {
    display: flex;
    align-items: center;
    border: 1px solid #d0cdc8;
    border-radius: 24px;
    overflow: hidden;
    background: #fff;
    height: 44px;
  }

  .nl-input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 0 0 0 18px;
    font-size: 0.85rem;
    color: var(--color-text);
    outline: none;
    font-family: inherit;
    height: 100%;
  }

  .nl-input::placeholder {
    color: #aaa;
  }

  .nl-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 100%;
    border: none;
    background: none;
    cursor: pointer;
    color: #999;
    padding: 0;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .nl-arrow:hover {
    color: var(--color-text);
  }

  .nl-msg {
    font-size: 0.8rem;
    margin: 0 0 12px;
  }

  .nl-msg--ok {
    color: #2a7d4f;
  }

  .nl-msg--err {
    color: #c44;
  }

  .nl-consent {
    font-size: 0.72rem;
    color: #999;
    line-height: 1.6;
    margin: 14px auto 0;
    max-width: 480px;
  }

  .nl-consent__link {
    color: #666;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .nl-consent__link:hover {
    color: var(--color-text);
  }

  @media (max-width: 767px) {
    .nl--{{ section.id }} {
      padding: 32px 16px 36px;
    }
    .nl-heading {
      font-size: 1.25rem;
    }
    .nl-form {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "class": "newsletter-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Inscrivez-vous à notre newsletter"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Subtitle",
      "default": "Ne ratez pas nos nouvelles collections, actualités et promotions..."
    },
    {
      "type": "textarea",
      "id": "consent_text",
      "label": "Consent text",
      "default": "En vous inscrivant, vous acceptez de recevoir nos emails. Vous pouvez vous désinscrire à tout moment. En savoir plus dans notre"
    },
    {
      "type": "url",
      "id": "policy_link",
      "label": "Privacy policy link"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
