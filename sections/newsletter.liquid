<section class="newsletter-section section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter-section__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="newsletter-section__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter__form', data-newsletter-form: '' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="newsletter__error" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
      {%- endif -%}
      <div class="newsletter__input-wrap">
        <input
          type="email"
          name="contact[email]"
          class="newsletter__input"
          placeholder="{{ 'newsletter.email_placeholder' | t }}"
          required
          autocomplete="email"
          aria-label="{{ 'newsletter.email_placeholder' | t }}"
          {% if form.posted_successfully? %}value=""{% endif %}
        >
        <button type="submit" class="newsletter__submit btn--icon" aria-label="{{ 'newsletter.submit' | t }}">
          {% render 'icon', name: 'arrow-right', size: 20 %}
        </button>
      </div>
    {%- endform -%}

    {%- if section.settings.consent_text != blank -%}
      <p class="newsletter__consent">
        {{ section.settings.consent_text }}
        {%- if section.settings.policy_link != blank -%}
          <a href="{{ section.settings.policy_link }}">{{ 'footer.privacy_policy' | t }}</a>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "class": "newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Restons en contact"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Inscrivez-vous à notre newsletter pour recevoir nos dernières actualités et offres exclusives."
    },
    {
      "type": "text",
      "id": "consent_text",
      "label": "Consent text",
      "default": "En vous inscrivant, vous acceptez notre"
    },
    {
      "type": "url",
      "id": "policy_link",
      "label": "Privacy policy link"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
