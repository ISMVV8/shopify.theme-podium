{%- comment -%}
  "Complétez le look" — cross-sell section
  Scoped class prefix: pcs-
{%- endcomment -%}

{%- liquid
  assign has_products = false
  for block in section.blocks
    if block.type == 'product' and block.settings.product != blank
      assign has_products = true
      break
    endif
  endfor
  if section.settings.use_metafield and product.metafields.custom.cross_sell_products.value
    assign has_products = true
  endif
-%}

{%- if has_products -%}
  <section class="pcs-section">
    <div class="pcs-container">
      <h2 class="pcs-title">{{ section.settings.heading | default: 'Complétez le look' }}</h2>
      <div class="pcs-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            {% render 'product-card', product: block.settings.product %}
          {%- endif -%}
        {%- endfor -%}

        {%- if section.settings.use_metafield and product.metafields.custom.cross_sell_products.value -%}
          {%- for cross_product in product.metafields.custom.cross_sell_products.value -%}
            {% render 'product-card', product: cross_product %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

<style>
.pcs-section {
  padding: 48px 0 56px;
  border-top: 1px solid #eae8e4;
}

.pcs-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

.pcs-title {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  margin: 0 0 28px;
  color: var(--color-text);
  text-align: center;
}

.pcs-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

@media (max-width: 1023px) {
  .pcs-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 767px) {
  .pcs-section { padding: 36px 0 44px; }
  .pcs-container { padding: 0 16px; }
  .pcs-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .pcs-title {
    font-size: 1.2rem;
    margin-bottom: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Cross-sell",
  "class": "cross-sell-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complétez le look"
    },
    {
      "type": "checkbox",
      "id": "use_metafield",
      "label": "Use product metafield (custom.cross_sell_products)",
      "default": false,
      "info": "If enabled, uses the product metafield for cross-sell items."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [{"name": "Cross-sell"}]
}
{% endschema %}
