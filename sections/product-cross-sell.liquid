{%- if section.blocks.size > 0 or section.settings.use_metafield -%}
  <section class="cross-sell-section section">
    <div class="container">
      <h2 class="cross-sell-section__title">{{ section.settings.heading | default: 'Complétez le look' }}</h2>
      <div class="cross-sell-grid">
        {%- comment -%} Manual product selection via blocks {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            {% render 'product-card', product: block.settings.product %}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Metafield-based selection {%- endcomment -%}
        {%- if section.settings.use_metafield and product.metafields.custom.cross_sell_products.value -%}
          {%- for cross_product in product.metafields.custom.cross_sell_products.value -%}
            {% render 'product-card', product: cross_product %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Cross-sell",
  "class": "cross-sell-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complétez le look"
    },
    {
      "type": "checkbox",
      "id": "use_metafield",
      "label": "Use product metafield (custom.cross_sell_products)",
      "default": false,
      "info": "If enabled, uses the product metafield for cross-sell items."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [{"name": "Cross-sell"}]
}
{% endschema %}
