{%- comment -%}
  Collection Grid — LV luxury style
  Clean toolbar with inline sort/filter, elegant product grid
{%- endcomment -%}

<section class="coll-section">
  <div class="container">

    {%- comment -%} Toolbar {%- endcomment -%}
    <div class="coll-toolbar">
      <div class="coll-toolbar__left">
        <p class="coll-toolbar__count">
          {{ 'collection.results_count' | t: count: collection.products_count }}
        </p>
      </div>
      <div class="coll-toolbar__right">
        <button class="coll-toolbar__btn" data-filter-open>
          {% render 'icon', name: 'filter', size: 14 %}
          <span>{{ 'collection.filter' | t }}</span>
          {%- assign active_count = 0 -%}
          {%- for filter in collection.filters -%}
            {%- assign active_count = active_count | plus: filter.active_values.size -%}
          {%- endfor -%}
          {%- if active_count > 0 -%}
            <span class="coll-toolbar__badge">{{ active_count }}</span>
          {%- endif -%}
        </button>
        <div class="coll-sort" data-sort-dropdown>
          <button class="coll-toolbar__btn" type="button" data-sort-toggle aria-expanded="false">
            {% render 'icon', name: 'sort', size: 14 %}
            <span>{{ 'collection.sort' | t }}</span>
          </button>
          <div class="coll-sort__dropdown">
            {%- for option in collection.sort_options -%}
              <button
                type="button"
                class="coll-sort__option{% if collection.sort_by == option.value or option.value == collection.default_sort_by and collection.sort_by == blank %} is-active{% endif %}"
                data-sort-value="{{ option.value }}"
              >
                {{ option.name }}
              </button>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} Active filter pills {%- endcomment -%}
    {%- assign has_active_filters = false -%}
    {%- for filter in collection.filters -%}
      {%- if filter.active_values.size > 0 -%}
        {%- assign has_active_filters = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_active_filters -%}
      <div class="coll-filters-active">
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a href="{{ value.url_to_remove }}" class="coll-filters-active__pill">
              {{ value.label }}
              {% render 'icon', name: 'close', size: 10 %}
            </a>
          {%- endfor -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="coll-filters-active__clear">
          {{ 'collection.clear_filters' | t }}
        </a>
      </div>
    {%- endif -%}

    {%- comment -%} Product grid {%- endcomment -%}
    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="coll-grid" style="--coll-columns: {{ section.settings.columns }};">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- else -%}
          <div class="coll-grid__empty">
            <p>{{ 'collection.no_products' | t | default: 'Aucun produit trouvé.' }}</p>
            {%- if has_active_filters -%}
              <a href="{{ collection.url }}" class="btn btn--secondary">
                {{ 'collection.clear_filters' | t }}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection grid",
  "class": "collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [{"name": "Collection grid"}]
}
{% endschema %}
