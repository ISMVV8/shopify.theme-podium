{%- comment -%}
  Size Guide page – Louis Vuitton inspired, elegant tables and how-to-measure section.
  Categories (Robes, Hauts, Pantalons…) as blocks with their own size charts.
{%- endcomment -%}

<section class="sg-page">
  {%- comment -%} Hero {%- endcomment -%}
  <div class="sg-page__hero">
    <h1 class="sg-page__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="sg-page__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="sg-page__body container">
    {%- comment -%} How to measure {%- endcomment -%}
    <div class="sg-page__measure">
      <h2 class="sg-page__section-title">Comment prendre vos mesures</h2>
      <div class="sg-page__measure-grid">
        <div class="sg-page__measure-item">
          <div class="sg-page__measure-num">1</div>
          <h3 class="sg-page__measure-name">Tour de poitrine</h3>
          <p class="sg-page__measure-desc">Mesurez horizontalement autour de la partie la plus forte de votre poitrine, en passant sous les bras.</p>
        </div>
        <div class="sg-page__measure-item">
          <div class="sg-page__measure-num">2</div>
          <h3 class="sg-page__measure-name">Tour de taille</h3>
          <p class="sg-page__measure-desc">Mesurez autour de la partie la plus étroite de votre taille, généralement au niveau du nombril.</p>
        </div>
        <div class="sg-page__measure-item">
          <div class="sg-page__measure-num">3</div>
          <h3 class="sg-page__measure-name">Tour de hanches</h3>
          <p class="sg-page__measure-desc">Mesurez autour de la partie la plus large de vos hanches, en gardant le mètre bien horizontal.</p>
        </div>
        <div class="sg-page__measure-item">
          <div class="sg-page__measure-num">4</div>
          <h3 class="sg-page__measure-name">Longueur</h3>
          <p class="sg-page__measure-desc">Mesurez du point le plus haut de l'épaule jusqu'à l'ourlet souhaité.</p>
        </div>
      </div>
    </div>

    {%- comment -%} Size charts from blocks {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'size_chart' -%}
        <div class="sg-page__chart" {{ block.shopify_attributes }}>
          <h2 class="sg-page__chart-title">{{ block.settings.title }}</h2>
          {%- if block.settings.description != blank -%}
            <p class="sg-page__chart-desc">{{ block.settings.description }}</p>
          {%- endif -%}
          <div class="sg-page__table-wrap">
            <table class="sg-page__table">
              <thead>
                <tr>
                  <th>Taille</th>
                  <th>{{ block.settings.col1_label | default: 'Poitrine (cm)' }}</th>
                  <th>{{ block.settings.col2_label | default: 'Taille (cm)' }}</th>
                  <th>{{ block.settings.col3_label | default: 'Hanches (cm)' }}</th>
                  {%- if block.settings.col4_label != blank -%}
                    <th>{{ block.settings.col4_label }}</th>
                  {%- endif -%}
                </tr>
              </thead>
              <tbody>
                {%- if block.settings.row_xs != blank -%}
                  <tr>
                    <td>XS</td>
                    {%- assign cols = block.settings.row_xs | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
                {%- if block.settings.row_s != blank -%}
                  <tr>
                    <td>S</td>
                    {%- assign cols = block.settings.row_s | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
                {%- if block.settings.row_m != blank -%}
                  <tr>
                    <td>M</td>
                    {%- assign cols = block.settings.row_m | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
                {%- if block.settings.row_l != blank -%}
                  <tr>
                    <td>L</td>
                    {%- assign cols = block.settings.row_l | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
                {%- if block.settings.row_xl != blank -%}
                  <tr>
                    <td>XL</td>
                    {%- assign cols = block.settings.row_xl | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
                {%- if block.settings.row_xxl != blank -%}
                  <tr>
                    <td>XXL</td>
                    {%- assign cols = block.settings.row_xxl | split: '|' -%}
                    {%- for col in cols -%}<td>{{ col | strip }}</td>{%- endfor -%}
                  </tr>
                {%- endif -%}
              </tbody>
            </table>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Tips {%- endcomment -%}
    {%- if section.settings.tips != blank -%}
      <div class="sg-page__tips">
        <h2 class="sg-page__section-title">Nos conseils</h2>
        <div class="sg-page__tips-content">
          {{ section.settings.tips }}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Bottom {%- endcomment -%}
  {%- if section.settings.bottom_text != blank -%}
    <div class="sg-page__bottom container">
      <p class="sg-page__bottom-text">{{ section.settings.bottom_text }}</p>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Guide des tailles",
  "class": "sg-page-section",
  "settings": [
