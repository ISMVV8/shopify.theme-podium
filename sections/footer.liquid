{%- comment -%}
  Footer – Louis Vuitton inspired.
  Dark background, refined typography, newsletter, 3-column links, social, legal bar.
{%- endcomment -%}

<footer class="footer" role="contentinfo">

  {%- comment -%} ── Newsletter band ── {%- endcomment -%}
  {%- if section.settings.show_newsletter -%}
    <div class="footer__newsletter">
      <div class="container footer__newsletter-inner">
        <div class="footer__newsletter-text">
          <h3 class="footer__newsletter-heading">{{ section.settings.newsletter_heading | default: 'Restez informé(e)' }}</h3>
          <p class="footer__newsletter-sub">{{ section.settings.newsletter_subtext | default: 'Inscrivez-vous pour recevoir nos dernières nouveautés et offres exclusives.' }}</p>
        </div>
        {%- form 'customer', class: 'footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-field">
            <input
              type="email"
              name="contact[email]"
              class="footer__newsletter-input"
              placeholder="Votre adresse e-mail"
              required
              autocomplete="email"
              aria-label="E-mail"
            >
            <button type="submit" class="footer__newsletter-btn" aria-label="S'inscrire">
              {% render 'icon', name: 'arrow-right', size: 18 %}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="footer__newsletter-success">Merci pour votre inscription !</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Main footer columns ── {%- endcomment -%}
  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        {%- comment -%} Column 1 {%- endcomment -%}
        <div class="footer__col">
          <h4 class="footer__heading">{{ section.settings.col1_title | default: 'Services' }}</h4>
          {%- if section.settings.menu_1 != blank -%}
            {%- for link in section.settings.menu_1.links -%}
              <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <a href="#" class="footer__link">Livraison & Retours</a>
            <a href="#" class="footer__link">FAQ</a>
            <a href="#" class="footer__link">Guide des tailles</a>
            <a href="#" class="footer__link">Suivi de commande</a>
          {%- endif -%}
        </div>

        {%- comment -%} Column 2 – Brand center {%- endcomment -%}
        <div class="footer__col footer__col--brand">
          <div class="footer__brand-name">{{ shop.name }}</div>

          {%- assign has_social = false -%}
          {%- if settings.social_facebook != blank or settings.social_instagram != blank or settings.social_pinterest != blank or settings.social_tiktok != blank or settings.social_whatsapp != blank or settings.social_twitter != blank or settings.social_youtube != blank or settings.social_snapchat != blank -%}
            {%- assign has_social = true -%}
          {%- endif -%}

          {%- if has_social -%}
            <div class="footer__social">
              {%- if settings.social_instagram != blank -%}
                <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                  {% render 'icon', name: 'instagram', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_facebook != blank -%}
                <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                  {% render 'icon', name: 'facebook', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok != blank -%}
                <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
                  {% render 'icon', name: 'tiktok', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_pinterest != blank -%}
                <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
                  {% render 'icon', name: 'pinterest', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_whatsapp != blank -%}
                <a href="{{ settings.social_whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp">
                  {% render 'icon', name: 'whatsapp', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_twitter != blank -%}
                <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X (Twitter)">
                  {% render 'icon', name: 'twitter', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_youtube != blank -%}
                <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
                  {% render 'icon', name: 'youtube', size: 18 %}
                </a>
              {%- endif -%}
              {%- if settings.social_snapchat != blank -%}
                <a href="{{ settings.social_snapchat }}" target="_blank" rel="noopener" aria-label="Snapchat">
                  {% render 'icon', name: 'snapchat', size: 18 %}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Column 3 {%- endcomment -%}
        <div class="footer__col">
          <h4 class="footer__heading">{{ section.settings.col3_title | default: shop.name }}</h4>
          {%- if section.settings.menu_2 != blank -%}
            {%- for link in section.settings.menu_2.links -%}
              <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <a href="#" class="footer__link">À propos</a>
            <a href="#" class="footer__link">Nos boutiques</a>
            <a href="#" class="footer__link">Nous contacter</a>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>

  {%- comment -%} ── Bottom bar ── {%- endcomment -%}
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} — {{ 'footer.rights' | t | default: 'Tous droits réservés' }}
      </div>
      <div class="footer__legal">
        <a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">Politique de confidentialité</a>
        <span class="footer__legal-sep">&middot;</span>
        <a href="{{ section.settings.terms_url | default: '/policies/terms-of-service' }}">CGV</a>
        <span class="footer__legal-sep">&middot;</span>
        <a href="{{ section.settings.legal_url | default: '#' }}">Mentions légales</a>
      </div>
      <div class="footer__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag }}
        {%- endfor -%}
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Afficher la newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Titre newsletter",
      "default": "Restez informé(e)"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Sous-texte newsletter",
      "default": "Inscrivez-vous pour recevoir nos dernières nouveautés et offres exclusives."
    },
    {
      "type": "header",
      "content": "Colonnes"
    },
    {
      "type": "text",
      "id": "col1_title",
      "label": "Titre colonne gauche",
      "default": "Services"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu colonne gauche",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Titre colonne droite",
      "default": "La Maison"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu colonne droite"
    },
    {
      "type": "header",
      "content": "Mentions légales"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "URL politique de confidentialité"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "URL conditions générales"
    },
    {
      "type": "url",
      "id": "legal_url",
      "label": "URL mentions légales"
    }
  ]
}
{% endschema %}
