{%- liquid
  assign max_right = section.settings.max_products_right | default: 4
  assign cta_label = section.settings.cta_label | default: 'VOIR PLUS'
-%}

<featured-products class="featured-products" data-section-id="{{ section.id }}">
  <div class="container">

    {%- comment -%} ── HEADER ROW ── {%- endcomment -%}
    <div class="fp-header">
      <h2 class="fp-header__title">{{ section.settings.heading | default: 'La sélection' }}</h2>
      <div class="fp-header__pills" role="tablist">
        {%- if section.settings.pill_1_label != blank -%}
          <button class="fp-pill is-active" data-pill="0" role="tab" aria-selected="true" aria-pressed="true" type="button">
            {{ section.settings.pill_1_label }}
          </button>
        {%- endif -%}
        {%- if section.settings.pill_2_label != blank -%}
          <button class="fp-pill" data-pill="1" role="tab" aria-selected="false" aria-pressed="false" type="button">
            {{ section.settings.pill_2_label }}
          </button>
        {%- endif -%}
        {%- if section.settings.pill_3_label != blank -%}
          <button class="fp-pill" data-pill="2" role="tab" aria-selected="false" aria-pressed="false" type="button">
            {{ section.settings.pill_3_label }}
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── TAB PANELS ── {%- endcomment -%}
    <div class="fp-panels">

      {%- comment -%} ── PANEL 0 ── {%- endcomment -%}
      {%- assign col = section.settings.pill_1_collection -%}
      {%- assign pill_label = section.settings.pill_1_label | default: 'Back in stock' -%}
      <div class="fp-panel is-active" data-panel="0" role="tabpanel">
        <div class="fp-row">
          {%- comment -%} LEFT: featured card {%- endcomment -%}
          <div class="fp-featured">
            <a href="{{ col.url | default: '#' }}" class="fp-featured__link">
              <div class="fp-featured__img-wrap">
                {%- if col != blank and col.featured_image -%}
                  <img src="{{ col.featured_image | image_url: width: 800 }}" alt="{{ col.title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col.featured_image.aspect_ratio | round }}">
                {%- elsif col != blank and col.products.size > 0 and col.products[0].featured_media -%}
                  <img src="{{ col.products[0].featured_media | image_url: width: 800 }}" alt="{{ col.products[0].title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col.products[0].featured_media.aspect_ratio | round }}">
                {%- else -%}
                  <div class="fp-featured__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'fp-featured__placeholder-svg' }}
                  </div>
                {%- endif -%}
                {%- if section.settings.show_featured_label -%}
                  <span class="fp-featured__label">{{ pill_label }}</span>
                {%- endif -%}
                <span class="fp-featured__cta">{{ cta_label }}</span>
              </div>
            </a>
          </div>

          {%- comment -%} RIGHT: 4 product cards {%- endcomment -%}
          <div class="fp-grid">
            {%- if col != blank and col.products.size > 0 -%}
              {%- for product in col.products limit: max_right -%}
                {% render 'product-card', product: product, show_wishlist: false %}
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..4) -%}
                <article class="product-card">
                  <div class="product-card__image-wrap">
                    {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
                  </div>
                  <div class="product-card__info">
                    <h3 class="product-card__title">Product title</h3>
                    <p class="product-card__subtitle">Color</p>
                    <div class="product-card__price">€29,99</div>
                  </div>
                </article>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} ── PANEL 1 ── {%- endcomment -%}
      {%- if section.settings.pill_2_label != blank -%}
        {%- assign col2 = section.settings.pill_2_collection -%}
        {%- assign pill_label2 = section.settings.pill_2_label -%}
        <div class="fp-panel" data-panel="1" role="tabpanel">
          <div class="fp-row">
            <div class="fp-featured">
              <a href="{{ col2.url | default: '#' }}" class="fp-featured__link">
                <div class="fp-featured__img-wrap">
                  {%- if col2 != blank and col2.featured_image -%}
                    <img src="{{ col2.featured_image | image_url: width: 800 }}" alt="{{ col2.title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col2.featured_image.aspect_ratio | round }}">
                  {%- elsif col2 != blank and col2.products.size > 0 and col2.products[0].featured_media -%}
                    <img src="{{ col2.products[0].featured_media | image_url: width: 800 }}" alt="{{ col2.products[0].title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col2.products[0].featured_media.aspect_ratio | round }}">
                  {%- else -%}
                    <div class="fp-featured__placeholder">
                      {{ 'collection-2' | placeholder_svg_tag: 'fp-featured__placeholder-svg' }}
                    </div>
                  {%- endif -%}
                  {%- if section.settings.show_featured_label -%}
                    <span class="fp-featured__label">{{ pill_label2 }}</span>
                  {%- endif -%}
                  <span class="fp-featured__cta">{{ cta_label }}</span>
                </div>
              </a>
            </div>
            <div class="fp-grid">
              {%- if col2 != blank and col2.products.size > 0 -%}
                {%- for product in col2.products limit: max_right -%}
                  {% render 'product-card', product: product, show_wishlist: false %}
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..4) -%}
                  <article class="product-card">
                    <div class="product-card__image-wrap">
                      {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
                    </div>
                    <div class="product-card__info">
                      <h3 class="product-card__title">Product title</h3>
                      <p class="product-card__subtitle">Color</p>
                      <div class="product-card__price">€29,99</div>
                    </div>
                  </article>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ── PANEL 2 ── {%- endcomment -%}
      {%- if section.settings.pill_3_label != blank -%}
        {%- assign col3 = section.settings.pill_3_collection -%}
        {%- assign pill_label3 = section.settings.pill_3_label -%}
        <div class="fp-panel" data-panel="2" role="tabpanel">
          <div class="fp-row">
            <div class="fp-featured">
              <a href="{{ col3.url | default: '#' }}" class="fp-featured__link">
                <div class="fp-featured__img-wrap">
                  {%- if col3 != blank and col3.featured_image -%}
                    <img src="{{ col3.featured_image | image_url: width: 800 }}" alt="{{ col3.title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col3.featured_image.aspect_ratio | round }}">
                  {%- elsif col3 != blank and col3.products.size > 0 and col3.products[0].featured_media -%}
                    <img src="{{ col3.products[0].featured_media | image_url: width: 800 }}" alt="{{ col3.products[0].title | escape }}" class="fp-featured__img" loading="lazy" width="800" height="{{ 800 | divided_by: col3.products[0].featured_media.aspect_ratio | round }}">
                  {%- else -%}
                    <div class="fp-featured__placeholder">
                      {{ 'collection-3' | placeholder_svg_tag: 'fp-featured__placeholder-svg' }}
                    </div>
                  {%- endif -%}
                  {%- if section.settings.show_featured_label -%}
                    <span class="fp-featured__label">{{ pill_label3 }}</span>
                  {%- endif -%}
                  <span class="fp-featured__cta">{{ cta_label }}</span>
                </div>
              </a>
            </div>
            <div class="fp-grid">
              {%- if col3 != blank and col3.products.size > 0 -%}
                {%- for product in col3.products limit: max_right -%}
                  {% render 'product-card', product: product, show_wishlist: false %}
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..4) -%}
                  <article class="product-card">
                    <div class="product-card__image-wrap">
                      {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
                    </div>
                    <div class="product-card__info">
                      <h3 class="product-card__title">Product title</h3>
                      <p class="product-card__subtitle">Color</p>
                      <div class="product-card__price">€29,99</div>
                    </div>
                  </article>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</featured-products>

{% schema %}
{
  "name": "Featured products",
  "class": "featured-products-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "La sélection"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Featured CTA label",
      "default": "VOIR PLUS"
    },
    {
      "type": "checkbox",
      "id": "show_featured_label",
      "label": "Show overlay label on featured card",
      "default": true
    },
    {
      "type": "range",
      "id": "max_products_right",
      "label": "Products on right grid",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Pill 1"
    },
    {
      "type": "text",
      "id": "pill_1_label",
      "label": "Pill 1 label",
      "default": "Back in stock"
    },
    {
      "type": "collection",
      "id": "pill_1_collection",
      "label": "Pill 1 collection"
    },
    {
      "type": "header",
      "content": "Pill 2"
    },
    {
      "type": "text",
      "id": "pill_2_label",
      "label": "Pill 2 label",
      "default": "Nouveautés"
    },
    {
      "type": "collection",
      "id": "pill_2_collection",
      "label": "Pill 2 collection"
    },
    {
      "type": "header",
      "content": "Pill 3"
    },
    {
      "type": "text",
      "id": "pill_3_label",
      "label": "Pill 3 label",
      "default": "Les incontournables"
    },
    {
      "type": "collection",
      "id": "pill_3_collection",
      "label": "Pill 3 collection"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
