{%- comment -%}
  FAQ page section – Louis Vuitton inspired accordion design.
  Each question is a configurable block with title + answer.
  Questions can be grouped by category.
{%- endcomment -%}

<section class="faq-page">
  {%- comment -%} Hero {%- endcomment -%}
  <div class="faq-page__hero">
    <h1 class="faq-page__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="faq-page__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="faq-page__body container">
    {%- comment -%} Group questions by category {%- endcomment -%}
    {%- assign current_category = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- if current_category != '' -%}
          </div>{%- comment -%} close previous group {%- endcomment -%}
        {%- endif -%}
        {%- assign current_category = block.settings.title -%}
        <div class="faq-page__group" {{ block.shopify_attributes }}>
          <h2 class="faq-page__group-title">{{ block.settings.title }}</h2>

      {%- elsif block.type == 'question' -%}
        {%- if current_category == '' -%}
          {%- assign current_category = 'default' -%}
          <div class="faq-page__group">
        {%- endif -%}

        <details class="faq-page__item" {{ block.shopify_attributes }}>
          <summary class="faq-page__question">
            <span class="faq-page__question-text">{{ block.settings.question }}</span>
            <span class="faq-page__question-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
            </span>
          </summary>
          <div class="faq-page__answer">
            <div class="faq-page__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      {%- endif -%}
    {%- endfor -%}

    {%- if current_category != '' -%}
      </div>{%- comment -%} close last group {%- endcomment -%}
    {%- endif -%}
  </div>

  {%- comment -%} Bottom contact {%- endcomment -%}
  {%- if section.settings.contact_text != blank -%}
    <div class="faq-page__contact container">
      <div class="faq-page__contact-inner">
        <p class="faq-page__contact-text">{{ section.settings.contact_text }}</p>
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}" class="faq-page__contact-btn">
            {{ section.settings.contact_btn_text | default: 'Nous écrire' }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.faq-page__item').forEach(function(item) {
      item.addEventListener('toggle', function() {
        if (this.open) {
          document.querySelectorAll('.faq-page__item[open]').forEach(function(other) {
            if (other !== item) other.removeAttribute('open');
          });
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ",
  "class": "faq-page-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Questions fréquentes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Retrouvez les réponses à vos questions les plus courantes"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Texte de contact",
      "default": "Vous ne trouvez pas la réponse à votre question ?"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email de contact"
    },
    {
      "type": "text",
      "id": "contact_btn_text",
      "label": "Texte du bouton contact",
      "default": "Nous écrire"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre de la catégorie",
          "default": "Commandes & Livraison"
        }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Quels sont les délais de livraison ?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Réponse",
          "default": "<p>Nos délais de livraison sont de 2 à 5 jours ouvrés pour la France métropolitaine et de 5 à 10 jours ouvrés pour les livraisons internationales.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "category", "settings": { "title": "Commandes & Livraison" } },
        { "type": "question", "settings": { "question": "Quels sont les délais de livraison ?", "answer": "<p>Nos délais de livraison sont de 2 à 5 jours ouvrés pour la France métropolitaine et de 5 à 10 jours ouvrés pour les livraisons internationales.</p>" } },
        { "type": "question", "settings": { "question": "Comment suivre ma commande ?", "answer": "<p>Dès l'expédition de votre commande, un email de confirmation vous est envoyé avec un numéro de suivi. Vous pouvez suivre votre colis directement depuis le lien fourni.</p>" } },
        { "type": "question", "settings": { "question": "Quels sont les frais de livraison ?", "answer": "<p>La livraison est offerte à partir de 100€ d'achat. En dessous, les frais de livraison sont de 4,99€ en France métropolitaine.</p>" } },
        { "type": "category", "settings": { "title": "Retours & Échanges" } },
        { "type": "question", "settings": { "question": "Quel est le délai pour retourner un article ?", "answer": "<p>Vous disposez de 14 jours à compter de la réception de votre commande pour effectuer un retour. L'article doit être dans son état d'origine, non porté et avec ses étiquettes.</p>" } },
        { "type": "question", "settings": { "question": "Comment effectuer un retour ?", "answer": "<p>Connectez-vous à votre espace client, sélectionnez la commande concernée et suivez les instructions de retour. Un bon de retour prépayé vous sera envoyé par email.</p>" } },
        { "type": "question", "settings": { "question": "Sous quel délai serai-je remboursé ?", "answer": "<p>Le remboursement est effectué sous 5 à 10 jours ouvrés après réception et vérification de l'article retourné, sur le moyen de paiement initial.</p>" } },
        { "type": "category", "settings": { "title": "Paiement & Sécurité" } },
        { "type": "question", "settings": { "question": "Quels moyens de paiement acceptez-vous ?", "answer": "<p>Nous acceptons les cartes bancaires (Visa, Mastercard, American Express), PayPal, Apple Pay et le paiement en 3 fois sans frais via Klarna.</p>" } },
        { "type": "question", "settings": { "question": "Mes données sont-elles sécurisées ?", "answer": "<p>Absolument. Toutes les transactions sont sécurisées par un cryptage SSL. Nous ne conservons jamais vos données bancaires.</p>" } }
      ]
    }
  ]
}
{% endschema %}
