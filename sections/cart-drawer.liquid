<cart-drawer class="cart-drawer-wrapper" id="cart-drawer">
  <div class="cart-drawer">
    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-drawer__header">
      <button class="btn--icon" data-cart-close aria-label="{{ 'accessibility.close_cart' | t }}">
        {% render 'icon', name: 'close', size: 20 %}
      </button>
      <h2 class="cart-drawer__title">{{ 'cart.title' | t }}</h2>
      <span class="cart-drawer__header-icon">
        {% render 'icon', name: 'cart', size: 20 %}
      </span>
    </div>

    {%- comment -%} Body {%- endcomment -%}
    <div class="cart-drawer__body">
      {%- if cart.item_count == 0 -%}
        <div class="cart-drawer__empty">
          <h3 class="cart-drawer__empty-title">{{ 'cart.empty_title' | t }}</h3>
          <p class="cart-drawer__empty-subtitle">{{ 'cart.empty_subtitle' | t }}</p>
          <div class="cart-drawer__empty-cards">
            {%- for block in section.blocks -%}
              {%- if block.type == 'empty_card' -%}
                <a href="{{ block.settings.link }}" class="cart-drawer__empty-card" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.title }}" width="100" loading="lazy">
                  {%- endif -%}
                  <span class="cart-drawer__empty-card-title">{{ block.settings.title }}</span>
                  <span class="cart-drawer__empty-card-cta">{{ 'cart.empty_cta' | t }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}
            {%- if section.blocks.size == 0 -%}
              <a href="/collections/all" class="cart-drawer__empty-card">
                <span class="cart-drawer__empty-card-title">Vêtements Femme</span>
                <span class="cart-drawer__empty-card-cta">{{ 'cart.empty_cta' | t }}</span>
              </a>
              <a href="/collections/all" class="cart-drawer__empty-card">
                <span class="cart-drawer__empty-card-title">Accessoires</span>
                <span class="cart-drawer__empty-card-cta">{{ 'cart.empty_cta' | t }}</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <div class="cart-drawer__items">
          {%- for item in cart.items -%}
            <div class="cart-drawer__item">
              <a href="{{ item.url }}">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.title | escape }}"
                    class="cart-drawer__item-image"
                    width="80"
                    height="100"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>
              <div class="cart-drawer__item-info">
                <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <span class="cart-drawer__item-variant">{{ item.variant.title }}</span>
                {%- endunless -%}
                <span class="cart-drawer__item-price">{{ item.final_line_price | money }}</span>
                <div class="cart-drawer__item-actions">
                  <div class="quantity-stepper" data-line-key="{{ item.key }}">
                    <button type="button" data-qty-minus aria-label="{{ 'cart.quantity' | t }} -">
                      {% render 'icon', name: 'minus', size: 14 %}
                    </button>
                    <input
                      type="number"
                      data-qty-input
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="{{ 'cart.quantity' | t }}"
                    >
                    <button type="button" data-qty-plus aria-label="{{ 'cart.quantity' | t }} +">
                      {% render 'icon', name: 'plus', size: 14 %}
                    </button>
                  </div>
                  <button class="btn--icon" data-remove-item="{{ item.key }}" aria-label="{{ 'cart.remove' | t }}">
                    {% render 'icon', name: 'trash', size: 16 %}
                  </button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Vous aimerez aussi – Recommendations {%- endcomment -%}
        <div class="cart-reco" data-cart-reco data-product-id="{{ cart.items.first.product.id }}">
          <div class="cart-reco__header">
            <h3 class="cart-reco__title">{{ 'product.you_may_like' | t }}</h3>
          </div>
          <div class="cart-reco__scroll" data-cart-reco-scroll>
            {%- comment -%} Products loaded via JS {%- endcomment -%}
          </div>
        </div>

        {%- comment -%} Trust badges {%- endcomment -%}
        <div class="cd-trust">
          <div class="cd-trust__item">
            <span class="cd-trust__icon">{% render 'icon', name: 'truck', size: 18 %}</span>
            <span class="cd-trust__text">Livraison rapide en Europe</span>
          </div>
          <div class="cd-trust__item">
            <span class="cd-trust__icon">{% render 'icon', name: 'return', size: 18 %}</span>
            <span class="cd-trust__text">Retours sous 14 jours</span>
          </div>
          <div class="cd-trust__item">
            <span class="cd-trust__icon">{% render 'icon', name: 'headset', size: 18 %}</span>
            <span class="cd-trust__text">Service client disponible & réactif</span>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer {%- endcomment -%}
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">

        {%- comment -%} Free shipping progress bar {%- endcomment -%}
        {%- assign free_shipping_threshold = settings.cart_free_shipping_threshold | default: '75' | times: 100 -%}
        {%- assign cart_total = cart.total_price -%}
        {%- assign remaining_cents = free_shipping_threshold | minus: cart_total -%}
        <div class="cd-shipping-bar" data-shipping-bar data-threshold="{{ free_shipping_threshold }}">
          {%- if remaining_cents > 0 -%}
            {%- assign remaining_money = remaining_cents | money -%}
            <p class="cd-shipping-bar__text" data-shipping-text>
              Plus que <strong>{{ remaining_money }}</strong> pour profiter de la livraison offerte
            </p>
          {%- else -%}
            <p class="cd-shipping-bar__text cd-shipping-bar__text--success" data-shipping-text>
              Vous bénéficiez de la livraison offerte ✓
            </p>
          {%- endif -%}
          <div class="cd-shipping-bar__track">
            {%- assign progress = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
            {%- if progress > 100 -%}{%- assign progress = 100 -%}{%- endif -%}
            <div class="cd-shipping-bar__fill" style="width: {{ progress }}%;" data-shipping-fill></div>
          </div>
        </div>

        <div class="cart-drawer__subtotal">
          <span class="cart-drawer__subtotal-label">{{ 'cart.subtotal' | t }}</span>
          <span class="cart-drawer__subtotal-price">{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-drawer__shipping-note">{{ 'cart.shipping_note' | t }}</p>
        <a href="{{ routes.cart_url }}/checkout" class="btn btn--primary btn--full btn--large">
          {{ 'cart.checkout' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "class": "cart-drawer-section",
  "settings": [],
  "blocks": [
    {
      "type": "empty_card",
      "name": "Empty state card",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vêtements Femme"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ]
}
{% endschema %}

