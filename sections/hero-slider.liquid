<section class="hero-section" id="home-hero">
  <hero-slider class="hero-slider" data-autoplay="{{ section.settings.autoplay }}" data-interval="{{ section.settings.interval }}">
    <div class="hero-slider__track">
      {%- for block in section.blocks -%}
        <div class="hero-slider__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              alt="{{ block.settings.image.alt | escape }}"
              class="hero-slider__bg"
              width="1920"
              height="{{ 1920 | divided_by: block.settings.image.aspect_ratio | round }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slider__bg hero-slider__placeholder' }}
          {%- endif -%}
          <div class="hero-slider__overlay"></div>
          {%- if block.settings.cta_text != blank -%}
            <a
              href="{{ block.settings.cta_link | default: '#' }}"
              class="hero-slider__cta btn btn--primary btn--large"
              {% if block.settings.cta_bg_color != blank and block.settings.cta_bg_color != 'rgba(0,0,0,0)' %}
                style="--cta-bg:{{ block.settings.cta_bg_color }};--cta-text:{{ block.settings.cta_text_color }};background:var(--cta-bg);color:var(--cta-text);border-color:var(--cta-bg);"
              {% endif %}
            >
              {{ block.settings.cta_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="hero-slider__slide is-active">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-slider__bg hero-slider__placeholder' }}
          <div class="hero-slider__overlay"></div>
          <a href="/collections/all" class="hero-slider__cta btn btn--primary btn--large">DÉCOUVRIR</a>
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="hero-slider__dots">
        {%- for block in section.blocks -%}
          <button
            class="hero-slider__dot{% if forloop.first %} active{% endif %}"
            data-slide-dot
            aria-label="Slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </hero-slider>
</section>

{% schema %}
{
  "name": "Hero slider",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Autoplay interval",
      "min": 3000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "default": 5000
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text",
          "default": "DÉCOUVRIR"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "color",
          "id": "cta_bg_color",
          "label": "CTA background color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "cta_text_color",
          "label": "CTA text color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
