<section class="account-page section">
  <div class="container">
    <div class="account-page__header">
      <h1>{{ 'customer.account.title' | t }}</h1>
      <a href="{{ routes.account_logout_url }}" class="btn btn--secondary">{{ 'customer.account.logout' | t }}</a>
    </div>

    <h2>{{ 'customer.account.orders' | t }}</h2>

    {%- if customer.orders.size > 0 -%}
      <table class="account-page__orders">
        <thead>
          <tr>
            <th>{{ 'customer.account.order_number' | t }}</th>
            <th>{{ 'customer.account.date' | t }}</th>
            <th>{{ 'customer.account.payment_status' | t }}</th>
            <th>{{ 'customer.account.fulfillment_status' | t }}</th>
            <th>{{ 'customer.account.total' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%d/%m/%Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p>{{ 'customer.account.no_orders' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Customer account",
  "class": "customer-account-section",
  "settings": [],
  "presets": [{"name": "Customer account"}]
}
{% endschema %}
