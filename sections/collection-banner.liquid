{%- comment -%}
  Collection Banner — LV luxury style
  Full-width hero with collection image, centered title + breadcrumb
{%- endcomment -%}

<section class="coll-hero">
  {%- if collection.image -%}
    <div class="coll-hero__media">
      <img
        src="{{ collection.image | image_url: width: 1920 }}"
        alt="{{ collection.title | escape }}"
        class="coll-hero__img"
        width="1920"
        height="{{ 1920 | divided_by: collection.image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
        srcset="
          {{ collection.image | image_url: width: 800 }} 800w,
          {{ collection.image | image_url: width: 1200 }} 1200w,
          {{ collection.image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
      >
      <div class="coll-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="coll-hero__content">
    <nav class="coll-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="/">{{ 'general.home' | t | default: 'Accueil' }}</a>
      <span class="coll-hero__breadcrumb-sep">/</span>
      <span>{{ collection.title }}</span>
    </nav>
    <h1 class="coll-hero__title">{{ collection.title }}</h1>
    {%- if collection.description != blank and section.settings.show_description -%}
      <div class="coll-hero__description">{{ collection.description }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "class": "collection-banner-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": false
    }
  ],
  "presets": [{"name": "Collection banner"}]
}
{% endschema %}
