<section class="collection-banner">
  <div class="container">
    <h1 class="collection-banner__title">{{ collection.title }}</h1>
    {%- if collection.description != blank and section.settings.show_description -%}
      <div class="collection-banner__description">{{ collection.description }}</div>
    {%- endif -%}
    <p class="collection-banner__count">
      {{ 'collection.results_count' | t: count: collection.products_count }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "class": "collection-banner-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": false
    }
  ]
}
{% endschema %}
