{%- comment -%}
  Contact page section – Louis Vuitton inspired.
  Block-based contact methods (2×2 grid) + Shopify built-in contact form.
{%- endcomment -%}

<section class="contact-page">
  {%- comment -%} Hero {%- endcomment -%}
  <div class="contact-page__hero">
    <h1 class="contact-page__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="contact-page__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="contact-page__body container">
    {%- comment -%} Contact method blocks – 2×2 grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="contact-page__methods">
        {%- for block in section.blocks -%}
          {%- if block.type == 'contact_method' -%}
            <div class="contact-page__method" {{ block.shopify_attributes }}>
              <h2 class="contact-page__method-title">{{ block.settings.title }}</h2>
              {%- if block.settings.description != blank -%}
                <p class="contact-page__method-desc">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.link_url != blank and block.settings.link_text != blank -%}
                <a href="{{ block.settings.link_url }}" class="contact-page__method-cta"
                  {%- if block.settings.link_url contains 'wa.me' or block.settings.link_url contains 'whatsapp' or block.settings.link_url contains 'http' %} target="_blank" rel="noopener"{% endif -%}
                >
                  {%- if block.settings.icon != blank -%}
                    <span class="contact-page__method-icon">
                      {% render 'icon', name: block.settings.icon, size: 18 %}
                    </span>
                  {%- endif -%}
                  <span class="contact-page__method-link-text">{{ block.settings.link_text }}</span>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Form section {%- endcomment -%}
    <div class="contact-page__form-section">
      <h2 class="contact-page__form-title">{{ section.settings.form_heading | default: 'Envoyez-nous un message' }}</h2>
      {%- if section.settings.form_subtext != blank -%}
        <p class="contact-page__form-sub">{{ section.settings.form_subtext }}</p>
      {%- endif -%}

      {%- form 'contact', class: 'contact-page__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-page__success">
            <p>Merci pour votre message. Nous vous répondrons dans les plus brefs délais.</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="contact-page__errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="contact-page__form-grid">
          <div class="contact-page__field">
            <label for="contact-name" class="contact-page__label">Nom complet</label>
            <input
              type="text"
              id="contact-name"
              name="contact[{{ 'contact.form.name' | t | default: 'Nom' }}]"
              class="contact-page__input"
              required
              autocomplete="name"
            >
          </div>
          <div class="contact-page__field">
            <label for="contact-email" class="contact-page__label">Email</label>
            <input
              type="email"
              id="contact-email"
              name="contact[email]"
              class="contact-page__input"
              required
              autocomplete="email"
            >
          </div>
        </div>

        <div class="contact-page__field">
          <label for="contact-subject" class="contact-page__label">Sujet</label>
          <select id="contact-subject" name="contact[{{ 'contact.form.subject' | t | default: 'Sujet' }}]" class="contact-page__input contact-page__select">
            <option value="">Sélectionnez un sujet</option>
            <option value="Commande">Question sur une commande</option>
            <option value="Livraison">Livraison</option>
            <option value="Retour">Retour ou échange</option>
            <option value="Produit">Question sur un produit</option>
            <option value="Taille">Conseil taille</option>
            <option value="Autre">Autre</option>
          </select>
        </div>

        <div class="contact-page__field">
          <label for="contact-phone" class="contact-page__label">Téléphone <span class="contact-page__optional">(optionnel)</span></label>
          <input
            type="tel"
            id="contact-phone"
            name="contact[{{ 'contact.form.phone' | t | default: 'Téléphone' }}]"
            class="contact-page__input"
            autocomplete="tel"
          >
        </div>

        <div class="contact-page__field">
          <label for="contact-body" class="contact-page__label">Message</label>
          <textarea
            id="contact-body"
            name="contact[body]"
            class="contact-page__input contact-page__textarea"
            rows="6"
            required
          ></textarea>
        </div>

        <button type="submit" class="contact-page__submit">
          Envoyer
        </button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nous contacter",
  "class": "contact-page-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nous contacter"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Notre équipe est à votre écoute pour toute question"
    },
    {
      "type": "header",
      "content": "Formulaire"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Titre du formulaire",
      "default": "Envoyez-nous un message"
    },
    {
      "type": "text",
      "id": "form_subtext",
      "label": "Sous-texte du formulaire",
      "default": "Nous vous répondrons sous 24 à 48 heures ouvrées."
    }
  ],
  "blocks": [
    {
      "type": "contact_method",
      "name": "Méthode de contact",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Téléphone"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Du Lundi au Dimanche de 10h à 19h (CET)."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "phone", "label": "Téléphone" },
            { "value": "whatsapp", "label": "WhatsApp" },
            { "value": "mail", "label": "Email" },
            { "value": "headset", "label": "Live Chat" },
            { "value": "map-pin", "label": "Localisation" },
            { "value": "clock", "label": "Horloge" }
          ],
          "default": "phone"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Texte du lien",
          "default": "Appelez-nous"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "URL du lien"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nous contacter",
      "blocks": [
        {
          "type": "contact_method",
          "settings": {
            "title": "Téléphone",
            "description": "Du Lundi au Dimanche de 10h à 19h (CET).",
            "icon": "phone",
            "link_text": "Appelez-nous"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "title": "WhatsApp",
            "description": "Du Lundi au Dimanche de 10h à 19h (CET).",
            "icon": "whatsapp",
            "link_text": "Contactez-nous sur WhatsApp"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "title": "E-mail",
            "description": "Un conseiller clientèle se chargera d'étudier votre demande",
            "icon": "mail",
            "link_text": "Écrivez-nous"
          }
        },
        {
          "type": "contact_method",
          "settings": {
            "title": "Live Chat",
            "description": "Du Lundi au Dimanche de 10h à 19h (CET).",
            "icon": "headset",
            "link_text": "Envoyez-nous un message"
          }
        }
      ]
    }
  ]
}
{% endschema %}
