{%- liquid
  assign cta_default = section.settings.cta_default | default: 'Découvrir toute la collection'
-%}

<section class="cm-section">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h2 class="cm-title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="cm-mosaic">
      {%- for block in section.blocks limit: 4 -%}
        {%- liquid
          assign col = block.settings.collection
          assign t = block.settings.title_override
          if t == blank and col != blank
            assign t = col.title
          endif
          if t == blank
            assign t = 'Collection'
          endif
          assign img = block.settings.image_override
          if img == blank and col != blank
            assign img = col.image
          endif
          assign cta_text = block.settings.cta_label | default: cta_default
          assign url = col.url | default: '#'
        -%}

        <a href="{{ url }}" class="cm-card cm-card--{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if img != blank -%}
            <img
              src="{{ img | image_url: width: 900 }}"
              alt="{{ t | escape }}"
              class="cm-card__img"
              width="900"
              height="{{ 900 | divided_by: img.aspect_ratio | round }}"
              loading="lazy"
              srcset="
                {{ img | image_url: width: 500 }} 500w,
                {{ img | image_url: width: 700 }} 700w,
                {{ img | image_url: width: 900 }} 900w
              "
              sizes="(min-width: 1024px) 50vw, 100vw"
            >
          {%- else -%}
            <div class="cm-card__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'cm-card__placeholder-svg' }}
            </div>
          {%- endif -%}
          <div class="cm-card__overlay">
            <h3 class="cm-card__name">{{ t }}</h3>
            <span class="cm-card__cta">{{ cta_text }}</span>
          </div>
        </a>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- assign placeholders = 'Nos gilets,Nos pulls,Nos t-shirts,Nos chemises' | split: ',' -%}
        {%- for i in (1..4) -%}
          <a href="#" class="cm-card cm-card--{{ forloop.index }}">
            <div class="cm-card__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'cm-card__placeholder-svg' }}
            </div>
            <div class="cm-card__overlay">
              <h3 class="cm-card__name">{{ placeholders[forloop.index0] }}</h3>
              <span class="cm-card__cta">{{ cta_default }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collections masonry",
  "class": "cm-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "cta_default",
      "label": "Default card CTA text",
      "default": "Découvrir toute la collection"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection tile",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Image override"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections masonry",
      "blocks": [
        { "type": "tile", "settings": { "title_override": "Nos gilets" } },
        { "type": "tile", "settings": { "title_override": "Nos pulls" } },
        { "type": "tile", "settings": { "title_override": "Nos t-shirts" } },
        { "type": "tile", "settings": { "title_override": "Nos chemises" } }
      ]
    }
  ]
}
{% endschema %}
