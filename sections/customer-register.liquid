<section class="login-hero">
  <div class="login-hero__image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>
  <div class="login-hero__content">
    <div class="login-hero__card">
      <h1 class="login-hero__title">{{ 'customer.register.title' | t }}</h1>

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div class="form-errors" role="alert">
            <p>{{ form.errors | default_errors }}</p>
          </div>
        {%- endif -%}

        <div class="form-field">
          <label for="reg-first-name">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" id="reg-first-name" name="customer[first_name]" autocomplete="given-name" required>
        </div>

        <div class="form-field">
          <label for="reg-last-name">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" id="reg-last-name" name="customer[last_name]" autocomplete="family-name" required>
        </div>

        <div class="form-field">
          <label for="reg-email">{{ 'customer.register.email' | t }}</label>
          <input type="email" id="reg-email" name="customer[email]" autocomplete="email" required>
        </div>

        <div class="form-field">
          <label for="reg-password">{{ 'customer.register.password' | t }}</label>
          <div class="form-field__input-wrap">
            <input type="password" id="reg-password" name="customer[password]" autocomplete="new-password" required>
            <button type="button" class="form-field__toggle btn--icon" data-password-toggle aria-label="Show password">
              <span class="icon-eye">{% render 'icon', name: 'eye', size: 18 %}</span>
              <span class="icon-eye-off" style="display:none;">{% render 'icon', name: 'eye-off', size: 18 %}</span>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--large">
          {{ 'customer.register.submit' | t }}
        </button>
      {%- endform -%}

      <div class="login-hero__divider">
        <p class="login-hero__register-text">{{ 'customer.register.have_account' | t }}</p>
        <a href="{{ routes.account_login_url }}" class="btn btn--secondary btn--full">
          {{ 'customer.register.sign_in' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer register",
  "class": "customer-register-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    }
  ]
}
{% endschema %}
